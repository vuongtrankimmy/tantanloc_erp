@page "/wms/suppliers"
@rendermode InteractiveServer

<SectionContent SectionName="PageTitle">Nhà cung cấp</SectionContent>

<SectionContent SectionName="PageBreadcrumbs">
    <li class="breadcrumb-item text-muted">
        <a href="/" class="text-muted text-hover-primary">Hệ thống</a>
    </li>
    <li class="breadcrumb-item text-gray-900">Nhà cung cấp</li>
</SectionContent>

<!--begin::Header-->
<div class="d-flex flex-stack mb-5">
    <div>
        <h3 class="fw-bold fs-2 text-gray-900 mb-1">Danh sách Nhà cung cấp</h3>
        <span class="text-muted fs-6">Quản lý và theo dõi thông tin đối tác cung ứng cho ngành Carton</span>
    </div>
    <div class="d-flex align-items-center">
        <button class="btn btn-sm btn-light border d-flex align-items-center me-3">
            <i class="ki-duotone ki-exit-down fs-3 me-2">
                <span class="path1"></span><span class="path2"></span>
            </i>
            Xuất Excel
        </button>
        <button class="btn btn-sm btn-primary d-flex align-items-center">
            <i class="ki-duotone ki-plus fs-3 me-2"></i> Thêm NCC mới
        </button>
    </div>
</div>
<!--end::Header-->

<!--begin::Card-->
<div class="card">
    <div class="card-header border-bottom pt-5">
        <!--begin::Filters-->
        <div class="d-flex w-100 flex-stack mb-5">
            <div class="d-flex align-items-center gap-3">
                <select class="form-select form-select-sm form-select-solid w-200px">
                    <option value="">Nhóm nguyên liệu</option>
                    <option value="PAPER">Giấy cuộn</option>
                    <option value="GLUE">Keo</option>
                    <option value="INK">Mực in</option>
                </select>
                <select class="form-select form-select-sm form-select-solid w-200px">
                    <option value="">Tất cả trạng thái</option>
                    <option value="ACTIVE">Đang hợp tác</option>
                    <option value="PENDING">Chờ duyệt HĐ</option>
                    <option value="PAUSED">Tạm dừng</option>
                    <option value="STOPPED">Ngừng hợp tác</option>
                </select>
            </div>
            
            <div class="d-flex align-items-center gap-3">
                <button class="btn btn-sm btn-icon btn-light border">
                    <i class="ki-duotone ki-filter fs-2"><span class="path1"></span><span class="path2"></span></i>
                </button>
                <button class="btn btn-sm btn-icon btn-light border">
                    <i class="ki-duotone ki-arrows-circle fs-2"><span class="path1"></span><span class="path2"></span></i>
                </button>
            </div>
        </div>
        <!--end::Filters-->
    </div>
    
    <div class="card-body py-4">
        <!--begin::Table-->
        <div class="table-responsive">
            <table class="table align-middle table-row-dashed fs-6 gy-5">
                <thead>
                    <tr class="text-start text-muted fw-bold fs-7 text-uppercase gs-0 border-bottom border-gray-200">
                        <th class="min-w-125px ps-4">Mã NCC</th>
                        <th class="min-w-250px">Tên nhà cung cấp</th>
                        <th class="min-w-150px">Người liên hệ</th>
                        <th class="min-w-125px">Số điện thoại</th>
                        <th class="min-w-125px">Nhóm nguyên liệu</th>
                        <th class="min-w-125px">Trạng thái</th>
                        <th class="text-end min-w-100px pe-4">Thao tác</th>
                    </tr>
                </thead>
                <tbody class="text-gray-600 fw-semibold">
                    @foreach (var supplier in Suppliers)
                    {
                        <tr>
                            <td class="ps-4">
                                <a href="#" class="text-primary fw-bold text-hover-primary mb-1">@supplier.Code</a>
                            </td>
                            <td>
                                <div class="d-flex flex-column">
                                    <span class="text-gray-800 fw-bold mb-1">@supplier.Name</span>
                                    <span class="text-muted fs-7">@supplier.Address</span>
                                </div>
                            </td>
                            <td>
                                @supplier.ContactPerson
                            </td>
                            <td>
                                @supplier.PhoneNumber
                            </td>
                            <td>
                                <span class="badge badge-light-@(GetCategoryColor(supplier.Category)) fw-bold px-3 py-2">@supplier.Category</span>
                            </td>
                            <td>
                                <span class="badge badge-light-@(GetStatusColor(supplier.Status)) fw-bold px-3 py-2 d-inline-flex align-items-center">
                                    <span class="bullet bullet-dot bg-@(GetStatusColor(supplier.Status)) me-2"></span> @supplier.Status
                                </span>
                            </td>
                            <td class="text-end pe-4">
                                <button class="btn btn-icon btn-active-light-primary w-30px h-30px me-3">
                                    <i class="ki-duotone ki-pencil fs-3"><span class="path1"></span><span class="path2"></span></i>
                                </button>
                                <button class="btn btn-icon btn-active-light-danger w-30px h-30px">
                                    <i class="ki-duotone ki-trash fs-3"><span class="path1"></span><span class="path2"></span><span class="path3"></span><span class="path4"></span><span class="path5"></span></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <!--end::Table-->

        <!--begin::Pagination-->
        <div class="d-flex flex-stack border-top pt-5 px-4">
            <div class="fs-6 fw-semibold text-gray-700">
                Hiển thị 1 đến 5 trong số 124 nhà cung cấp
            </div>
            <ul class="pagination">
                <li class="page-item previous disabled"><a href="#" class="page-link"><i class="previous"></i></a></li>
                <li class="page-item active"><a href="#" class="page-link">1</a></li>
                <li class="page-item"><a href="#" class="page-link">2</a></li>
                <li class="page-item"><a href="#" class="page-link">3</a></li>
                <li class="page-item"><a href="#" class="page-link">...</a></li>
                <li class="page-item"><a href="#" class="page-link">25</a></li>
                <li class="page-item next"><a href="#" class="page-link"><i class="next"></i></a></li>
            </ul>
        </div>
        <!--end::Pagination-->
    </div>
</div>
<!--end::Card-->
