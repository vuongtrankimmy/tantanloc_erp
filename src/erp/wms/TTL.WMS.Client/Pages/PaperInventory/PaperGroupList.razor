@page "/wms/paper-inventory/groups"
@namespace TTL.WMS.Client.Pages.PaperInventory

<div class="d-flex flex-column flex-column-fluid">
    <!--begin::Toolbar-->
    <div id="kt_app_toolbar" class="app-toolbar py-3 py-lg-6">
        <div id="kt_app_toolbar_container" class="app-container container-fluid d-flex flex-stack">
            <!--begin::Page title-->
            <div class="page-title d-flex flex-column justify-content-center flex-wrap me-3">
                <h1 class="page-heading d-flex text-gray-900 fw-bold fs-2 flex-column justify-content-center my-0">Quản lý Nhóm Giấy Dùng Chung</h1>
                <ul class="breadcrumb breadcrumb-separatorless fw-semibold fs-7 my-0 pt-1">
                    <li class="breadcrumb-item text-muted">Theo dõi tồn kho, giữ chỗ và vật tư cụ thể theo từng phân nhóm.</li>
                </ul>
            </div>
            <!--end::Page title-->
            <!--begin::Actions-->
            <div class="d-flex align-items-center gap-2 gap-lg-3">
                <a href="#" class="btn btn-sm btn-light fw-bold border border-gray-300">
                    <i class="ki-duotone ki-filter fs-6 text-muted me-1"><span class="path1"></span><span class="path2"></span></i>Bộ lọc
                </a>
                <a href="/wms/paper-inventory/groups/create" class="btn btn-sm btn-primary fw-bold">
                    <i class="ki-duotone ki-plus fs-2"></i>Thêm nhóm mới
                </a>
                <a href="#" class="btn btn-sm btn-light-primary fw-bold">
                    <i class="ki-duotone ki-file-down fs-2"><span class="path1"></span><span class="path2"></span></i>Xuất báo cáo
                </a>
            </div>
            <!--end::Actions-->
        </div>
    </div>
    <!--end::Toolbar-->

    <!--begin::Content-->
    <div id="kt_app_content" class="app-content flex-column-fluid">
        <div id="kt_app_content_container" class="app-container container-fluid">
            <!--begin::Stats-->
            <div class="row g-5 g-xl-8 mb-8">
                <!-- Stat Card 1 -->
                <div class="col-xl-3">
                    <div class="card card-xl-stretch border border-gray-200 shadow-sm h-100">
                        <div class="card-body p-6">
                            <div class="d-flex align-items-center justify-content-between mb-4">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="symbol symbol-40px symbol-light-primary rounded">
                                        <span class="symbol-label">
                                            <i class="ki-duotone ki-clipboard fs-2 text-primary"><span class="path1"></span><span class="path2"></span><span class="path3"></span></i>
                                        </span>
                                    </div>
                                    <div class="text-gray-500 fw-bold fs-8 text-uppercase tracking-wider">THỰC TẾ (TỒN KHO THỰC TẾ)</div>
                                </div>
                                <span class="badge badge-light-success fw-bold px-2 py-1">+12%</span>
                            </div>
                            <div class="d-flex align-items-baseline">
                                <div class="fs-1 fw-bold text-gray-900 me-2">1,240,500</div>
                            </div>
                            <div class="text-muted fs-8 mt-1 fst-italic">Thực tế (TỒN KHO THỰC TẾ)</div>
                        </div>
                    </div>
                </div>
                <!-- Stat Card 2 -->
                <div class="col-xl-3">
                    <div class="card card-xl-stretch border border-gray-200 shadow-sm h-100">
                        <div class="card-body p-6">
                            <div class="d-flex align-items-center justify-content-between mb-4">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="symbol symbol-40px symbol-light-warning rounded">
                                        <span class="symbol-label">
                                            <i class="ki-duotone ki-truck fs-2 text-warning"><span class="path1"></span><span class="path2"></span><span class="path3"></span><span class="path4"></span><span class="path5"></span></i>
                                        </span>
                                    </div>
                                    <div class="text-gray-500 fw-bold fs-8 text-uppercase tracking-wider">HÀNG VỀ (HÀNG ĐANG VỀ)</div>
                                </div>
                                <span class="badge badge-light-warning fw-bold px-2 py-1">Đang xử lý</span>
                            </div>
                            <div class="d-flex align-items-baseline">
                                <div class="fs-1 fw-bold text-gray-900 me-2">315,000</div>
                            </div>
                            <div class="text-muted fs-8 mt-1 fst-italic">Hàng về (HÀNG ĐANG VỀ)</div>
                        </div>
                    </div>
                </div>
                <!-- Stat Card 3 -->
                <div class="col-xl-3">
                    <div class="card card-xl-stretch border border-gray-200 shadow-sm h-100">
                        <div class="card-body p-6">
                            <div class="d-flex align-items-center justify-content-between mb-4">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="symbol symbol-40px symbol-light-danger rounded">
                                        <span class="symbol-label">
                                            <i class="ki-duotone ki-bookmark fs-2 text-danger"><span class="path1"></span><span class="path2"></span></i>
                                        </span>
                                    </div>
                                    <div class="text-gray-500 fw-bold fs-8 text-uppercase tracking-wider">GIỮ CHỖ (GIỮ CHỖ)</div>
                                </div>
                                <span class="badge badge-light-danger fw-bold px-2 py-1">Chờ xuất</span>
                            </div>
                            <div class="d-flex align-items-baseline">
                                <div class="fs-1 fw-bold text-gray-900 me-2">182,300</div>
                            </div>
                            <div class="text-muted fs-8 mt-1 fst-italic">Giữ chỗ (GIỮ CHỖ)</div>
                        </div>
                    </div>
                </div>
                <!-- Stat Card 4 -->
                <div class="col-xl-3">
                    <div class="card card-xl-stretch border border-gray-200 shadow-sm h-100">
                        <div class="card-body p-6">
                            <div class="d-flex align-items-center justify-content-between mb-4">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="symbol symbol-40px symbol-light-success rounded">
                                        <span class="symbol-label">
                                            <i class="ki-duotone ki-check-circle fs-2 text-success"><span class="path1"></span><span class="path2"></span></i>
                                        </span>
                                    </div>
                                    <div class="text-gray-500 fw-bold fs-8 text-uppercase tracking-wider">KHẢ DỤNG (KHẢ DỤNG)</div>
                                </div>
                                <span class="badge badge-light-success fw-bold px-2 py-1">Sẵn sàng</span>
                            </div>
                            <div class="d-flex align-items-baseline">
                                <div class="fs-1 fw-bold text-gray-900 me-2">1,373,200</div>
                            </div>
                            <div class="text-muted fs-8 mt-1 fst-italic">Khả dụng (KHẢ DỤNG)</div>
                        </div>
                    </div>
                </div>
            </div>
            <!--end::Stats-->

            <!--begin::Table-->
            <div class="card card-flush border border-gray-200 shadow-sm">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table align-middle table-row-dashed fs-6 gy-5 mb-0" id="kt_paper_group_table">
                            <thead class="bg-light">
                                <tr class="text-start text-gray-500 fw-bold fs-8 text-uppercase gs-0">
                                    <th class="w-50px text-center ps-4">#</th>
                                    <th class="min-w-250px">Thông tin nhóm</th>
                                    <th class="min-w-400px pe-4">
                                        <div class="d-flex align-items-center justify-content-between">
                                            <span>Phân tích số lượng (kg)</span>
                                            <div class="d-flex align-items-center fs-9 fw-normal text-muted gap-3 text-lowercase">
                                                <div class="d-flex align-items-center"><span class="bullet bullet-dot bg-warning me-1"></span>giữ chỗ (po)</div>
                                                <div class="d-flex align-items-center"><span class="bullet bullet-dot bg-primary me-1"></span>đang về</div>
                                                <div class="d-flex align-items-center"><span class="bullet bullet-dot bg-success me-1"></span>khả dụng</div>
                                                <div class="d-flex align-items-center"><span class="bullet bullet-dot bg-danger me-1"></span>đang xuất sx</div>
                                                <div class="d-flex align-items-center"><span class="bullet bullet-dot me-1" style="background-color: #d97706 !important;"></span>đặt trước</div>
                                            </div>
                                        </div>
                                    </th>
                                </tr>
                            </thead>
                            <tbody class="fw-semibold text-gray-600">
                                <!-- Row 1 -->
                                <tr>
                                    <td class="text-center ps-4">
                                        <button class="btn btn-icon btn-sm btn-light btn-active-light-primary toggle h-25px w-25px" @onclick="() => ToggleRow(1)">
                                            <i class="ki-duotone @(expandedRow == 1 ? "ki-up" : "ki-down") fs-3 m-0"></i>
                                        </button>
                                    </td>
                                    <td>
                                        <div class="d-flex flex-column">
                                            <a href="#" class="text-gray-900 text-hover-primary fw-bold mb-1 fs-6" data-kt-drawer-show="true" data-kt-drawer-target="#kt_drawer_paper_group_detail">Giấy Kraft Việt Nam ĐL 175</a>
                                            <span class="text-muted fs-8">175 gsm - Industrial Grade</span>
                                        </div>
                                    </td>
                                    <td class="pe-4">
                                        <div class="d-flex flex-column gap-3">
                                            <div class="d-flex align-items-center">
                                                <span class="w-70px text-gray-600 fw-semibold fs-8">TỒN KHO</span>
                                                <div class="flex-grow-1 h-20px d-flex rounded overflow-hidden">
                                                    <div class="bg-warning d-flex justify-content-center align-items-center text-white fs-9 fw-bold px-1" style="width: 15%">67.5k</div>
                                                    <div class="bg-primary d-flex justify-content-center align-items-center text-white fs-9 fw-bold px-1" style="width: 12%">54k</div>
                                                    <div class="bg-success d-flex justify-content-center align-items-center text-white fs-9 fw-bold px-1" style="width: 73%">328.5k</div>
                                                </div>
                                            </div>
                                            <div class="d-flex align-items-center">
                                                <span class="w-70px text-gray-600 fw-semibold fs-8">SỬ DỤNG</span>
                                                <div class="flex-grow-1 h-20px d-flex rounded overflow-hidden">
                                                    <div class="bg-danger d-flex justify-content-center align-items-center text-white fs-9 fw-bold px-1" style="width: 40%">180k</div>
                                                    <div class="d-flex justify-content-center align-items-center text-white fs-9 fw-bold px-1" style="width: 60%; background-color: #d97706;">270k</div>
                                                </div>
                                            </div>
                                        </div>
                                    </td>
                                </tr>

                                <!-- Row 2 -->
                                <tr class="@(expandedRow == 2 ? "bg-light-primary" : "") border-top border-gray-200">
                                    <td class="text-center ps-4">
                                        <button class="btn btn-icon btn-sm btn-light btn-active-light-primary toggle h-25px w-25px @(expandedRow == 2 ? "active" : "")" @onclick="() => ToggleRow(2)">
                                            <i class="ki-duotone @(expandedRow == 2 ? "ki-up" : "ki-down") fs-3 m-0"></i>
                                        </button>
                                    </td>
                                    <td class="border-start-0 border-end-0 @(expandedRow == 2 ? "border-primary border-start border-start-3" : "")">
                                        <div class="d-flex flex-column">
                                            <span class="@(expandedRow == 2 ? "text-primary" : "text-gray-900") fw-bold mb-1 fs-6">Giấy Kraft Nhật ĐL 125</span>
                                            <span class="text-muted fs-8">125 gsm - Standard Mix</span>
                                        </div>
                                    </td>
                                    <td class="pe-4">
                                        <div class="d-flex flex-column gap-3">
                                            <div class="d-flex align-items-center">
                                                <span class="w-70px text-gray-600 fw-semibold fs-8">TỒN KHO</span>
                                                <div class="flex-grow-1 h-20px d-flex rounded overflow-hidden">
                                                    <div class="bg-warning d-flex justify-content-center align-items-center text-white fs-9 fw-bold px-1" style="width: 20%">160k</div>
                                                    <div class="bg-primary d-flex justify-content-center align-items-center text-white fs-9 fw-bold px-1" style="width: 30%">240k</div>
                                                    <div class="bg-success d-flex justify-content-center align-items-center text-white fs-9 fw-bold px-1" style="width: 50%">400k</div>
                                                </div>
                                            </div>
                                            <div class="d-flex align-items-center">
                                                <span class="w-70px text-gray-600 fw-semibold fs-8">SỬ DỤNG</span>
                                                <div class="flex-grow-1 h-20px d-flex rounded overflow-hidden">
                                                    <div class="bg-danger d-flex justify-content-center align-items-center text-white fs-9 fw-bold px-1" style="width: 20%">120k</div>
                                                    <div class="d-flex justify-content-center align-items-center text-white fs-9 fw-bold px-1" style="width: 80%; background-color: #d97706;">480k</div>
                                                </div>
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                                <!-- Expanded content for Row 2 -->
                                @if (expandedRow == 2)
                                {
                                    <tr class="bg-light-primary">
                                        <td colspan="3" class="p-0 border-0">
                                            <div class="px-5 pb-5">
                                                <div class="border border-gray-200 bg-white rounded shadow-sm">
                                                    <table class="table align-middle table-row-dashed fs-6 gy-4 mb-0">
                                                        <thead class="bg-light">
                                                            <tr class="text-start text-gray-500 fw-bold fs-8 text-uppercase gs-0">
                                                                <th class="w-30px text-center ps-4">
                                                                    <i class="ki-duotone ki-element-11 fs-5">
                                                                        <span class="path1"></span><span class="path2"></span><span class="path3"></span><span class="path4"></span>
                                                                    </i>
                                                                </th>
                                                                <th class="min-w-100px">THÔNG TIN NHÓM</th>
                                                                <th class="min-w-200px">TÊN VẬT TƯ</th>
                                                                <th class="text-center min-w-80px">SỐ CUỘN</th>
                                                                <th class="text-end min-w-100px">TỒN THỰC TẾ (KG)</th>
                                                                <th class="text-center min-w-100px">TỒN LÂU NHẤT</th>
                                                                <th class="text-center min-w-100px pe-4">PHÂN TÍCH SỐ LƯỢNG (KG)</th>
                                                            </tr>
                                                        </thead>
                                                        <tbody class="fw-semibold text-gray-600">
                                                            <tr>
                                                                <td class="text-center ps-4">
                                                                    <i class="ki-duotone ki-element-11 fs-5 text-gray-400">
                                                                        <span class="path1"></span><span class="path2"></span><span class="path3"></span><span class="path4"></span>
                                                                    </i>
                                                                </td>
                                                                <td class="text-gray-900 fw-bold">KN-125-1100</td>
                                                                <td>
                                                                    <div class="d-flex flex-column">
                                                                        <span class="text-gray-800">Giấy Kraft Nhật 125gsm - Loại A</span>
                                                                        <span class="text-muted fs-8">Khổ 1100 mm</span>
                                                                    </div>
                                                                </td>
                                                                <td class="text-center text-gray-900 fw-bold">12</td>
                                                                <td class="text-end text-gray-900">45,000</td>
                                                                <td class="text-center text-gray-600">12/08/2023</td>
                                                                <td class="text-center pe-4"><span class="badge badge-light-success text-success fw-bold px-3 py-1">ỔN ĐỊNH</span></td>
                                                            </tr>
                                                            <tr>
                                                                <td class="text-center ps-4">
                                                                    <i class="ki-duotone ki-element-11 fs-5 text-gray-400">
                                                                        <span class="path1"></span><span class="path2"></span><span class="path3"></span><span class="path4"></span>
                                                                    </i>
                                                                </td>
                                                                <td class="text-gray-900 fw-bold">KN-125-1200</td>
                                                                <td>
                                                                    <div class="d-flex flex-column">
                                                                        <span class="text-gray-800">Giấy Kraft Nhật 125gsm - Tiêu chuẩn</span>
                                                                        <span class="text-muted fs-8">Khổ 1200 mm</span>
                                                                    </div>
                                                                </td>
                                                                <td class="text-center text-gray-900 fw-bold">15</td>
                                                                <td class="text-end text-gray-900">60,000</td>
                                                                <td class="text-center text-gray-600">05/09/2023</td>
                                                                <td class="text-center pe-4"><span class="badge badge-light-success text-success fw-bold px-3 py-1">ỔN ĐỊNH</span></td>
                                                            </tr>
                                                            <tr>
                                                                <td class="text-center ps-4">
                                                                    <i class="ki-duotone ki-element-11 fs-5 text-gray-400">
                                                                        <span class="path1"></span><span class="path2"></span><span class="path3"></span><span class="path4"></span>
                                                                    </i>
                                                                </td>
                                                                <td class="text-gray-900 fw-bold">KN-125-1300</td>
                                                                <td>
                                                                    <div class="d-flex flex-column">
                                                                        <span class="text-gray-800">Giấy Kraft Nhật 125gsm - Cuộn lẻ</span>
                                                                        <span class="text-muted fs-8">Khổ 1300 mm</span>
                                                                    </div>
                                                                </td>
                                                                <td class="text-center text-gray-900 fw-bold">5</td>
                                                                <td class="text-end text-gray-900">20,000</td>
                                                                <td class="text-center text-gray-600">20/07/2023</td>
                                                                <td class="text-center pe-4"><span class="badge badge-light-warning text-warning fw-bold px-3 py-1">THẤP</span></td>
                                                            </tr>
                                                        </tbody>
                                                        <tfoot>
                                                            <tr>
                                                                <td colspan="7" class="bg-light-secondary px-5 py-3 border-top border-gray-200">
                                                                    <div class="d-flex justify-content-between align-items-center">
                                                                        <span class="text-muted fs-8 fst-italic">Hiển thị 3 mã vật tư thuộc nhóm KN-125 (Kéo thả để ưu tiên sử dụng)</span>
                                                                        <a href="#" class="text-primary fw-bold fs-8 text-uppercase">XEM THÊM CHI TIẾT</a>
                                                                    </div>
                                                                </td>
                                                            </tr>
                                                        </tfoot>
                                                    </table>
                                                </div>
                                            </div>
                                        </td>
                                    </tr>
                                }

                                <!-- Row 3 -->
                                <tr class="border-top border-gray-200">
                                    <td class="text-center ps-4">
                                        <button class="btn btn-icon btn-sm btn-light btn-active-light-primary toggle h-25px w-25px" @onclick="() => ToggleRow(3)">
                                            <i class="ki-duotone @(expandedRow == 3 ? "ki-up" : "ki-down") fs-3 m-0"></i>
                                        </button>
                                    </td>
                                    <td>
                                        <div class="d-flex flex-column">
                                            <span class="text-gray-900 fw-bold mb-1 fs-6">Giấy Ford Trắng ĐL 80</span>
                                            <span class="text-muted fs-8">80 gsm - Office Premium</span>
                                        </div>
                                    </td>
                                    <td class="pe-4">
                                        <div class="d-flex flex-column gap-3">
                                            <div class="d-flex align-items-center">
                                                <span class="w-70px text-gray-600 fw-semibold fs-8">TỒN KHO</span>
                                                <div class="flex-grow-1 h-20px d-flex rounded overflow-hidden">
                                                    <div class="bg-warning d-flex justify-content-center align-items-center text-white fs-9 fw-bold px-1" style="width: 10%">10k</div>
                                                    <div class="bg-primary d-flex justify-content-center align-items-center text-white fs-9 fw-bold px-1" style="width: 10%">20k</div>
                                                    <div class="bg-success d-flex justify-content-center align-items-center text-white fs-9 fw-bold px-1" style="width: 80%">170k</div>
                                                </div>
                                            </div>
                                            <div class="d-flex align-items-center">
                                                <span class="w-70px text-gray-600 fw-semibold fs-8">SỬ DỤNG</span>
                                                <div class="flex-grow-1 h-20px d-flex rounded overflow-hidden">
                                                    <div class="bg-danger d-flex justify-content-center align-items-center text-white fs-9 fw-bold px-1" style="width: 75%">225k</div>
                                                    <div class="d-flex justify-content-center align-items-center text-white fs-9 fw-bold px-1" style="width: 25%; background-color: #d97706;">75k</div>
                                                </div>
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                    <!-- Pagination -->
                    <div class="d-flex flex-stack flex-wrap p-5 border-top border-gray-200 bg-light">
                        <div class="fs-6 fw-semibold text-gray-500">Đang hiển thị 1-10 trên 45 nhóm giấy</div>
                        <ul class="pagination mb-0">
                            <li class="page-item previous disabled"><a href="#" class="page-link"><i class="previous"></i></a></li>
                            <li class="page-item active"><a href="#" class="page-link">1</a></li>
                            <li class="page-item"><a href="#" class="page-link">2</a></li>
                            <li class="page-item"><a href="#" class="page-link">3</a></li>
                            <li class="page-item next"><a href="#" class="page-link"><i class="next"></i></a></li>
                        </ul>
                    </div>
                </div>
            </div>
            <!--end::Table-->

        </div>
    </div>
    <!--end::Content-->
</div>

<TTL.WMS.Client.Pages.PaperInventory.Components.PaperGroupDetailDrawer />

<style>
    .tracking-wider {
        letter-spacing: 0.05em;
    }
    .border-start-3 {
        border-left-width: 3px !important;
    }
</style>

@code {
    private int expandedRow = 2; // Default to row 2 expanded as in mockup

    private void ToggleRow(int rowId)
    {
        if (expandedRow == rowId)
        {
            expandedRow = 0;
        }
        else
        {
            expandedRow = rowId;
        }
    }
}
