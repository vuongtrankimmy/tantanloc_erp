@namespace TTL.WMS.Client.Pages.PaperInventory.Components

<div id="kt_drawer_paper_group_detail" class="bg-body" data-kt-drawer="true" data-kt-drawer-name="paper_group_detail" data-kt-drawer-activate="true" data-kt-drawer-overlay="true" data-kt-drawer-width="{default:'300px', 'md': '600px'}" data-kt-drawer-direction="end" data-kt-drawer-toggle="#kt_drawer_paper_group_detail_toggle" data-kt-drawer-close="#kt_drawer_paper_group_detail_close">
    <!--begin::Card-->
    <div class="card shadow-none rounded-0 w-100 d-flex flex-column h-100">
        <!--begin::Header-->
        <div class="card-header border-bottom border-gray-200 py-6" id="kt_drawer_paper_group_detail_header">
            <div class="card-title flex-column">
                <div class="d-flex align-items-center mb-2">
                    <i class="ki-duotone ki-document text-primary fs-3 me-2"><span class="path1"></span><span class="path2"></span></i>
                    <span class="text-primary fw-bold text-uppercase fs-8 tracking-wider">THÔNG TIN CHI TIẾT</span>
                </div>
                <h3 class="fw-bold text-gray-900 fs-3 m-0 d-flex flex-column">
                    <span>Chi tiết sử dụng Nhóm giấy:</span>
                    <span class="text-primary fs-2">Giấy Kraft Việt Nam ĐL 175</span>
                </h3>
            </div>
            <div class="card-toolbar">
                <div class="btn btn-icon btn-sm btn-active-light-primary" id="kt_drawer_paper_group_detail_close">
                    <i class="ki-duotone ki-cross fs-2"><span class="path1"></span><span class="path2"></span></i>
                </div>
            </div>
        </div>
        <!--end::Header-->

        <!--begin::Body-->
        <div class="card-body px-0 py-5" id="kt_drawer_paper_group_detail_body">
            <div class="scroll-y px-5 px-lg-8 h-100" data-kt-scroll="true" data-kt-scroll-activate="true" data-kt-scroll-max-height="auto" data-kt-scroll-dependencies="#kt_drawer_paper_group_detail_header, #kt_drawer_paper_group_detail_footer" data-kt-scroll-wrappers="#kt_drawer_paper_group_detail_body" data-kt-scroll-offset="0px">
                
                <div class="d-flex flex-column gap-5">
                    <!-- Item 1 -->
                    <div class="border border-gray-200 rounded p-0 d-flex flex-column bg-white shadow-sm">
                        <div class="p-6 pb-4">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span class="text-muted fw-semibold fs-8 text-uppercase">MÃ SẢN PHẨM: TP-KFT-3L-102</span>
                                <span class="badge badge-light-success text-success fw-bold px-3 py-1">Đang sử dụng</span>
                            </div>
                            <div class="text-gray-900 fw-bold fs-4 mb-2">Giấy tấm 3 lớp - Thùng A1 Standard</div>
                            <div class="text-gray-600 fs-7 mb-4">Kích thước tấm: 1200 x 800 mm</div>
                            <div class="d-flex align-items-center gap-6">
                                <div class="d-flex align-items-center gap-2">
                                    <span class="text-gray-500 fw-bold fs-8">SỐ CON:</span>
                                    <span class="text-gray-900 fw-bold fs-7">4</span>
                                </div>
                                <div class="d-flex align-items-center gap-2">
                                    <span class="text-gray-500 fw-bold fs-8">ĐÃ SẢN XUẤT:</span>
                                    <span class="text-gray-900 fw-bold fs-7">1,200</span>
                                </div>
                            </div>
                        </div>
                        <div class="table-responsive border-top border-gray-200">
                            <table class="table align-middle table-row-dashed fs-6 gy-3 mb-0">
                                <thead>
                                    <tr class="text-start text-gray-500 fw-bold fs-8 text-uppercase gs-0 bg-light">
                                        <th class="ps-6">LỚP</th>
                                        <th class="text-end pe-6">TRỌNG LƯỢNG (KG)</th>
                                    </tr>
                                </thead>
                                <tbody class="fw-semibold text-gray-700">
                                    <tr class="bg-light-primary">
                                        <td class="ps-6">
                                            <div class="d-flex align-items-center text-primary fw-bold">
                                                <span class="bullet bullet-dot bg-primary me-2"></span>Mặt
                                            </div>
                                        </td>
                                        <td class="text-end pe-6 text-primary fw-bold">0.4 / 1.6</td>
                                    </tr>
                                    <tr>
                                        <td class="ps-6">Đáy</td>
                                        <td class="text-end pe-6 text-gray-600">0.4 / 1.6</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <!-- Item 2 -->
                    <div class="border border-gray-200 rounded p-0 d-flex flex-column bg-white shadow-sm">
                        <div class="p-6 pb-4">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span class="text-muted fw-semibold fs-8 text-uppercase">MÃ SẢN PHẨM: TP-ECOM-5L-V2</span>
                                <span class="badge badge-light text-gray-700 fw-bold px-3 py-1">Ngưng sử dụng</span>
                            </div>
                            <div class="text-gray-900 fw-bold fs-4 mb-2">Giấy tấm 5 lớp - Hộp Thương mại điện tử</div>
                            <div class="text-gray-600 fs-7 mb-4">Kích thước tấm: 600 x 400 mm</div>
                            <div class="d-flex align-items-center gap-6">
                                <div class="d-flex align-items-center gap-2">
                                    <span class="text-gray-500 fw-bold fs-8">SỐ CON:</span>
                                    <span class="text-gray-900 fw-bold fs-7">6</span>
                                </div>
                                <div class="d-flex align-items-center gap-2">
                                    <span class="text-gray-500 fw-bold fs-8">ĐÃ SẢN XUẤT:</span>
                                    <span class="text-gray-900 fw-bold fs-7">0</span>
                                </div>
                            </div>
                        </div>
                        <div class="table-responsive border-top border-gray-200">
                            <table class="table align-middle table-row-dashed fs-6 gy-3 mb-0">
                                <thead>
                                    <tr class="text-start text-gray-500 fw-bold fs-8 text-uppercase gs-0 bg-light">
                                        <th class="ps-6">LỚP</th>
                                        <th class="text-end pe-6">TRỌNG LƯỢNG (KG)</th>
                                    </tr>
                                </thead>
                                <tbody class="fw-semibold text-gray-700">
                                    <tr>
                                        <td class="ps-6">Sóng A</td>
                                        <td class="text-end pe-6 text-gray-600">0.5 / 3.0</td>
                                    </tr>
                                    <tr>
                                        <td class="ps-6">Sóng B</td>
                                        <td class="text-end pe-6 text-gray-600">0.6 / 3.6</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <!-- Item 3 -->
                    <div class="border border-gray-200 rounded p-0 d-flex flex-column bg-white shadow-sm mb-5">
                        <div class="p-6 pb-4">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span class="text-muted fw-semibold fs-8 text-uppercase">MÃ SẢN PHẨM: TP-PRM-3L-GIFT</span>
                                <span class="badge badge-light-success text-success fw-bold px-3 py-1">Đang sử dụng</span>
                            </div>
                            <div class="text-gray-900 fw-bold fs-4 mb-2">Hộp quà tặng cao cấp 3 lớp</div>
                            <div class="text-gray-600 fs-7 mb-4">Kích thước tấm: 800 x 600 mm</div>
                            <div class="d-flex align-items-center gap-6">
                                <div class="d-flex align-items-center gap-2">
                                    <span class="text-gray-500 fw-bold fs-8">SỐ CON:</span>
                                    <span class="text-gray-900 fw-bold fs-7">5</span>
                                </div>
                                <div class="d-flex align-items-center gap-2">
                                    <span class="text-gray-500 fw-bold fs-8">ĐÃ SẢN XUẤT:</span>
                                    <span class="text-gray-900 fw-bold fs-7">2,500</span>
                                </div>
                            </div>
                        </div>
                        <div class="table-responsive border-top border-gray-200">
                            <table class="table align-middle table-row-dashed fs-6 gy-3 mb-0">
                                <thead>
                                    <tr class="text-start text-gray-500 fw-bold fs-8 text-uppercase gs-0 bg-light">
                                        <th class="ps-6">LỚP</th>
                                        <th class="text-end pe-6">TRỌNG LƯỢNG (KG)</th>
                                    </tr>
                                </thead>
                                <tbody class="fw-semibold text-gray-700">
                                    <tr>
                                        <td class="ps-6">Mặt</td>
                                        <td class="text-end pe-6 text-gray-600">0.3 / 1.5</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>

                </div>

            </div>
        </div>
        <!--end::Body-->

        <!--begin::Footer-->
        <div class="card-footer border-top border-gray-200 d-flex justify-content-between align-items-center py-5 px-8 bg-white" id="kt_drawer_paper_group_detail_footer">
            <div class="d-flex flex-column">
                <span class="text-muted fw-bold fs-8 text-uppercase mb-1">TỔNG SỬ DỤNG NHÓM GIẤY</span>
                <span class="text-primary fw-bold fs-2">1,625.5 Kg</span>
            </div>
            <div class="d-flex gap-3">
                <button type="button" class="btn btn-light fw-bold border border-gray-300">Xuất báo cáo</button>
                <button type="button" class="btn btn-primary fw-bold">Xác nhận phân bổ</button>
            </div>
        </div>
        <!--end::Footer-->
    </div>
    <!--end::Card-->
</div>

<style>
    .tracking-wider {
        letter-spacing: 0.05em;
    }
</style>
