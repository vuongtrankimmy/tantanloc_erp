@page "/wms/finished-products/paper-boards"
@namespace TTL.WMS.Client.Pages.FinishedProducts

<div class="d-flex flex-column flex-column-fluid">
    <!--begin::Toolbar-->
    <div id="kt_app_toolbar" class="app-toolbar py-3 py-lg-6">
        <div id="kt_app_toolbar_container" class="app-container container-fluid d-flex flex-stack">
            <!--begin::Page title-->
            <div class="page-title d-flex flex-column justify-content-center flex-wrap me-3">
                <h1 class="page-heading d-flex text-gray-900 fw-bold fs-2 flex-column justify-content-center my-0">Quản lý Giấy tấm Thành phẩm</h1>
                <ul class="breadcrumb breadcrumb-separatorless fw-semibold fs-7 my-0 pt-1">
                    <li class="breadcrumb-item text-muted">Theo dõi tồn kho, điều phối vận chuyển và quản lý lệnh sản xuất tấm phôi.</li>
                </ul>
            </div>
            <!--end::Page title-->
            <!--begin::Actions-->
            <div class="d-flex align-items-center gap-2 gap-lg-3">
                <a href="#" class="btn btn-sm btn-light fw-bold border border-gray-300">
                    <i class="ki-duotone ki-filter fs-6 text-muted me-1"><span class="path1"></span><span class="path2"></span></i>Bộ lọc trạng thái
                </a>
                <a href="#" class="btn btn-sm btn-light fw-bold border border-gray-300">
                    <i class="ki-duotone ki-file-down fs-2 text-gray-600"><span class="path1"></span><span class="path2"></span></i>Xuất báo cáo
                </a>
            </div>
            <!--end::Actions-->
        </div>
    </div>
    <!--end::Toolbar-->

    <!--begin::Content-->
    <div id="kt_app_content" class="app-content flex-column-fluid position-relative">
        <div id="kt_app_content_container" class="app-container container-fluid">
            <!--begin::Stats-->
            <div class="row g-5 g-xl-8 mb-8">
                <!-- Stat Card 1 -->
                <div class="col-xl-3">
                    <div class="card card-xl-stretch border border-gray-200 shadow-sm h-100">
                        <div class="card-body p-6">
                            <div class="text-gray-500 fw-bold fs-8 text-uppercase mb-2 tracking-wider">TỔNG TỒN KHO</div>
                            <div class="d-flex align-items-baseline gap-2 mt-4">
                                <div class="fs-1 fw-bold text-gray-900">45,280</div>
                                <div class="fw-semibold fs-7 text-gray-500">Tấm</div>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- Stat Card 2 -->
                <div class="col-xl-3">
                    <div class="card card-xl-stretch border border-gray-200 shadow-sm h-100 border-start border-primary border-4">
                        <div class="card-body p-6">
                            <div class="text-primary fw-bold fs-8 text-uppercase mb-2 tracking-wider">THEO ĐƠN HÀNG</div>
                            <div class="d-flex align-items-baseline gap-3 mt-4">
                                <div class="fs-1 fw-bold text-primary">32,150</div>
                                <div class="fw-semibold fs-7 text-gray-500">71%</div>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- Stat Card 3 -->
                <div class="col-xl-3">
                    <div class="card card-xl-stretch border border-gray-200 shadow-sm h-100 border-start border-warning border-4" style="border-left-color: #f97316 !important;">
                        <div class="card-body p-6">
                            <div class="fw-bold fs-8 text-uppercase mb-2 tracking-wider" style="color: #ea580c;">HÀNG TỰ DO</div>
                            <div class="d-flex align-items-baseline gap-3 mt-4">
                                <div class="fs-1 fw-bold" style="color: #c2410c;">13,130</div>
                                <div class="fw-semibold fs-7 text-gray-500">29%</div>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- Stat Card 4 -->
                <div class="col-xl-3">
                    <div class="card card-xl-stretch border border-gray-200 shadow-sm h-100 border-start border-danger border-4">
                        <div class="card-body p-6">
                            <div class="text-danger fw-bold fs-8 text-uppercase mb-2 tracking-wider">CHỜ BÁO LỖI</div>
                            <div class="d-flex align-items-baseline gap-3 mt-4">
                                <div class="fs-1 fw-bold text-danger">420</div>
                                <div class="fw-semibold fs-7 text-gray-500">Cần xử lý</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!--end::Stats-->

            <!--begin::Table Card-->
            <div class="card card-flush border border-gray-200 shadow-sm mb-5">
                <!-- Card Header -->
                <div class="card-header border-bottom border-gray-200 pt-5 pb-4">
                    <h3 class="card-title align-items-center">
                        <div class="symbol symbol-35px symbol-light-primary me-3">
                            <span class="symbol-label">
                                <i class="ki-duotone ki-archive fs-2 text-primary"><span class="path1"></span><span class="path2"></span><span class="path3"></span></i>
                            </span>
                        </div>
                        <span class="card-label fw-bold text-gray-900 fs-5">Danh sách thành phẩm lưu kho</span>
                    </h3>
                    <div class="card-toolbar d-flex align-items-center gap-3">
                        <span class="text-muted fs-8">Cập nhật: 10:45 AM</span>
                        <button class="btn btn-icon btn-sm btn-light btn-active-light-primary w-30px h-30px">
                            <i class="ki-duotone ki-arrows-circle fs-3 m-0"><span class="path1"></span><span class="path2"></span></i>
                        </button>
                    </div>
                </div>

                <!-- Card Body -->
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table align-middle table-row-dashed fs-6 gy-5 mb-0" id="kt_finished_paper_table">
                            <thead class="bg-light">
                                <tr class="text-start text-gray-500 fw-bold fs-8 text-uppercase gs-0">
                                    <th class="min-w-300px ps-6">TÊN GIẤY TẤM & KẾT CẤU</th>
                                    <th class="min-w-400px">PHÂN BỔ TỒN KHO (THEO ĐƠN / TỰ DO)</th>
                                    <th class="w-100px text-center pe-6">HÀNH ĐỘNG</th>
                                </tr>
                            </thead>
                            <tbody class="fw-semibold text-gray-600">
                                <!-- Row 1 -->
                                <tr>
                                    <td class="ps-6">
                                        <div class="d-flex flex-column gap-1">
                                            <span class="text-gray-900 fw-bold fs-5">Tấm phôi 3 lớp - 600×400</span>
                                            <span class="text-muted fs-7 text-uppercase tracking-wider">K125 / M125 / K125</span>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="d-flex flex-column gap-2 pe-10">
                                            <div class="d-flex justify-content-between align-items-center fs-8 fw-bold">
                                                <span class="text-primary">2,500</span>
                                                <span class="text-gray-600">500</span>
                                            </div>
                                            <div class="d-flex h-15px rounded overflow-hidden">
                                                <div class="bg-primary d-flex justify-content-center align-items-center text-white fs-9" style="width: 83%">83%</div>
                                                <div class="bg-gray-300 d-flex justify-content-center align-items-center text-gray-600 fs-9" style="width: 17%">17%</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-center pe-6">
                                        <button class="btn btn-icon btn-sm btn-active-light-primary w-30px h-30px" @onclick="() => ToggleRow(1)">
                                            <i class="ki-duotone @(expandedRow == 1 ? "ki-up" : "ki-down") fs-2 text-gray-700 m-0"></i>
                                        </button>
                                    </td>
                                </tr>

                                <!-- Expanded Row 1 -->
                                @if (expandedRow == 1)
                                {
                                    <tr>
                                        <td colspan="3" class="p-0 border-0">
                                            <div class="px-6 py-5">
                                                <div class="border border-gray-200 rounded">
                                                    <!-- Sub header -->
                                                    <div class="d-flex justify-content-between align-items-center px-6 py-4 border-bottom border-gray-200">
                                                        <h4 class="text-gray-700 fw-bold fs-6 m-0 text-uppercase tracking-wider">CHI TIẾT PHÂN BỔ ĐƠN HÀNG</h4>
                                                        <div class="d-flex gap-2">
                                                            <button class="btn btn-sm btn-primary py-2 px-4 fw-bold fs-8">Điều chỉnh SL</button>
                                                            <button class="btn btn-sm bg-light text-gray-700 border border-gray-300 py-2 px-4 fw-bold fs-8 btn-active-light-primary">Chuyển mục đích</button>
                                                            <button class="btn btn-sm btn-light-danger text-danger py-2 px-4 fw-bold fs-8">Báo lỗi</button>
                                                        </div>
                                                    </div>
                                                    <!-- Sub table -->
                                                    <div class="table-responsive">
                                                        <table class="table align-middle table-row-dashed fs-7 gy-4 mb-0">
                                                            <thead>
                                                                <tr class="text-start text-gray-600 fw-bold fs-8 text-uppercase gs-0">
                                                                    <th class="ps-6">Mã đơn (PO/DO)</th>
                                                                    <th class="text-end">Số lượng</th>
                                                                    <th class="text-center">Ngày giao dự kiến</th>
                                                                    <th class="text-center">Công đoạn tiếp</th>
                                                                    <th class="text-center">Ngày sản xuất</th>
                                                                    <th class="text-end pe-6">Trạng thái</th>
                                                                </tr>
                                                            </thead>
                                                            <tbody class="text-gray-700 fw-semibold">
                                                                <tr>
                                                                    <td class="ps-6"><a href="#" class="text-primary fw-bold text-hover-primary">PO-2024-0892</a></td>
                                                                    <td class="text-end text-gray-900">1,200</td>
                                                                    <td class="text-center text-gray-600">25/05/2024</td>
                                                                    <td class="text-center"><span class="badge badge-light-warning text-warning fw-bold px-3 py-1">In ấn</span></td>
                                                                    <td class="text-center text-gray-600">20/05/2024</td>
                                                                    <td class="text-end pe-6"><span class="badge badge-light-success text-success fw-bold px-3 py-1">Đã sẵn sàng</span></td>
                                                                </tr>
                                                                <tr>
                                                                    <td class="ps-6"><a href="#" class="text-primary fw-bold text-hover-primary">PO-2024-0915</a></td>
                                                                    <td class="text-end text-gray-900">1,300</td>
                                                                    <td class="text-center text-gray-600">28/05/2024</td>
                                                                    <td class="text-center"><span class="badge badge-light-info text-info fw-bold px-3 py-1" style="color: #9333ea !important; background-color: #f3e8ff !important;">Bế</span></td>
                                                                    <td class="text-center text-gray-600">21/05/2024</td>
                                                                    <td class="text-end pe-6"><span class="badge badge-light-primary text-primary fw-bold px-3 py-1">Chờ bốc xếp</span></td>
                                                                </tr>
                                                            </tbody>
                                                        </table>
                                                    </div>
                                                </div>
                                            </div>
                                        </td>
                                    </tr>
                                }

                                <!-- Row 2 -->
                                <tr class="@(expandedRow == 1 ? "border-top border-gray-200" : "")">
                                    <td class="ps-6">
                                        <div class="d-flex flex-column gap-1">
                                            <span class="text-gray-900 fw-bold fs-5">Tấm 5 lớp - 1200×800 - Sóng BC</span>
                                            <span class="text-muted fs-7 text-uppercase tracking-wider">K150/M125/M125/M125/K150</span>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="d-flex flex-column gap-2 pe-10">
                                            <div class="d-flex justify-content-between align-items-center fs-8 fw-bold">
                                                <span class="text-primary">8,400</span>
                                                <span class="text-gray-600">4,200</span>
                                            </div>
                                            <div class="d-flex h-15px rounded overflow-hidden">
                                                <div class="bg-primary d-flex justify-content-center align-items-center text-white fs-9" style="width: 66%">66%</div>
                                                <div class="bg-gray-300 d-flex justify-content-center align-items-center text-gray-600 fs-9" style="width: 34%">34%</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-center pe-6">
                                        <button class="btn btn-icon btn-sm btn-active-light-primary w-30px h-30px" @onclick="() => ToggleRow(2)">
                                            <i class="ki-duotone @(expandedRow == 2 ? "ki-up" : "ki-down") fs-2 text-gray-700 m-0"></i>
                                        </button>
                                    </td>
                                </tr>

                                <!-- Row 3 -->
                                <tr>
                                    <td class="ps-6">
                                        <div class="d-flex flex-column gap-1">
                                            <span class="text-gray-900 fw-bold fs-5">Tấm E-Flute Trắng - 450×450</span>
                                            <span class="text-muted fs-7 text-uppercase tracking-wider">W140 / M125 / K125</span>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="d-flex flex-column gap-2 pe-10">
                                            <div class="d-flex justify-content-between align-items-center fs-8 fw-bold">
                                                <span class="text-primary">12,000</span>
                                                <span class="text-gray-600">150</span>
                                            </div>
                                            <div class="d-flex h-15px rounded overflow-hidden">
                                                <div class="bg-primary d-flex justify-content-center align-items-center text-white fs-9" style="width: 98.7%">98.7%</div>
                                                <div class="bg-gray-300 d-flex justify-content-center align-items-center text-gray-600 fs-9" style="width: 1.3%">1.3%</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-center pe-6">
                                        <button class="btn btn-icon btn-sm btn-active-light-primary w-30px h-30px" @onclick="() => ToggleRow(3)">
                                            <i class="ki-duotone @(expandedRow == 3 ? "ki-up" : "ki-down") fs-2 text-gray-700 m-0"></i>
                                        </button>
                                    </td>
                                </tr>

                                <!-- Row 4 -->
                                <tr>
                                    <td class="ps-6">
                                        <div class="d-flex flex-column gap-1">
                                            <span class="text-gray-900 fw-bold fs-5">Tấm Chống Thấm - 800×600</span>
                                            <span class="text-muted fs-7 text-uppercase tracking-wider">PE170 / K150 / K150</span>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="d-flex flex-column gap-2 pe-10">
                                            <div class="d-flex justify-content-between align-items-center fs-8 fw-bold">
                                                <span class="text-primary">5,200</span>
                                                <span class="text-gray-600">2,800</span>
                                            </div>
                                            <div class="d-flex h-15px rounded overflow-hidden">
                                                <div class="bg-primary d-flex justify-content-center align-items-center text-white fs-9" style="width: 65%">65%</div>
                                                <div class="bg-gray-300 d-flex justify-content-center align-items-center text-gray-600 fs-9" style="width: 35%">35%</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-center pe-6">
                                        <button class="btn btn-icon btn-sm btn-active-light-primary w-30px h-30px" @onclick="() => ToggleRow(4)">
                                            <i class="ki-duotone @(expandedRow == 4 ? "ki-up" : "ki-down") fs-2 text-gray-700 m-0"></i>
                                        </button>
                                    </td>
                                </tr>

                            </tbody>
                        </table>
                    </div>

                    <!-- Pagination -->
                    <div class="d-flex flex-stack flex-wrap p-5 border-top border-gray-200 bg-light rounded-bottom">
                        <div class="fs-6 fw-semibold text-gray-500">Hiển thị <span class="fw-bold text-gray-800">1 - 10</span> trong tổng số <span class="fw-bold text-gray-800">142</span> loại giấy tấm</div>
                        <ul class="pagination mb-0">
                            <li class="page-item previous disabled"><a href="#" class="page-link"><i class="previous"></i></a></li>
                            <li class="page-item active"><a href="#" class="page-link">1</a></li>
                            <li class="page-item"><a href="#" class="page-link">2</a></li>
                            <li class="page-item"><a href="#" class="page-link">3</a></li>
                            <li class="page-item disabled"><span class="page-link">...</span></li>
                            <li class="page-item"><a href="#" class="page-link">15</a></li>
                            <li class="page-item next"><a href="#" class="page-link"><i class="next"></i></a></li>
                        </ul>
                    </div>
                </div>
            </div>
            <!--end::Table Card-->

            <!-- Floating Action Button -->
            <button class="btn btn-icon btn-primary rounded-circle w-50px h-50px shadow position-fixed bottom-0 end-0 m-10" style="z-index: 100;" title="Tạo Lệnh Mới">
                <i class="ki-duotone ki-plus fs-1 m-0"></i>
            </button>
        </div>
    </div>
    <!--end::Content-->
</div>

<style>
    .tracking-wider {
        letter-spacing: 0.05em;
    }
</style>

@code {
    private int expandedRow = 1; // Default to row 1 expanded as in mockup

    private void ToggleRow(int rowId)
    {
        if (expandedRow == rowId)
        {
            expandedRow = 0;
        }
        else
        {
            expandedRow = rowId;
        }
    }
}
