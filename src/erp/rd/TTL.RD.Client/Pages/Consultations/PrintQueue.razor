@page "/rd/print-consultations/queue"
@namespace TTL.RD.Client.Pages.Consultations

<div class="d-flex flex-column flex-column-fluid">
    <!--begin::Toolbar-->
    <div id="kt_app_toolbar" class="app-toolbar py-3 py-lg-6">
        <div id="kt_app_toolbar_container" class="app-container container-fluid d-flex flex-stack">
            <!--begin::Page title-->
            <div class="page-title d-flex flex-column justify-content-center flex-wrap me-3">
                <h1 class="page-heading d-flex text-gray-900 fw-bold fs-1 flex-column justify-content-center my-0">Bảng Kanban: Tư vấn In ấn</h1>
                <ul class="breadcrumb breadcrumb-separatorless fw-semibold fs-7 my-0 pt-1">
                    <li class="breadcrumb-item text-muted">Quản lý quy trình thiết kế và in ấn tại phòng R&D</li>
                </ul>
            </div>
            <!--end::Page title-->
            <!--begin::Actions-->
            <div class="d-flex align-items-center gap-2 gap-lg-3">
                <!-- Avatar group -->
                <div class="symbol-group symbol-hover me-3">
                    <div class="symbol symbol-35px symbol-circle">
                        <img alt="Pic" src="_content/TTL.Shared.UI/assets/media/avatars/300-1.jpg" />
                    </div>
                    <div class="symbol symbol-35px symbol-circle">
                        <img alt="Pic" src="_content/TTL.Shared.UI/assets/media/avatars/300-2.jpg" />
                    </div>
                    <div class="symbol symbol-35px symbol-circle">
                        <img alt="Pic" src="_content/TTL.Shared.UI/assets/media/avatars/300-3.jpg" />
                    </div>
                    <div class="symbol symbol-35px symbol-circle">
                        <span class="symbol-label bg-gray-200 text-gray-800 fw-bold fs-8">+4</span>
                    </div>
                </div>
                <!-- Filter -->
                <a href="#" class="btn btn-sm bg-white fw-bold border border-gray-300 text-gray-700 btn-active-light-primary">
                    <i class="ki-duotone ki-filter fs-3 text-muted me-1"><span class="path1"></span><span class="path2"></span></i>Bộ lọc
                </a>
            </div>
            <!--end::Actions-->
        </div>
    </div>
    <!--end::Toolbar-->

    <!--begin::Content-->
    <div id="kt_app_content" class="app-content flex-column-fluid pb-0 position-relative">
        <div id="kt_app_content_container" class="app-container container-fluid h-100 d-flex flex-column">
            <!--begin::Kanban-->
            <div class="d-flex flex-grow-1 overflow-auto gap-6 pb-20">
                
                <!-- Column 1: Yêu cầu mới -->
                <div class="w-350px min-w-350px d-flex flex-column rounded-3 bg-light-danger bg-opacity-25 border border-danger border-opacity-25">
                    <!-- Column Header -->
                    <div class="d-flex align-items-center justify-content-between p-5 pb-3">
                        <div class="d-flex align-items-center gap-2">
                            <span class="bullet bullet-vertical h-20px bg-danger w-4px rounded-pill"></span>
                            <h3 class="fw-bold fs-5 mb-0 text-gray-900">Yêu cầu mới</h3>
                            <span class="badge bg-white text-gray-700 fw-bold border border-gray-200 fs-8">03</span>
                        </div>
                        <button class="btn btn-icon btn-sm btn-active-color-primary">
                            <i class="ki-duotone ki-dots-horizontal fs-2"><span class="path1"></span><span class="path2"></span><span class="path3"></span></i>
                        </button>
                    </div>
                    <!-- Column Body (Scrollable) -->
                    <div class="d-flex flex-column gap-4 p-5 pt-0 h-100 overflow-auto">
                        <!-- Card 1 -->
                        <div class="card bg-white shadow-sm border-0 border-start border-danger border-3 rounded-2 cursor-pointer hover-elevate-up" data-bs-toggle="modal" data-bs-target="#kt_modal_print_detail">
                            <div class="card-body p-5">
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <span class="badge badge-light-danger text-danger fw-bold fs-9 tracking-wider">KHẨN CẤP</span>
                                    <span class="text-gray-500 fs-8 fw-semibold tracking-wider">IN-4402</span>
                                </div>
                                <div class="text-gray-900 fw-bold fs-5 mb-2">Hộp Giấy Cao Cấp V2</div>
                                <div class="text-gray-600 fs-7 mb-6">Khách hàng: Vinamilk Corp</div>
                                <div class="d-flex justify-content-between align-items-center">
                                    <div class="d-flex align-items-center text-gray-500 fs-8 fw-semibold">
                                        <i class="ki-duotone ki-calendar-8 fs-5 text-gray-500 me-2"><span class="path1"></span><span class="path2"></span><span class="path3"></span><span class="path4"></span><span class="path5"></span><span class="path6"></span></i>
                                        24 thg 10, 2023
                                    </div>
                                    <div class="symbol symbol-25px symbol-circle">
                                        <span class="symbol-label bg-gray-200 text-gray-600 fw-bold fs-8">JD</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <!-- Card 2 -->
                        <div class="card bg-white shadow-sm border-0 border-start border-gray-400 border-3 rounded-2 cursor-pointer hover-elevate-up" data-bs-toggle="modal" data-bs-target="#kt_modal_print_detail">
                            <div class="card-body p-5">
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <span class="badge bg-gray-200 text-gray-700 fw-bold fs-9 tracking-wider">BÌNH THƯỜNG</span>
                                    <span class="text-gray-500 fs-8 fw-semibold tracking-wider">IN-4405</span>
                                </div>
                                <div class="text-gray-900 fw-bold fs-5 mb-2">Thiết kế Template Carton 5 Lớp</div>
                                <div class="text-gray-600 fs-7 mb-6">Khách hàng: Logi Logistics</div>
                                <div class="d-flex justify-content-between align-items-center">
                                    <div class="d-flex align-items-center text-gray-500 fs-8 fw-semibold">
                                        <i class="ki-duotone ki-calendar-8 fs-5 text-gray-500 me-2"><span class="path1"></span><span class="path2"></span><span class="path3"></span><span class="path4"></span><span class="path5"></span><span class="path6"></span></i>
                                        26 thg 10, 2023
                                    </div>
                                    <div class="symbol symbol-25px symbol-circle">
                                        <span class="symbol-label bg-gray-200 text-gray-600 fw-bold fs-8">+</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <!-- Card 3 -->
                        <div class="card bg-white shadow-sm border-0 border-start border-gray-400 border-3 rounded-2 cursor-pointer hover-elevate-up" data-bs-toggle="modal" data-bs-target="#kt_modal_print_detail">
                            <div class="card-body p-5">
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <span class="badge bg-gray-200 text-gray-700 fw-bold fs-9 tracking-wider">BÌNH THƯỜNG</span>
                                    <span class="text-gray-500 fs-8 fw-semibold tracking-wider">IN-4410</span>
                                </div>
                                <div class="text-gray-900 fw-bold fs-5 mb-2">In Thử Mẫu Nhãn Chai</div>
                                <div class="text-gray-600 fs-7 mb-6">Khách hàng: Heineken Vietnam</div>
                                <div class="d-flex justify-content-between align-items-center">
                                    <div class="d-flex align-items-center text-gray-500 fs-8 fw-semibold">
                                        <i class="ki-duotone ki-calendar-8 fs-5 text-gray-500 me-2"><span class="path1"></span><span class="path2"></span><span class="path3"></span><span class="path4"></span><span class="path5"></span><span class="path6"></span></i>
                                        Hôm nay
                                    </div>
                                    <div class="symbol symbol-25px symbol-circle">
                                        <span class="symbol-label bg-gray-200 text-gray-600 fw-bold fs-8">AK</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Column 2: Đang xử lý -->
                <div class="w-350px min-w-350px d-flex flex-column rounded-3 bg-light-primary bg-opacity-25 border border-primary border-opacity-25">
                    <div class="d-flex align-items-center justify-content-between p-5 pb-3">
                        <div class="d-flex align-items-center gap-2">
                            <span class="bullet bullet-vertical h-20px bg-primary w-4px rounded-pill"></span>
                            <h3 class="fw-bold fs-5 mb-0 text-gray-900">Đang xử lý</h3>
                            <span class="badge bg-white text-primary fw-bold border border-gray-200 fs-8">02</span>
                        </div>
                        <button class="btn btn-icon btn-sm btn-active-color-primary">
                            <i class="ki-duotone ki-dots-horizontal fs-2"><span class="path1"></span><span class="path2"></span><span class="path3"></span></i>
                        </button>
                    </div>
                    <div class="d-flex flex-column gap-4 p-5 pt-0 h-100 overflow-auto">
                        <!-- Card 4 -->
                        <div class="card bg-white shadow-sm border-0 border-start border-danger border-3 rounded-2 cursor-pointer hover-elevate-up" data-bs-toggle="modal" data-bs-target="#kt_modal_print_detail">
                            <div class="card-body p-5">
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <span class="badge badge-light-danger text-danger fw-bold fs-9 tracking-wider">KHẨN CẤP</span>
                                    <div class="d-flex align-items-center text-gray-500 fs-8 fw-semibold tracking-wider">
                                        <i class="ki-duotone ki-flash fs-6 text-primary me-1"><span class="path1"></span><span class="path2"></span><span class="path3"></span><span class="path4"></span></i>
                                        IN-4398
                                    </div>
                                </div>
                                <div class="text-gray-900 fw-bold fs-5 mb-2">Mẫu In Phun Offset Đa Sắc</div>
                                <div class="text-gray-600 fs-7 mb-6">Khách hàng: TH True Milk</div>
                                <div class="d-flex justify-content-between align-items-center">
                                    <div class="d-flex align-items-center text-gray-500 fs-8 fw-semibold">
                                        <i class="ki-duotone ki-time fs-5 text-gray-500 me-2"><span class="path1"></span><span class="path2"></span></i>
                                        Bắt đầu 2 ngày trước
                                    </div>
                                    <div class="symbol symbol-25px symbol-circle">
                                        <img alt="Pic" src="_content/TTL.Shared.UI/assets/media/avatars/300-2.jpg" />
                                    </div>
                                </div>
                            </div>
                        </div>
                        <!-- Card 5 -->
                        <div class="card bg-white shadow-sm border-0 border-start border-gray-400 border-3 rounded-2 cursor-pointer hover-elevate-up" data-bs-toggle="modal" data-bs-target="#kt_modal_print_detail">
                            <div class="card-body p-5">
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <span class="badge bg-gray-200 text-gray-700 fw-bold fs-9 tracking-wider">BÌNH THƯỜNG</span>
                                    <span class="text-gray-500 fs-8 fw-semibold tracking-wider">IN-4400</span>
                                </div>
                                <div class="text-gray-900 fw-bold fs-5 mb-2">Thử Nghiệm Độ Bền Màu Carton</div>
                                <div class="text-gray-600 fs-7 mb-6">Khách hàng: Nội bộ R&D</div>
                                <div class="d-flex justify-content-between align-items-center">
                                    <div class="d-flex align-items-center text-gray-500 fs-8 fw-semibold">
                                        <i class="ki-duotone ki-time fs-5 text-gray-500 me-2"><span class="path1"></span><span class="path2"></span></i>
                                        Đang triển khai
                                    </div>
                                    <div class="symbol symbol-25px symbol-circle">
                                        <span class="symbol-label bg-gray-200 text-gray-600 fw-bold fs-8">R&D</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Column 3: Đã hoàn thành -->
                <div class="w-350px min-w-350px d-flex flex-column rounded-3 bg-light-success bg-opacity-25 border border-success border-opacity-25">
                    <div class="d-flex align-items-center justify-content-between p-5 pb-3">
                        <div class="d-flex align-items-center gap-2">
                            <span class="bullet bullet-vertical h-20px bg-success w-4px rounded-pill"></span>
                            <h3 class="fw-bold fs-5 mb-0 text-gray-900">Đã hoàn thành</h3>
                            <span class="badge bg-white text-success fw-bold border border-gray-200 fs-8">01</span>
                        </div>
                        <button class="btn btn-icon btn-sm btn-active-color-primary">
                            <i class="ki-duotone ki-dots-horizontal fs-2"><span class="path1"></span><span class="path2"></span><span class="path3"></span></i>
                        </button>
                    </div>
                    <div class="d-flex flex-column gap-4 p-5 pt-0 h-100 overflow-auto">
                        <!-- Card 6 -->
                        <div class="card bg-white shadow-sm border-0 border-start border-success border-3 rounded-2 cursor-pointer hover-elevate-up" data-bs-toggle="modal" data-bs-target="#kt_modal_print_detail">
                            <div class="card-body p-5">
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <span class="badge badge-light-success text-success fw-bold fs-9 tracking-wider">HOÀN THÀNH</span>
                                </div>
                                <div class="text-gray-900 fw-bold fs-5 mb-2">Catalogue Giới Thiệu SP</div>
                                <div class="text-gray-600 fs-7 mb-6">Khách hàng: Slate ERP</div>
                                <div class="d-flex justify-content-between align-items-center">
                                    <div class="d-flex align-items-center text-success fs-8 fw-semibold">
                                        <i class="ki-duotone ki-check-circle fs-5 text-success me-2"><span class="path1"></span><span class="path2"></span></i>
                                        Xong 20 thg 10
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
            <!--end::Kanban-->
            
            <!-- Sticky Footer Bottom -->
            <div class="position-absolute bottom-0 start-0 w-100 bg-white border-top border-gray-200 d-flex justify-content-between align-items-center px-8 py-5" style="z-index: 10;">
                <div class="d-flex gap-10">
                    <div>
                        <div class="text-gray-500 fs-8 fw-bold text-uppercase tracking-wider mb-1">Tổng yêu cầu</div>
                        <div class="text-gray-900 fw-bolder fs-3">06</div>
                    </div>
                    <div class="border-start border-gray-300"></div>
                    <div>
                        <div class="text-gray-500 fs-8 fw-bold text-uppercase tracking-wider mb-1">Tỉ lệ hoàn thành</div>
                        <div class="text-success fw-bolder fs-3">16.7%</div>
                    </div>
                    <div class="border-start border-gray-300"></div>
                    <div>
                        <div class="text-gray-500 fs-8 fw-bold text-uppercase tracking-wider mb-1">Cần xử lý gấp</div>
                        <div class="text-danger fw-bolder fs-3">02</div>
                    </div>
                </div>
                
                <div class="d-flex align-items-center gap-6">
                    <a href="#" class="text-primary fw-bold text-hover-primary">Xem báo cáo chi tiết</a>
                    <span class="badge bg-dark text-white fw-bold px-4 py-2">Cập nhật lúc 14:30</span>
                </div>
            </div>
            
        </div>
    </div>
    <!--end::Content-->
</div>

<TTL.RD.Client.Pages.Consultations.Components.PrintDetailModal />

<style>
    .tracking-wider {
        letter-spacing: 0.05em;
    }
</style>
