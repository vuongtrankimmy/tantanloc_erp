@page "/leave/requests"
@using TTL.Shared.Models.HRM.Operations

<SectionContent SectionName="PageTitle">Quản lý nghỉ phép & Công tác</SectionContent>

<SectionContent SectionName="PageBreadcrumbs">
    <li class="breadcrumb-item text-muted">
        <a href="/" class="text-muted text-hover-primary">Trang chủ</a>
    </li>
    <li class="breadcrumb-item text-muted">Quản lý yêu cầu</li>
    <li class="breadcrumb-item text-gray-900">Nghỉ phép & Công tác</li>
</SectionContent>

<div class="mb-5">
    <!--begin::Cards-->
    <div class="row g-5 g-xl-8">
        <div class="col-md-4">
            <div class="card bg-primary card-xl-stretch mb-xl-8">
                <div class="card-body p-6">
                    <div class="fs-2hx fw-bold text-white mb-2">@Requests.Count</div>
                    <div class="fs-6 fw-semibold text-white opacity-75">Tổng yêu cầu</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-warning card-xl-stretch mb-xl-8">
                <div class="card-body p-6">
                    <div class="fs-2hx fw-bold text-white mb-2">@Requests.Count(e => e.status == "Chờ phê duyệt")</div>
                    <div class="fs-6 fw-semibold text-white opacity-75">Đang chờ duyệt</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-success card-xl-stretch mb-xl-8">
                <div class="card-body p-6">
                    <div class="fs-2hx fw-bold text-white mb-2">@Requests.Count(e => e.status == "Đã phê duyệt")</div>
                    <div class="fs-6 fw-semibold text-white opacity-75">Đã duyệt</div>
                </div>
            </div>
        </div>
    </div>
    <!--end::Cards-->
</div>

<div class="d-flex flex-wrap flex-stack pb-7">
    <!--begin::Title-->
    <div class="d-flex flex-wrap align-items-center my-1">
        <h3 class="fw-bold me-5 my-1">Danh sách yêu cầu (@Requests.Count)</h3>
    </div>
    <!--end::Title-->
    <!--begin::Controls-->
    <div class="d-flex flex-wrap my-1 gap-2">
        <!--begin::Tab nav-->
        <ul class="nav nav-pills me-4 mb-2 mb-sm-0" role="tablist">
            <li class="nav-item m-0" role="presentation">
                <a class="btn btn-sm btn-icon btn-light btn-color-muted btn-active-primary me-2 @GetActiveCssClass(ViewMode.Card)" @onclick="() => SetActiveView(ViewMode.Card)" aria-selected="@(ActiveView == ViewMode.Card)" role="button" tabindex="-1">
                    <i class="ki-duotone ki-element-plus fs-2">
                        <span class="path1"></span><span class="path2"></span><span class="path3"></span><span class="path4"></span><span class="path5"></span>
                    </i>
                </a>
            </li>
            <li class="nav-item m-0" role="presentation">
                <a class="btn btn-sm btn-icon btn-light btn-color-muted btn-active-primary @GetActiveCssClass(ViewMode.Table)" @onclick="() => SetActiveView(ViewMode.Table)" aria-selected="@(ActiveView == ViewMode.Table)" role="button">
                    <i class="ki-duotone ki-row-horizontal fs-2">
                        <span class="path1"></span><span class="path2"></span>
                    </i>
                </a>
            </li>
        </ul>
        <!--end::Tab nav-->
        <!--begin::Search-->
        <div class="d-flex align-items-center position-relative">
            <i class="ki-duotone ki-magnifier fs-3 position-absolute ms-3">
                <span class="path1"></span><span class="path2"></span>
            </i>
            <input type="text" id="kt_filter_search" class="form-control form-control-sm form-control-solid w-200px ps-10" placeholder="Tìm kiếm nhân viên..." />
        </div>
        <!--end::Search-->
        <!--begin::Select-->
        <select name="department" class="form-select form-select-sm border-body bg-body w-150px">
            <option value="">Tất cả phòng ban</option>
        </select>
        <select name="status" class="form-select form-select-sm border-body bg-body w-150px">
            <option value="">Tất cả trạng thái</option>
            <option value="pending">Chờ phê duyệt</option>
            <option value="approved">Đã phê duyệt</option>
            <option value="rejected">Từ chối</option>
        </select>
        <!--end::Select-->
        <button class="btn btn-sm btn-primary">
            <i class="ki-duotone ki-plus fs-3"></i> Tạo yêu cầu mới
        </button>
    </div>
    <!--end::Controls-->
</div>

<div class="tab-content">
    <div id="kt_project_users_card_pane" class="tab-pane fade @GetShowActiveCssClass(ViewMode.Card)" role="tabpanel">
        <div class="row g-6 g-xl-9">
            <!-- Cards can be added here later -->
        </div>
    </div>
    <div id="kt_project_users_table_pane" class="tab-pane fade @GetShowActiveCssClass(ViewMode.Table)" role="tabpanel">
        <div class="card card-flush">
            <div class="card-body pt-0">
                <table id="kt_project_users_table" class="table table-row-bordered table-row-dashed gy-4 align-middle fw-bold">
                    <thead class="fs-7 text-gray-500 text-uppercase">
                        <tr>
                            <th class="min-w-200px">NHÂN VIÊN</th>
                            <th class="text-center min-w-100px">LOẠI YÊU CẦU</th>
                            <th class="min-w-125px">THỜI GIAN</th>
                            <th class="min-w-200px">LÝ DO</th>
                            <th class="text-center min-w-125px">TRẠNG THÁI</th>
                            <th class="text-center min-w-125px">THAO TÁC</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var req in Requests)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="symbol symbol-35px me-3">
                                            <div class="symbol-label bg-light-primary text-primary fw-bold">@req.employee_name.Substring(0, 1)</div>
                                        </div>
                                        <div class="d-flex justify-content-start flex-column">
                                            <a href="javascript:;" class="text-dark fw-bolder text-hover-primary fs-6 mb-1">@req.employee_name</a>
                                            <span class="text-muted fw-bold fs-7">@req.department</span>
                                        </div>
                                    </div>
                                </td>
                                <td class="text-center">
                                    @if (req.request_category == "Nghỉ phép")
                                    {
                                        <span class="badge bg-light-primary text-primary fw-bold px-3 py-1 fs-8">Nghỉ phép</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-light-purple text-purple fw-bold px-3 py-1 fs-8" style="color: #A020F0; background-color: #F8F5FF;">Công tác</span>
                                    }
                                </td>
                                <td>
                                    <div class="d-flex flex-column">
                                        <span class="text-gray-900 fw-bold fs-6">@req.start_date.ToString("dd/MM") - @req.end_date.ToString("dd/MM/yyyy")</span>
                                        <span class="text-muted fs-7">@req.total_days.ToString("0") ngày</span>
                                    </div>
                                </td>
                                <td>
                                    <span class="text-gray-800 fw-semibold text-truncate d-inline-block" style="max-width: 200px;" title="@req.reason">@req.reason</span>
                                </td>
                                <td class="text-center">
                                    <div class="badge @GetStatusBadgeClass(req.status) px-3 py-1 fs-8">@req.status</div>
                                </td>
                                <td class="text-center">
                                    @if (req.status == "Chờ phê duyệt")
                                    {
                                        <button class="btn btn-sm btn-icon btn-active-light-success text-success fw-bold me-2" title="Phê duyệt">
                                            <i class="ki-duotone ki-check fs-2 text-success"></i>
                                        </button>
                                        <button class="btn btn-sm btn-icon btn-active-light-danger text-danger fw-bold kt_drawer_leave_request_toggle" title="Từ chối" @onclick="() => SelectRequest(req)">
                                            <i class="ki-duotone ki-cross fs-2 text-danger"><span class="path1"></span><span class="path2"></span></i>
                                        </button>
                                    }
                                    else
                                    {
                                        <button class="btn btn-sm btn-icon btn-active-light-primary kt_drawer_leave_request_toggle" title="Xem chi tiết" @onclick="() => SelectRequest(req)">
                                            <i class="ki-duotone ki-dots-vertical fs-2"><span class="path1"></span><span class="path2"></span><span class="path3"></span><span class="path4"></span></i>
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                <div class="px-7 py-5 border-top">
                    <div class="d-flex flex-stack flex-wrap pt-10">
                        <div class="fs-6 fw-bold text-gray-700">
                            <span>Hiển thị 1 đến @Requests.Count trong tổng số @Requests.Count bản ghi</span>
                        </div>
                        <ul class="pagination">
                            <li class="page-item previous disabled"><a href="javascript:;" class="page-link"><i class="ki-outline ki-left fs-2"></i></a></li>
                            <li class="page-item active"><a href="javascript:;" class="page-link">1</a></li>
                            <li class="page-item next disabled"><a href="javascript:;" class="page-link"><i class="ki-outline ki-right fs-2"></i></a></li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<LeaveRequestDrawer Request="SelectedRequest" />
