@page "/hrm/payroll/payroll_detail/{PayrollCode}"
@page "/hrm/payroll/payroll_detail"
@using TTL.Shared.Models.HRM.Operations

<SectionContent SectionName="PageTitle">Thông tin chi tiết</SectionContent>
<SectionContent SectionName="PageBreadcrumbs">
    <li class="breadcrumb-item text-muted">
        <a href="/" class="text-muted text-hover-primary">Trang chủ</a>
    </li>
    <li class="breadcrumb-item">
        <span class="bullet bg-gray-500 w-5px h-2px"></span>
    </li>
    <li class="breadcrumb-item text-muted">Lương & Phúc lợi</li>
    <li class="breadcrumb-item">
        <span class="bullet bg-gray-500 w-5px h-2px"></span>
    </li>
    <li class="breadcrumb-item text-muted">
        <a href="/payroll/payroll_list" class="text-muted text-hover-primary">Kỳ tính lương</a>
    </li>
    <li class="breadcrumb-item">
        <span class="bullet bg-gray-500 w-5px h-2px"></span>
    </li>
    <li class="breadcrumb-item text-gray-900">Thông tin chi tiết</li>
</SectionContent>

<div class="mb-5">
    <!--begin::Cards-->
    <div class="row g-5 g-xl-8">
        <div class="col-md-3">
            <div class="card bg-primary card-xl-stretch mb-xl-8">
                <div class="card-body p-6">
                    <div class="fs-2hx fw-bold text-white mb-2">@TotalNetSalary.ToString("N0") <span class="fs-4 text-white opacity-75">đ</span></div>
                    <div class="fs-6 fw-semibold text-white opacity-75 text-uppercase">TỔNG THỰC LĨNH</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-light-danger card-xl-stretch mb-xl-8 border border-danger border-dashed">
                <div class="card-body p-6">
                    <div class="fs-2hx fw-bold text-danger mb-2">@TotalTax.ToString("N0") <span class="fs-4 text-danger opacity-75">đ</span></div>
                    <div class="fs-6 fw-semibold text-danger opacity-75 text-uppercase">TỔNG THUẾ TNCN</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-light-success card-xl-stretch mb-xl-8 border border-success border-dashed">
                <div class="card-body p-6">
                    <div class="fs-2hx fw-bold text-success mb-2">@TotalInsurance.ToString("N0") <span class="fs-4 text-success opacity-75">đ</span></div>
                    <div class="fs-6 fw-semibold text-success opacity-75 text-uppercase">TỔNG BẢO HIỂM</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-body card-xl-stretch mb-xl-8 shadow-sm">
                <div class="card-body p-6">
                    <div class="fs-2hx fw-bold text-dark mb-2">@TotalEmployees</div>
                    <div class="fs-6 fw-semibold text-gray-500 text-uppercase">TỔNG NHÂN SỰ</div>
                </div>
            </div>
        </div>
    </div>
    <!--end::Cards-->
</div>

<div class="d-flex flex-wrap flex-stack pb-7">
    <!--begin::Title-->
    <div class="d-flex flex-wrap align-items-center my-1">
        <h3 class="fw-bold me-5 my-1">Chi tiết (@FilteredDetails.Count())</h3>
    </div>
    <!--end::Title-->
    <!--begin::Controls-->
    <div class="d-flex flex-wrap my-1 gap-3">
        <!--begin::Search-->
        <div class="d-flex align-items-center position-relative">
            <i class="ki-outline ki-magnifier fs-3 position-absolute ms-4 top-50 translate-middle-y"></i>
            <input type="text" class="form-control form-control-sm form-control-solid w-200px ps-12" placeholder="Tìm tên, mã nhân viên..." @bind="SearchQuery" @bind:event="oninput" />
        </div>
        <!--end::Search-->
        <!--begin::Filters-->
        <div class="d-flex align-items-center">
            <span class="fs-7 fw-semibold text-gray-500 me-2 text-nowrap">Phòng ban:</span>
            <select class="form-select form-select-sm form-select-solid w-200px" @bind="SelectedDepartment">
                @foreach (var dept in Departments)
                {
                    <option value="@dept">@dept</option>
                }
            </select>
        </div>
        <div class="ms-2">
            <span class="badge badge-light-primary border border-primary border-dashed fw-bold px-4 py-2 fs-7">
                <i class="ki-outline ki-document fs-4 me-1 text-primary"></i> 
                @CurrentPayroll.PayrollName
            </span>
        </div>
        <!--end::Filters-->
        <!--begin::Actions-->
        <button type="button" class="btn btn-sm btn-light-primary fw-bold">
            <i class="ki-outline ki-file-down fs-2"></i> Xuất excel
        </button>
        <button type="button" class="btn btn-sm btn-primary fw-bold">
            <i class="ki-outline ki-check-circle fs-2"></i> Chốt lương tháng này
        </button>
        <button type="button" class="btn btn-sm btn-light-success fw-bold border border-success border-dashed">
            <i class="ki-outline ki-arrows-circle fs-2 text-success"></i> Tính toán lại (Sync)
        </button>
        <!--end::Actions-->
    </div>
    <!--end::Controls-->
</div>

<!-- Payroll Details Table -->
<div class="card">
    <div class="card-header align-items-center py-5 gap-2 gap-md-5">
        <div class="card-title">
            <div class="d-flex align-items-center position-relative my-1">
                <span class="fs-7 fw-semibold text-gray-500 me-2">Chọn nhóm nhân viên:</span>
                <span class="badge badge-light-success fw-bold px-3 py-1">Tất cả nhân viên (@TotalEmployees)</span>
            </div>
        </div>
        <div class="card-toolbar">
            <div class="d-flex align-items-center">
                <span class="fs-8 fw-semibold text-gray-500 me-2">Công thức tính lương:</span>
                <span class="badge badge-light fw-bold text-gray-700 border border-gray-300 border-dashed fs-8 px-3 py-1">Lương CB + Phụ cấp - Khấu trừ = Thực Lĩnh</span>
            </div>
        </div>
    </div>
    <div class="card-body pt-0">
        <div class="table-responsive">
            <table class="table align-middle table-row-dashed fs-6 gy-4" id="kt_payroll_detail_table">
                <thead>
                    <tr class="text-start text-muted fw-bold fs-7 text-uppercase gs-0 bg-light">
                        <th class="w-10px pe-2 ps-3 rounded-start">
                            <div class="form-check form-check-sm form-check-custom form-check-solid">
                                <input class="form-check-input" type="checkbox" data-kt-check="true" data-kt-check-target="#kt_payroll_detail_table .form-check-input" value="1" />
                            </div>
                        </th>
                        <th class="min-w-200px">NHÂN VIÊN</th>
                        <th class="min-w-100px text-end">LƯƠNG CƠ BẢN</th>
                        <th class="min-w-100px text-end">PHỤ CẤP</th>
                        <th class="min-w-80px text-center">NGÀY CÔNG</th>
                        <th class="min-w-100px text-end">KHẤU TRỪ</th>
                        <th class="min-w-125px text-end">THỰC LĨNH</th>
                        <th class="min-w-100px text-center">TRẠNG THÁI</th>
                        <th class="min-w-80px text-end rounded-end pe-4">THAO TÁC</th>
                    </tr>
                </thead>
                <tbody class="text-gray-600 fw-semibold">
                    @foreach (var detail in FilteredDetails)
                    {
                        <tr>
                            <td class="ps-3">
                                <div class="form-check form-check-sm form-check-custom form-check-solid">
                                    <input class="form-check-input" type="checkbox" value="1" />
                                </div>
                            </td>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="symbol symbol-40px me-3">
                                        @if (!string.IsNullOrEmpty(detail.AvatarUrl))
                                        {
                                            <img src="@detail.AvatarUrl" alt="avatar" />
                                        }
                                        else
                                        {
                                            <span class="symbol-label bg-light-@detail.AvatarColor.ToLower() text-@detail.AvatarColor.ToLower() fw-bold fs-5">
                                                @detail.EmployeeName.Substring(0, 1)
                                            </span>
                                        }
                                    </div>
                                    <div class="d-flex justify-content-start flex-column">
                                        <a href="javascript:;" class="text-gray-800 fw-bold text-hover-primary mb-1 fs-6 kt_drawer_employee_payroll_toggle" @onmousedown="() => SelectPayrollDetail(detail)">@detail.EmployeeName</a>
                                        <span class="text-gray-500 fw-semibold d-block fs-8">@detail.EmployeeCode • @detail.Department</span>
                                    </div>
                                </div>
                            </td>
                            <td class="text-end">
                                <span class="text-gray-800 fw-bold">@detail.BasicSalary.ToString("N0") đ</span>
                            </td>
                            <td class="text-end">
                                <span class="text-success fw-bold">+ @detail.Allowance.ToString("N0") đ</span>
                            </td>
                            <td class="text-center">
                                <span class="text-gray-800 fw-bold">@detail.WorkingDays</span>
                            </td>
                            <td class="text-end">
                                <span class="text-danger fw-bold">- @detail.Deduction.ToString("N0") đ</span>
                            </td>
                            <td class="text-end">
                                <span class="text-primary fw-bold fs-5">@detail.NetSalary.ToString("N0") đ</span>
                            </td>
                            <td class="text-center">
                                <span class="badge badge-light-success fw-bold px-3 py-2 border border-success border-dashed">
                                    @detail.StatusName
                                </span>
                            </td>
                            <td class="text-end">
                                <a class="btn btn-icon btn-light-primary btn-sm cursor-pointer kt_drawer_employee_payroll_toggle" @onmousedown="() => SelectPayrollDetail(detail)">
                                    <i class="ki-outline ki-eye fs-3"></i>
                                </a>
                            </td>
                        </tr>
                    }
                    @if (!FilteredDetails.Any())
                    {
                        <tr>
                            <td colspan="9" class="text-center p-10">
                                <div class="d-flex flex-column align-items-center">
                                    <i class="ki-outline ki-search fs-5x text-gray-400 mb-5"></i>
                                    <div class="fs-4 fw-bold text-gray-600 mb-2">Không tìm thấy chi tiết</div>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
                @if (FilteredDetails.Any())
                {
                    <tfoot class="bg-light fw-bold">
                        <tr>
                            <td colspan="2" class="ps-3">
                                <span class="text-gray-800 fs-6 text-uppercase">TỔNG CỘNG (@FilteredDetails.Count() NV)</span>
                            </td>
                            <td class="text-end text-gray-800 fs-6">@TotalBasicSalary.ToString("N0") đ</td>
                            <td class="text-end text-success fs-6">+ @TotalAllowance.ToString("N0") đ</td>
                            <td class="text-center text-muted">--</td>
                            <td class="text-end text-danger fs-6">- @TotalDeduction.ToString("N0") đ</td>
                            <td class="text-end text-primary fs-5">@TotalNetSalary.ToString("N0") đ</td>
                            <td colspan="2"></td>
                        </tr>
                    </tfoot>
                }
            </table>
        </div>
    </div>
</div>

<EmployeePayrollDrawer PayrollDetail="SelectedDetail" />
