@using TTL.Shared.Models.HRM.Operations

<div id="kt_drawer_employee_payroll" class="bg-body" data-kt-drawer="true" data-kt-drawer-name="employee_payroll" data-kt-drawer-activate="true" data-kt-drawer-overlay="true" data-kt-drawer-width="{default:'300px', 'md': '600px'}" data-kt-drawer-direction="end" data-kt-drawer-toggle=".kt_drawer_employee_payroll_toggle" data-kt-drawer-close="#kt_drawer_employee_payroll_close">
    
    <div class="card w-100 border-0 rounded-0" id="kt_drawer_employee_payroll_card">
        
        <!--begin::Card header-->
        <div class="card-header border-0 pb-0">
            <div class="card-title flex-column">
                <h3 class="fw-bold mb-1">Điều chỉnh Phiếu lương</h3>
            </div>
            <div class="card-toolbar">
                <button type="button" class="btn btn-sm btn-icon btn-active-light-primary me-n5" id="kt_drawer_employee_payroll_close">
                    <i class="ki-outline ki-cross fs-1"></i>
                </button>
            </div>
        </div>
        <!--end::Card header-->

        <!--begin::Card body-->
        <div class="card-body scroll-y px-10 py-5" id="kt_drawer_employee_payroll_body">
            @if (PayrollDetail != null)
            {
                <!-- Employee Summary Box -->
                <div class="d-flex align-items-center mb-8 bg-dark rounded p-5">
                    <div class="symbol symbol-50px symbol-circle me-5">
                        @if (!string.IsNullOrEmpty(PayrollDetail.AvatarUrl))
                        {
                            <img src="@PayrollDetail.AvatarUrl" alt="avatar" />
                        }
                        else
                        {
                            <div class="symbol-label fs-2 bg-light-@PayrollDetail.AvatarColor.ToLower() text-@PayrollDetail.AvatarColor.ToLower()">
                                @PayrollDetail.EmployeeName.Substring(0, 1)
                            </div>
                        }
                    </div>
                    <div class="flex-grow-1">
                        <div class="text-white fw-bold fs-5 mb-1">@PayrollDetail.EmployeeName</div>
                        <div class="fs-7 text-gray-400">Mã NV: @PayrollDetail.EmployeeCode • @PayrollDetail.Department</div>
                    </div>
                </div>

                <!-- Tabs -->
                <ul class="nav nav-stretch nav-line-tabs nav-line-tabs-2x border-transparent fs-5 fw-bold mb-8" role="tablist">
                    <li class="nav-item" role="presentation">
                        <a class="nav-link text-active-primary ms-0 me-10 py-3 cursor-pointer @(ActiveTab == "overview" ? "active" : "")" data-bs-toggle="tab" href="#kt_tab_overview" @onclick='() => SetActiveTab("overview")'>
                            <i class="ki-outline ki-element-11 fs-4 me-2"></i> Tổng quan
                        </a>
                    </li>
                    <li class="nav-item" role="presentation">
                        <a class="nav-link text-active-primary ms-0 me-10 py-3 cursor-pointer @(ActiveTab == "attendance" ? "active" : "")" data-bs-toggle="tab" href="#kt_tab_attendance" @onclick='() => SetActiveTab("attendance")'>
                            <i class="ki-outline ki-time fs-4 me-2"></i> Chấm công
                        </a>
                    </li>


                </ul>

                <div class="tab-content">
                    <!-- Tab Overview -->
                    <div class="tab-pane fade @(ActiveTab == "overview" ? "show active" : "")" id="kt_tab_overview" role="tabpanel">


                    <!-- Stats Cards -->
                    <div class="row g-4 mb-8">
                        <div class="col-4">
                            <div class="bg-light-info rounded py-4 px-3 h-100 text-center">
                                <div class="fw-semibold fs-8 text-info text-uppercase mb-2">CÔNG ĐI LÀM</div>
                                <div class="fw-bold fs-4 text-info">@PayrollDetail.WorkingDays ngày</div>
                            </div>
                        </div>
                        <div class="col-4">
                            <div class="bg-light-primary rounded py-4 px-3 h-100 text-center">
                                <div class="fw-semibold fs-8 text-primary text-uppercase mb-2">NGHỈ CÓ PHÉP</div>
                                <div class="fw-bold fs-4 text-primary">0 ngày</div>
                            </div>
                        </div>
                        <div class="col-4">
                            <div class="bg-light-danger rounded py-4 px-3 h-100 text-center">
                                <div class="fw-semibold fs-8 text-danger text-uppercase mb-2">TỔNG CỘNG</div>
                                <div class="fw-bold fs-4 text-danger">@PayrollDetail.WorkingDays ngày</div>
                            </div>
                        </div>
                    </div>

                    <!-- CHI TIẾT THU NHẬP MAPPING -->
                    <div class="mb-8">
                        <div class="d-flex flex-stack mb-6">
                            <h4 class="fw-bold text-gray-800 m-0 text-uppercase fs-7">CHI TIẾT THU NHẬP MAPPING</h4>
                        </div>

                        <!-- Lương chính -->
                        <div class="border border-gray-300 border-dashed rounded p-5 mb-5">
                            <div class="d-flex flex-stack mb-4">
                                <div class="d-flex align-items-center">
                                    <div class="symbol symbol-40px symbol-light-primary me-4">
                                        <span class="symbol-label">
                                            <i class="ki-outline ki-wallet fs-2 text-primary"></i>
                                        </span>
                                    </div>
                                    <div class="d-flex flex-column">
                                        <span class="fw-bold text-gray-800 fs-5">Lương chính</span>
                                        <span class="text-gray-500 fw-semibold fs-8">Dựa trên ngày công thực tế</span>
                                    </div>
                                </div>
                                <span class="fw-bold text-gray-800 fs-4">@((PayrollDetail.BasicSalary).ToString("N0")) đ</span>
                            </div>
                            <div class="separator separator-dashed my-3"></div>
                            <div class="d-flex flex-stack fs-7">
                                <span class="text-gray-600">Lương cơ bản theo hợp đồng:</span>
                                <span class="text-gray-800 fw-bold">@((PayrollDetail.BasicSalary).ToString("N0")) đ</span>
                            </div>
                            <div class="d-flex flex-stack fs-7 mt-2">
                                <span class="text-gray-600">Tỷ lệ hưởng lương:</span>
                                <span class="text-gray-800 fw-bold">100%</span>
                            </div>
                        </div>

                        <!-- Phụ cấp -->
                        <div class="border border-gray-300 border-dashed rounded p-5 mb-5">
                            <div class="d-flex flex-stack mb-4">
                                <div class="d-flex align-items-center">
                                    <div class="symbol symbol-40px symbol-light-info me-4">
                                        <span class="symbol-label">
                                            <i class="ki-outline ki-bill fs-2 text-info"></i>
                                        </span>
                                    </div>
                                    <div class="d-flex flex-column">
                                        <span class="fw-bold text-gray-800 fs-5">Phụ cấp</span>
                                        <span class="text-gray-500 fw-semibold fs-8">Các khoản phụ cấp theo quy định</span>
                                    </div>
                                </div>
                                <span class="fw-bold text-gray-800 fs-4">@((PayrollDetail.Allowance).ToString("N0")) đ</span>
                            </div>
                            <div class="separator separator-dashed my-3"></div>
                            <div class="d-flex flex-stack fs-7">
                                <span class="text-gray-600">Phụ cấp trách nhiệm / Chức vụ:</span>
                                <span class="text-gray-800 fw-bold">@((PayrollDetail.Allowance * 0.5m).ToString("N0")) đ</span>
                            </div>
                            <div class="d-flex flex-stack fs-7 mt-2">
                                <span class="text-gray-600">Phụ cấp xăng xe / Đi lại:</span>
                                <span class="text-gray-800 fw-bold">@((PayrollDetail.Allowance * 0.25m).ToString("N0")) đ</span>
                            </div>
                            <div class="d-flex flex-stack fs-7 mt-2">
                                <span class="text-gray-600">Phụ cấp ăn trưa:</span>
                                <span class="text-gray-800 fw-bold">@((PayrollDetail.Allowance * 0.25m).ToString("N0")) đ</span>
                            </div>
                        </div>

                        <!-- Thưởng & Khác -->
                        <div class="border border-gray-300 border-dashed rounded p-5 mb-8">
                            <div class="d-flex flex-stack mb-4">
                                <div class="d-flex align-items-center">
                                    <div class="symbol symbol-40px symbol-light-success me-4">
                                        <span class="symbol-label">
                                            <i class="ki-outline ki-gift fs-2 text-success"></i>
                                        </span>
                                    </div>
                                    <div class="d-flex flex-column">
                                        <span class="fw-bold text-gray-800 fs-5">Thưởng & Khoản cộng khác</span>
                                        <span class="text-gray-500 fw-semibold fs-8">Làm thêm giờ, hoa hồng, thưởng KPI</span>
                                    </div>
                                </div>
                                <span class="fw-bold text-gray-800 fs-4">0 đ</span>
                            </div>
                            <div class="separator separator-dashed my-3"></div>
                            <div class="d-flex flex-stack fs-7">
                                <span class="text-gray-600">Làm thêm giờ (OT):</span>
                                <span class="text-gray-800 fw-bold">0 đ</span>
                            </div>
                            <div class="d-flex flex-stack fs-7 mt-2">
                                <span class="text-gray-600">Thưởng năng suất / KPI:</span>
                                <span class="text-gray-800 fw-bold">0 đ</span>
                            </div>
                        </div>

                        <!-- TỔNG THU NHẬP BOX -->
                        <div class="card bg-primary shadow-sm rounded-4 mt-8">
                            <div class="card-body p-6">
                                <div class="d-flex flex-stack">
                                    <!--begin::Wrapper-->
                                    <div class="d-flex flex-column me-3">
                                        <div class="text-white opacity-75 fw-semibold fs-7 mb-1 text-uppercase">TỔNG THU NHẬP (GROSS)</div>
                                        <div class="text-white fw-bold fs-2x mb-1">
                                            @((PayrollDetail.BasicSalary + PayrollDetail.Allowance).ToString("N0")) <span class="fs-4 opacity-75">đ</span>
                                        </div>
                                        <div class="text-white opacity-50 fs-8">Chưa bao gồm các khoản khấu trừ (BHXH, BHYT, Thuế TNCN)</div>
                                    </div>
                                    <!--end::Wrapper-->
                                    
                                    <!--begin::Icon-->
                                    <div class="symbol symbol-60px symbol-circle symbol-light-primary bg-white bg-opacity-10 d-none d-sm-flex">
                                        <span class="symbol-label">
                                            <i class="ki-outline ki-wallet fs-2x text-white"></i>
                                        </span>
                                    </div>
                                    <!--end::Icon-->
                                </div>
                            </div>
                        </div>

                        <!-- NET SALARY BOX -->
                        <div class="card bg-danger shadow-sm rounded-4 mt-8">
                            <div class="card-body p-6">
                                <div class="d-flex flex-stack">
                                    <div class="d-flex flex-column me-3">
                                        <div class="text-white opacity-75 fw-semibold fs-7 mb-1 text-uppercase">Thực lĩnh cuối cùng</div>
                                        <div class="text-white fw-bold fs-2x mb-1">
                                            @PayrollDetail.NetSalary.ToString("N0") <span class="fs-4 opacity-75">đ</span>
                                        </div>
                                        <div class="text-white opacity-50 fs-8">Mapping hệ thống công thức & dữ liệu chấm công</div>
                                    </div>
                                    <div class="symbol symbol-60px symbol-circle symbol-light-danger bg-white bg-opacity-10 d-none d-sm-flex">
                                        <span class="symbol-label">
                                            <i class="ki-outline ki-bank fs-2x text-white"></i>
                                        </span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    </div>

                    <!-- Tab Attendance -->
                    <div class="tab-pane fade @(ActiveTab == "attendance" ? "show active" : "")" id="kt_tab_attendance" role="tabpanel">
                        <div class="mb-8">
                        <div class="d-flex flex-stack mb-3">
                            <span class="text-gray-600 fw-semibold">Lương cơ bản mapping (Gross):</span>
                            <span class="text-gray-800 fw-bold fs-6">@((PayrollDetail.BasicSalary + PayrollDetail.Allowance).ToString("N0")) đ</span>
                        </div>
                        <div class="d-flex flex-stack mb-3">
                            <span class="text-gray-600 fw-semibold">Số ngày công chuẩn (Tháng 10):</span>
                            <span class="text-gray-800 fw-bold fs-6">26 ngày</span>
                        </div>
                        <div class="d-flex flex-stack mb-8">
                            <span class="text-gray-600 fw-semibold">Lương tính mỗi ngày:</span>
                            <span class="text-primary fw-bold fs-6">@(((PayrollDetail.BasicSalary + PayrollDetail.Allowance) / 26).ToString("N0")) đ</span>
                        </div>
                        
                        <h4 class="fw-bold text-gray-500 mb-5 text-uppercase fs-7">CHI TIẾT LỊCH SỬ CHẤM CÔNG</h4>
                        
                        <div class="border rounded p-5 mb-8">
                            <div class="d-flex flex-stack mb-6 flex-wrap gap-3">
                                <div class="d-flex flex-column">
                                    <span class="fw-bold fs-5 text-gray-800">Dữ liệu chấm công</span>
                                    <span class="text-gray-400 fs-8">Lịch sử chấm công - Tháng 04/2026</span>
                                </div>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="d-flex align-items-center border border-gray-300 rounded px-3 py-1 me-2">
                                        <i class="ki-outline ki-left fs-5 text-gray-500 cursor-pointer"></i>
                                        <span class="mx-3 fw-bold text-gray-700 fs-8 text-nowrap">Tháng 4/2026</span>
                                        <i class="ki-outline ki-right fs-5 text-gray-500 cursor-pointer"></i>
                                    </div>
                                    <button class="btn btn-sm btn-light-primary fw-bold px-3 py-1 fs-8 text-nowrap">
                                        <i class="ki-outline ki-arrows-circle fs-5"></i> Đồng bộ
                                    </button>
                                    <button class="btn btn-sm btn-light fw-bold px-3 py-1 fs-8 text-nowrap">
                                        <i class="ki-outline ki-file-down fs-5"></i> Kết xuất
                                    </button>
                                </div>
                            </div>
                            
                            <div class="d-flex align-items-center border-bottom border-gray-200 border-dashed pb-5 mb-5 overflow-auto">
                                <div class="d-flex flex-column align-items-center me-10">
                                    <span class="text-primary fw-bold fs-4">@(AttendanceRecords?.Sum(x => x.WorkDays).ToString("0.0") ?? "0.0")</span>
                                    <span class="text-gray-500 fs-8 text-nowrap">Công chuẩn</span>
                                </div>
                                <div class="border-start border-gray-200 h-30px me-10"></div>
                                <div class="d-flex flex-column align-items-center me-10">
                                    <span class="text-danger fw-bold fs-4">@(AttendanceRecords?.Count(x => x.Status == "Đi muộn") ?? 0)</span>
                                    <span class="text-gray-500 fs-8 text-nowrap">Đi muộn/về sớm</span>
                                </div>
                                <div class="border-start border-gray-200 h-30px me-10"></div>
                                <div class="d-flex flex-column align-items-center me-10">
                                    <span class="text-info fw-bold fs-4">0.0h</span>
                                    <span class="text-gray-500 fs-8 text-nowrap">Giờ làm thêm</span>
                                </div>
                                <div class="border-start border-gray-200 h-30px me-10"></div>
                                <div class="d-flex flex-column align-items-center">
                                    <span class="text-success fw-bold fs-4">@(AttendanceRecords?.Count(x => x.Status == "Vắng mặt") ?? 0)</span>
                                    <span class="text-gray-500 fs-8 text-nowrap">Nghỉ/Không phép</span>
                                </div>
                            </div>
                            
                            <div class="table-responsive">
                                <table class="table align-middle table-row-dashed fs-8 gy-3 mb-0">
                                    <thead>
                                        <tr class="text-start text-gray-400 fw-bold text-uppercase gs-0">
                                            <th class="min-w-50px">NGÀY</th>
                                            <th class="min-w-50px">THỨ</th>
                                            <th class="min-w-50px">VÀO</th>
                                            <th class="min-w-50px">RA</th>
                                            <th class="min-w-60px text-center">SỐ CÔNG</th>
                                            <th class="min-w-80px text-center">TRẠNG THÁI</th>
                                            <th class="min-w-50px text-end">CHI TIẾT</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (AttendanceRecords != null && AttendanceRecords.Any())
                                        {
                                            @foreach (var record in AttendanceRecords)
                                            {
                                                <tr>
                                                    <td>
                                                        <span class="text-gray-800 fw-bold">@record.Date.ToString("dd/MM")</span>
                                                    </td>
                                                    <td>
                                                        <span class="text-gray-600 fw-semibold">@record.Date.ToString("ddd", new System.Globalization.CultureInfo("vi-VN"))</span>
                                                    </td>
                                                    <td>
                                                        <span class="text-gray-800">@record.CheckIn</span>
                                                    </td>
                                                    <td>
                                                        <span class="text-gray-800">@record.CheckOut</span>
                                                    </td>
                                                    <td class="text-center">
                                                        <span class="text-primary fw-bold">@record.WorkDays.ToString("0.0")</span>
                                                    </td>
                                                    <td class="text-center">
                                                        <span class="badge badge-light-@record.StatusColor fw-bold">@record.Status</span>
                                                    </td>
                                                    <td class="text-end">
                                                        <button class="btn btn-icon btn-active-light-primary w-30px h-30px me-3">
                                                            <i class="ki-outline ki-eye fs-3"></i>
                                                        </button>
                                                    </td>
                                                </tr>
                                            }
                                        }
                                        else
                                        {
                                            <tr>
                                                <td colspan="7" class="text-center py-10">
                                                    <div class="d-flex flex-column align-items-center">
                                                        <i class="ki-outline ki-information-5 fs-3x text-gray-400 mb-3"></i>
                                                        <span class="text-gray-500 fw-semibold fs-7">Không có dữ liệu chấm công tháng 04/2026.</span>
                                                    </div>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>

                        <!-- NET SALARY BOX -->
                        <div class="card bg-danger shadow-sm rounded-4 mt-8">
                            <div class="card-body p-6">
                                <div class="d-flex flex-stack">
                                    <div class="d-flex flex-column me-3">
                                        <div class="text-white opacity-75 fw-semibold fs-7 mb-1 text-uppercase">Thực lĩnh cuối cùng</div>
                                        <div class="text-white fw-bold fs-2x mb-1">
                                            @PayrollDetail.NetSalary.ToString("N0") <span class="fs-4 opacity-75">đ</span>
                                        </div>
                                        <div class="text-white opacity-50 fs-8">Mapping hệ thống công thức & dữ liệu chấm công</div>
                                    </div>
                                    <div class="symbol symbol-60px symbol-circle symbol-light-danger bg-white bg-opacity-10 d-none d-sm-flex">
                                        <span class="symbol-label">
                                            <i class="ki-outline ki-bank fs-2x text-white"></i>
                                        </span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    </div>




                </div>
            }
        </div>
        <!--end::Card body-->
        
        <!--begin::Card footer-->
        <div class="card-footer border-top p-5 d-flex justify-content-between align-items-center">
            <button type="button" class="btn btn-light fw-bold" data-kt-drawer-dismiss="true">Hủy bỏ</button>
            <div class="d-flex gap-2">
                <button type="button" class="btn btn-light-success text-success fw-bold">
                    <i class="ki-outline ki-printer fs-4 me-1"></i> In phiếu lương
                </button>
                <button type="button" class="btn btn-primary fw-bold">Lưu thay đổi</button>
            </div>
        </div>
        <!--end::Card footer-->
    </div>
</div>
