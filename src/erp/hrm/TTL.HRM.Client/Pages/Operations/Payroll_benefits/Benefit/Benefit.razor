<SectionContent SectionName="PageTitle">Danh mục Phụ cấp & Phúc lợi</SectionContent>

<SectionContent SectionName="PageBreadcrumbs">
    <li class="breadcrumb-item text-muted">Cấu hình</li>
    <li class="breadcrumb-item text-muted">Chính sách lương</li>
    <li class="breadcrumb-item text-gray-900">Phụ cấp & Phúc lợi</li>
