@page "/hrm/paroll"
@using TTL.Shared.Models.HRM.Operations

<SectionContent SectionName="PageTitle">Kỳ tính lương</SectionContent>
<SectionContent SectionName="PageBreadcrumbs">
    <li class="breadcrumb-item text-muted">
        <a href="/" class="text-muted text-hover-primary">Trang chủ</a>
    </li>
    <li class="breadcrumb-item">
        <span class="bullet bg-gray-500 w-5px h-2px"></span>
    </li>
    <li class="breadcrumb-item text-muted">Lương & Phúc lợi</li>
    <li class="breadcrumb-item">
        <span class="bullet bg-gray-500 w-5px h-2px"></span>
    </li>
    <li class="breadcrumb-item text-gray-900">Kỳ tính lương</li>
</SectionContent>

<div class="mb-5">
    <!--begin::Cards-->
    <div class="row g-5 g-xl-8">
        <div class="col-md-3">
            <div class="card bg-danger card-xl-stretch mb-xl-8">
                <div class="card-body p-6">
                    <div class="fs-2hx fw-bold text-white mb-2">@TotalPaymentSum.ToString("N0") <span class="fs-4 text-white opacity-75">đ</span></div>
                    <div class="fs-6 fw-semibold text-white opacity-75 text-uppercase">TỔNG THỰC LĨNH</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-light-danger card-xl-stretch mb-xl-8 border border-danger border-dashed">
                <div class="card-body p-6">
                    <div class="fs-2hx fw-bold text-danger mb-2">@TotalTaxSum.ToString("N0") <span class="fs-4 text-danger opacity-75">đ</span></div>
                    <div class="fs-6 fw-semibold text-danger opacity-75 text-uppercase">TỔNG THUẾ TNCN</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-light-success card-xl-stretch mb-xl-8 border border-success border-dashed">
                <div class="card-body p-6">
                    <div class="fs-2hx fw-bold text-success mb-2">@TotalInsuranceSum.ToString("N0") <span class="fs-4 text-success opacity-75">đ</span></div>
                    <div class="fs-6 fw-semibold text-success opacity-75 text-uppercase">TỔNG BẢO HIỂM</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-body card-xl-stretch mb-xl-8 shadow-sm">
                <div class="card-body p-6">
                    <div class="fs-2hx fw-bold text-dark mb-2">@TotalEmployeeCount</div>
                    <div class="fs-6 fw-semibold text-gray-500 text-uppercase">TỔNG NHÂN SỰ</div>
                </div>
            </div>
        </div>
    </div>
    <!--end::Cards-->
</div>

<div class="d-flex flex-wrap flex-stack pb-7">
    <!--begin::Title-->
    <div class="d-flex flex-wrap align-items-center my-1">
        <h3 class="fw-bold me-5 my-1">Bảng lương (@FilteredPayrolls.Count())</h3>
    </div>
    <!--end::Title-->
    <!--begin::Controls-->
    <div class="d-flex flex-wrap my-1 gap-3">
        <!--begin::Search-->
        <div class="d-flex align-items-center position-relative">
            <i class="ki-outline ki-magnifier fs-3 position-absolute ms-4 top-50 translate-middle-y"></i>
            <input type="text" class="form-control form-control-sm form-control-solid w-200px ps-12" placeholder="Tìm kiếm bảng lương..." @bind="SearchQuery" @bind:event="oninput" />
        </div>
        <!--end::Search-->
        <!--begin::Filters-->
        <select class="form-select form-select-sm form-select-solid w-125px" @bind="SelectedYear">
            <option value="2026">Năm 2026</option>
            <option value="2025">Năm 2025</option>
        </select>
        <select class="form-select form-select-sm form-select-solid w-150px" @bind="SelectedMonth">
            <option value="Tất cả các tháng">Tất cả các tháng</option>
            @for (int i = 1; i <= 12; i++)
            {
                <option value="@(i.ToString("D2"))">Tháng @(i.ToString("D2"))</option>
            }
        </select>
        <!--end::Filters-->
        <!--begin::Actions-->
        <button type="button" class="btn btn-sm btn-primary fw-bold" @onclick="CalculateMonthPayroll">
            <i class="ki-outline ki-plus fs-2"></i> Tính lương tháng này
        </button>
        <!--end::Actions-->
    </div>
    <!--end::Controls-->
</div>

<!-- Payroll Table List -->
<div class="card">
    <div class="card-body py-4">
        <div class="table-responsive">
            <table class="table align-middle table-row-dashed fs-6 gy-5" id="kt_payroll_table">
                <thead>
                    <tr class="text-start text-muted fw-bold fs-7 text-uppercase gs-0">
                        <th class="w-10px pe-2">
                            <div class="form-check form-check-sm form-check-custom form-check-solid me-3">
                                <input class="form-check-input" type="checkbox" data-kt-check="true" data-kt-check-target="#kt_payroll_table .form-check-input" value="1" />
                            </div>
                        </th>
                        <th class="min-w-250px">KỲ LƯƠNG</th>
                        <th class="min-w-100px text-center">THÁNG/NĂM</th>
                        <th class="min-w-100px text-center">NHÂN VIÊN</th>
                        <th class="min-w-150px text-end">TỔNG CHI TRẢ</th>
                        <th class="min-w-125px text-center">TRẠNG THÁI</th>
                        <th class="text-end min-w-100px">THAO TÁC</th>
                    </tr>
                </thead>
                <tbody class="text-gray-600 fw-semibold">
                    @foreach (var payroll in FilteredPayrolls)
                    {
                        <tr>
                            <td>
                                <div class="form-check form-check-sm form-check-custom form-check-solid">
                                    <input class="form-check-input" type="checkbox" value="1" />
                                </div>
                            </td>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="symbol symbol-40px me-3">
                                        <div class="symbol-label bg-light-@GetStatusBadgeColor(payroll.StatusId)">
                                            <i class="ki-outline @GetStatusIconClass(payroll.StatusId) fs-2 text-@GetStatusBadgeColor(payroll.StatusId)"></i>
                                        </div>
                                    </div>
                                    <div class="d-flex justify-content-start flex-column">
                                        <a href="/hrm/payroll/payroll_detail/@payroll.Code" class="text-gray-800 fw-bold text-hover-primary mb-1 fs-6">@payroll.PayrollName</a>
                                        <span class="text-gray-500 fw-semibold d-block fs-8">Mã: @payroll.Code</span>
                                    </div>
                                </div>
                            </td>
                            <td class="text-center">
                                <span class="fw-bold text-gray-800">@payroll.MonthYear</span>
                            </td>
                            <td class="text-center">
                                @if (payroll.StatusId == 1)
                                {
                                    <span class="text-muted">--</span>
                                }
                                else
                                {
                                    <span class="text-gray-800">@payroll.EmployeeCount nhân viên</span>
                                }
                            </td>
                            <td class="text-end">
                                @if (payroll.StatusId == 1)
                                {
                                    <span class="text-muted">--</span>
                                }
                                else
                                {
                                    <span class="text-gray-800 fw-bold">@payroll.TotalPayment.ToString("N0") đ</span>
                                }
                            </td>
                            <td class="text-center">
                                @if (payroll.StatusId == 1)
                                {
                                    <span class="text-muted fw-semibold fs-7">@payroll.StatusName</span>
                                }
                                else
                                {
                                    <span class="badge badge-light-@GetStatusBadgeColor(payroll.StatusId) border border-@GetStatusBadgeColor(payroll.StatusId) border-dashed fw-bold px-3 py-2">
                                        @payroll.StatusName
                                    </span>
                                }
                            </td>
                            <td class="text-end">
                                @if (payroll.StatusId == 1)
                                {
                                    <button class="btn btn-sm btn-light-primary fw-bold px-4 py-2">
                                        <i class="ki-outline ki-plus fs-4 me-1"></i> Khởi tạo
                                    </button>
                                }
                                else
                                {
                                    <a href="/hrm/payroll/payroll_detail/@payroll.Code" class="btn btn-icon btn-light-primary btn-sm me-2">
                                        <i class="ki-outline ki-eye fs-3"></i>
                                    </a>
                                    <a href="#" class="btn btn-icon btn-light-danger btn-sm">
                                        <i class="ki-outline ki-trash fs-3"></i>
                                    </a>
                                }
                            </td>
                        </tr>
                    }
                    @if (!FilteredPayrolls.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center p-10">
                                <div class="d-flex flex-column align-items-center">
                                    <i class="ki-outline ki-file-slash fs-5x text-gray-400 mb-5"></i>
                                    <div class="fs-4 fw-bold text-gray-600 mb-2">Không tìm thấy dữ liệu</div>
                                    <div class="fs-6 text-gray-500">Vui lòng thử lại với từ khóa khác</div>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
