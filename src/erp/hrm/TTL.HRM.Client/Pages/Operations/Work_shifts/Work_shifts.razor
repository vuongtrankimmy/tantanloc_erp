@page "/hrm/attendance/shifts"
@using TTL.Shared.Models.HRM.Operations
@using TTL.HRM.Client.Pages.Operations.Work_shifts

<SectionContent SectionName="PageTitle">Danh mục ca</SectionContent>

<SectionContent SectionName="PageBreadcrumbs">
    <li class="breadcrumb-item text-muted">
        <a href="/" class="text-muted text-hover-primary">Trang chủ</a>
    </li>
    <li class="breadcrumb-item text-muted">Chấm công</li>
    <li class="breadcrumb-item text-gray-900">Danh mục ca</li>
</SectionContent>

<div class="mb-5">
    <!--begin::Cards-->
    <div class="row g-5 g-xl-8">
        <div class="col-md-4">
            <div class="card bg-primary card-xl-stretch mb-xl-8">
                <div class="card-body p-6">
                    <div class="fs-2hx fw-bold text-white mb-2">@Shifts.Count</div>
                    <div class="fs-6 fw-semibold text-white opacity-75">Tổng số ca làm việc</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-success card-xl-stretch mb-xl-8">
                <div class="card-body p-6">
                    <div class="fs-2hx fw-bold text-white mb-2">@GetShiftCountByStatus(1)</div>
                    <div class="fs-6 fw-semibold text-white opacity-75">Ca Cố định</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-info card-xl-stretch mb-xl-8">
                <div class="card-body p-6">
                    <div class="fs-2hx fw-bold text-white mb-2">@GetShiftCountByStatus(2)</div>
                    <div class="fs-6 fw-semibold text-white opacity-75">Ca Linh hoạt</div>
                </div>
            </div>
        </div>
    </div>
    <!--end::Cards-->
</div>

<div class="d-flex flex-wrap flex-stack pb-7">
    <!--begin::Title-->
    <div class="d-flex flex-wrap align-items-center my-1">
        <h3 class="fw-bold me-5 my-1">Shifts (@Shifts.Count)</h3>
    </div>
    <!--end::Title-->
    <!--begin::Controls-->
    <div class="d-flex flex-wrap my-1">
        <!--begin::Search-->
        <div class="d-flex align-items-center position-relative me-4">
            <i class="ki-duotone ki-magnifier fs-3 position-absolute ms-3">
                <span class="path1"></span><span class="path2"></span>
            </i>
            <input type="text" id="kt_filter_search" class="form-control form-control-sm form-control-solid w-250px ps-10" placeholder="Tìm tên hoặc mã ca..." />
        </div>
        <!--end::Search-->
        <!--begin::Actions-->
        <div class="d-flex my-0 gap-3">
            <button type="button" class="btn btn-sm btn-light-primary fw-bold">
                <i class="ki-outline ki-abstract-14 fs-2"></i> Sơ đồ tổng quát
            </button>
            <button type="button" class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#kt_modal_add_shift" @onclick="CreateNew">
                <i class="ki-outline ki-plus fs-2"></i> Thêm ca mới
            </button>
        </div>
        <!--end::Actions-->
    </div>
    <!--end::Controls-->
</div>

<div class="card">
    <div class="card-body py-4">
        <div class="table-responsive">
            <table class="table align-middle table-row-dashed fs-6 gy-5" id="kt_table_shifts">
                <thead>
                    <tr class="text-start text-muted fw-bold fs-7 text-uppercase gs-0">
                        <th class="w-10px pe-2">
                            <div class="form-check form-check-sm form-check-custom form-check-solid me-3">
                                <input class="form-check-input" type="checkbox" data-kt-check="true" data-kt-check-target="#kt_table_shifts .form-check-input" value="1" />
                            </div>
                        </th>
                        <th class="min-w-200px">Tên ca</th>
                        <th class="text-center min-w-100px">Mã ca</th>
                        <th class="text-center min-w-150px">Thời gian làm việc</th>
                        <th class="text-center min-w-100px">Trạng thái</th>
                        <th class="text-center min-w-100px">Màu sắc</th>
                        <th class="text-end min-w-100px pe-4">Thao tác</th>
                    </tr>
                </thead>
                <tbody class="text-gray-600 fw-semibold">
                    @foreach (var shift in Shifts)
                    {
                        <tr>
                            <td>
                                <div class="form-check form-check-sm form-check-custom form-check-solid">
                                    <input class="form-check-input" type="checkbox" value="1" />
                                </div>
                            </td>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="symbol symbol-circle symbol-40px overflow-hidden me-3">
                                        <div class="symbol-label fs-3 bg-light-@shift.Color text-@shift.Color">
                                            @shift.Name.Substring(0, 1)
                                        </div>
                                    </div>
                                    <div class="d-flex flex-column">
                                        <div class="text-gray-800 fw-bold mb-1">
                                            @shift.Name
                                            @if (shift.IsDefault)
                                            {
                                                <span class="badge badge-light-danger fw-bold ms-2 fs-9">Mặc định</span>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </td>
                            <td class="text-center fw-bold">@shift.ShiftCode</td>
                            <td class="text-center">
                                <span class="badge badge-light fw-bold text-success border border-success border-dashed fs-7 px-3 py-2">@shift.StartTime</span>
                                <span class="text-muted mx-1">-</span>
                                <span class="badge badge-light fw-bold text-danger border border-danger border-dashed fs-7 px-3 py-2">@shift.EndTime</span>
                            </td>
                            <td class="text-center">
                                <span class="text-primary fw-bold">@GetStatusText(shift.StatusId)</span>
                            </td>
                            <td class="text-center">
                                <span class="badge badge-light-@shift.Color border border-@shift.Color border-dashed fs-8">@shift.Color.ToUpper()</span>
                            </td>
                            <td class="text-end pe-4">
                                <button type="button" class="btn btn-sm btn-icon btn-color-primary btn-active-light-primary show menu-dropdown" data-kt-menu-trigger="click" data-kt-menu-placement="bottom-end">
                                    <i class="ki-duotone ki-category fs-6">
                                        <span class="path1"></span>
                                        <span class="path2"></span>
                                        <span class="path3"></span>
                                        <span class="path4"></span>
                                    </i>
                                </button>
                                <div class="menu menu-sub menu-sub-dropdown menu-column menu-rounded menu-gray-800 menu-state-bg-light-primary fw-semibold w-200px py-3" data-kt-menu="true" data-popper-placement="bottom-end">
                                    <div class="menu-item px-3">
                                        <a href="javascript:void(0);" class="menu-link px-3"><i class="ki-outline ki-setting-2 fs-5 me-2 text-primary"></i> Cấu hình</a>
                                    </div>
                                    <div class="menu-item px-3">
                                        <a href="/attendance/shifts/allocate/@shift.Code" class="menu-link px-3"><i class="ki-outline ki-profile-user fs-5 me-2 text-info"></i> Nhân sự</a>
                                    </div>
                                    <div class="separator my-2"></div>
                                    <div class="menu-item px-3">
                                        <a href="javascript:void(0);" class="menu-link px-3"><i class="ki-outline ki-eye fs-5 me-2 text-success"></i> Xem chi tiết</a>
                                    </div>
                                    <div class="menu-item px-3">
                                        <a href="javascript:void(0);" class="menu-link px-3" data-bs-toggle="modal" data-bs-target="#kt_modal_add_shift" @onclick="() => EditShift(shift)"><i class="ki-outline ki-pencil fs-5 me-2 text-warning"></i> Chỉnh sửa</a>
                                    </div>
                                    <div class="menu-item px-3">
                                        <a href="javascript:void(0);" class="menu-link px-3"><i class="ki-outline ki-trash fs-5 me-2 text-danger"></i> Xóa</a>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            
            <!-- Pagination -->
            <div class="px-7 py-5 border-top">
                <div class="d-flex flex-stack flex-wrap pt-10">
                    <div class="fs-6 fw-bold text-gray-700">
                        <span>Hiển thị 1 đến @Shifts.Count trong tổng số @Shifts.Count bản ghi</span>
                    </div>
                    <ul class="pagination">
                        <li class="page-item previous disabled"><a href="javascript:;" class="page-link"><i class="ki-outline ki-left fs-2"></i></a></li>
                        <li class="page-item active"><a href="javascript:;" class="page-link">1</a></li>
                        <li class="page-item next disabled"><a href="javascript:;" class="page-link"><i class="ki-outline ki-right fs-2"></i></a></li>
                    </ul>
                </div>
            </div>
            
        </div>
    </div>
</div>

<ShiftEditModal Model="CurrentShift" OnSave="SaveShift" />

