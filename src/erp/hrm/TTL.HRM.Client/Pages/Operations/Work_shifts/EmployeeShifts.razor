@page "/hrm/shift/employee"
@using TTL.HRM.Client.Pages.Operations.Work_shifts.Components
@rendermode InteractiveServer

<SectionContent SectionName="PageTitle">Phân ca nhân sự</SectionContent>

<SectionContent SectionName="PageBreadcrumbs">
    <li class="breadcrumb-item text-muted">
        <a href="/" class="text-muted text-hover-primary">Trang chủ</a>
    </li>
    <li class="breadcrumb-item text-muted">Vận hành & Nhân sự</li>
    <li class="breadcrumb-item text-muted">Ca làm việc</li>
    <li class="breadcrumb-item text-gray-900">Phân ca nhân sự</li>
</SectionContent>

<!--begin::Header-->
<div class="d-flex flex-stack mb-5">
    <div>
        <h3 class="fw-bold fs-2 text-gray-900 mb-1">Danh sách ca nhân viên</h3>
        <span class="text-muted fs-6">Quản lý và phân bổ ca làm việc cho từng nhân viên.</span>
    </div>
    <div class="d-flex align-items-center">
        <button class="btn btn-sm btn-primary d-flex align-items-center" data-bs-toggle="offcanvas" data-bs-target="#offcanvas_employee_shift_assignment">
            <i class="ki-duotone ki-plus fs-3 me-2"></i> Phân ca mới
        </button>
    </div>
</div>
<!--end::Header-->

<!--begin::Card-->
<div class="card">
    <div class="card-header border-bottom pt-5">
        <!--begin::Filters-->
        <div class="d-flex w-100 flex-stack mb-5">
            <div class="d-flex align-items-center position-relative my-1">
                <i class="ki-duotone ki-magnifier fs-3 position-absolute ms-4"><span class="path1"></span><span class="path2"></span></i>
                <input type="text" class="form-control form-control-sm form-control-solid w-250px ps-12" placeholder="Tìm kiếm nhân viên..." />
            </div>
            <div class="d-flex align-items-center gap-3">
                <select class="form-select form-select-sm form-select-solid w-200px">
                    <option value="">Tất cả phòng ban</option>
                    <option value="KT">Kỹ thuật</option>
                    <option value="HR">Nhân sự</option>
                    <option value="KD">Kinh doanh</option>
                    <option value="MKT">Marketing</option>
                </select>
                <select class="form-select form-select-sm form-select-solid w-150px">
                    <option value="">Tuần này</option>
                    <option value="">Tuần sau</option>
                    <option value="">Tháng này</option>
                </select>
            </div>
        </div>
        <!--end::Filters-->
    </div>
    
    <div class="card-body py-4">
        <!--begin::Table-->
        <div class="table-responsive">
            <table class="table align-middle table-row-dashed fs-6 gy-5">
                <thead>
                    <tr class="text-start text-muted fw-bold fs-7 text-uppercase gs-0">
                        <th class="min-w-200px ps-4">Nhân viên</th>
                        <th class="min-w-150px">Phòng ban</th>
                        <th class="min-w-150px">Lịch làm việc tuần này</th>
                        <th class="min-w-125px">Tổng giờ dự kiến</th>
                        <th class="text-end min-w-100px pe-4">Thao tác</th>
                    </tr>
                </thead>
                <tbody class="text-gray-600 fw-semibold">
                    <tr>
                        <td class="ps-4">
                            <div class="d-flex align-items-center">
                                <div class="symbol symbol-40px symbol-circle me-3">
                                    <img src="https://ui-avatars.com/api/?name=Nguy%E1%BB%85n+V%C4%83n+An&background=random&color=fff" alt="" />
                                </div>
                                <div class="d-flex flex-column">
                                    <span class="text-gray-800 fw-bold mb-1">Nguyễn Văn An</span>
                                    <span class="text-muted fs-7">NV-0284</span>
                                </div>
                            </div>
                        </td>
                        <td>Kỹ thuật</td>
                        <td>
                            <div class="d-flex flex-column gap-1">
                                <span class="badge badge-light-primary fw-bold px-3 py-1">T2-T6: Ca Sáng</span>
                                <span class="badge badge-light-warning fw-bold px-3 py-1">T7: Ca Đêm</span>
                            </div>
                        </td>
                        <td>48 giờ</td>
                        <td class="text-end pe-4">
                            <button type="button" class="btn btn-sm btn-icon btn-color-primary btn-active-light-primary show menu-dropdown" data-kt-menu-trigger="click" data-kt-menu-placement="bottom-end">
                                <i class="ki-duotone ki-category fs-6">
                                    <span class="path1"></span><span class="path2"></span><span class="path3"></span><span class="path4"></span>
                                </i>
                            </button>
                            <div class="menu menu-sub menu-sub-dropdown menu-column menu-rounded menu-gray-800 menu-state-bg-light-primary fw-semibold w-200px py-3" data-kt-menu="true" data-popper-placement="bottom-end">
                                <div class="menu-item px-3">
                                    <a href="javascript:void(0);" class="menu-link px-3" data-bs-toggle="offcanvas" data-bs-target="#offcanvas_employee_shift_assignment">Phân ca</a>
                                </div>
                                <div class="menu-item px-3">
                                    <a href="javascript:void(0);" class="menu-link px-3" data-bs-toggle="offcanvas" data-bs-target="#offcanvas_employee_shift_assignment">Chỉnh sửa</a>
                                </div>
                            </div>
                        </td>
                    </tr>
                    <tr>
                        <td class="ps-4">
                            <div class="d-flex align-items-center">
                                <div class="symbol symbol-40px symbol-circle me-3">
                                    <img src="https://ui-avatars.com/api/?name=L%C3%AA+Th%E1%BB%8B+B%C3%ACnh&background=random&color=fff" alt="" />
                                </div>
                                <div class="d-flex flex-column">
                                    <span class="text-gray-800 fw-bold mb-1">Lê Thị Bình</span>
                                    <span class="text-muted fs-7">NV-0912</span>
                                </div>
                            </div>
                        </td>
                        <td>Nhân sự</td>
                        <td>
                            <div class="d-flex flex-column gap-1">
                                <span class="badge badge-light-secondary text-dark fw-bold px-3 py-1">T2-T6: Hành chính</span>
                            </div>
                        </td>
                        <td>40 giờ</td>
                        <td class="text-end pe-4">
                            <button type="button" class="btn btn-sm btn-icon btn-color-primary btn-active-light-primary show menu-dropdown" data-kt-menu-trigger="click" data-kt-menu-placement="bottom-end">
                                <i class="ki-duotone ki-category fs-6">
                                    <span class="path1"></span><span class="path2"></span><span class="path3"></span><span class="path4"></span>
                                </i>
                            </button>
                            <div class="menu menu-sub menu-sub-dropdown menu-column menu-rounded menu-gray-800 menu-state-bg-light-primary fw-semibold w-200px py-3" data-kt-menu="true" data-popper-placement="bottom-end">
                                <div class="menu-item px-3">
                                    <a href="javascript:void(0);" class="menu-link px-3" data-bs-toggle="offcanvas" data-bs-target="#offcanvas_employee_shift_assignment">Phân ca</a>
                                </div>
                                <div class="menu-item px-3">
                                    <a href="javascript:void(0);" class="menu-link px-3" data-bs-toggle="offcanvas" data-bs-target="#offcanvas_employee_shift_assignment">Chỉnh sửa</a>
                                </div>
                            </div>
                        </td>
                    </tr>
                    <tr>
                        <td class="ps-4">
                            <div class="d-flex align-items-center">
                                <div class="symbol symbol-40px symbol-circle me-3">
                                    <img src="https://ui-avatars.com/api/?name=Ph%E1%BA%A1m+V%C4%83n+C%C6%B0%E1%BB%9Dng&background=random&color=fff" alt="" />
                                </div>
                                <div class="d-flex flex-column">
                                    <span class="text-gray-800 fw-bold mb-1">Phạm Văn Cường</span>
                                    <span class="text-muted fs-7">NV-1044</span>
                                </div>
                            </div>
                        </td>
                        <td>Kinh doanh</td>
                        <td>
                            <div class="d-flex flex-column gap-1">
                                <span class="badge badge-light-warning fw-bold px-3 py-1">T2-T7: Ca Đêm</span>
                            </div>
                        </td>
                        <td>48 giờ</td>
                        <td class="text-end pe-4">
                            <button type="button" class="btn btn-sm btn-icon btn-color-primary btn-active-light-primary show menu-dropdown" data-kt-menu-trigger="click" data-kt-menu-placement="bottom-end">
                                <i class="ki-duotone ki-category fs-6">
                                    <span class="path1"></span><span class="path2"></span><span class="path3"></span><span class="path4"></span>
                                </i>
                            </button>
                            <div class="menu menu-sub menu-sub-dropdown menu-column menu-rounded menu-gray-800 menu-state-bg-light-primary fw-semibold w-200px py-3" data-kt-menu="true" data-popper-placement="bottom-end">
                                <div class="menu-item px-3">
                                    <a href="javascript:void(0);" class="menu-link px-3" data-bs-toggle="offcanvas" data-bs-target="#offcanvas_employee_shift_assignment">Phân ca</a>
                                </div>
                                <div class="menu-item px-3">
                                    <a href="javascript:void(0);" class="menu-link px-3" data-bs-toggle="offcanvas" data-bs-target="#offcanvas_employee_shift_assignment">Chỉnh sửa</a>
                                </div>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
        <!--end::Table-->
    </div>
</div>
<!--end::Card-->

<EmployeeShiftAssignmentDrawer />
