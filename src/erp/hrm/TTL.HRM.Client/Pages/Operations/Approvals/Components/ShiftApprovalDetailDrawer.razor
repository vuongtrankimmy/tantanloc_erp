@using TTL.HRM.Client.Pages.Operations.Approvals

<div class="offcanvas offcanvas-end w-500px" tabindex="-1" id="offcanvas_shift_approval_detail" aria-labelledby="offcanvas_shift_approval_detail_label">
    <!--begin::Header-->
    <div class="offcanvas-header border-bottom py-4 d-flex justify-content-between align-items-center">
        <div class="d-flex align-items-center">
            <button type="button" class="btn btn-icon btn-sm btn-active-light-primary me-2" data-bs-dismiss="offcanvas" aria-label="Close">
                <i class="ki-duotone ki-cross fs-2x"><span class="path1"></span><span class="path2"></span></i>
            </button>
            <h2 class="offcanvas-title fw-bold fs-3" id="offcanvas_shift_approval_detail_label">Chi tiết đơn đổi ca</h2>
        </div>
        @if (Request != null)
        {
            @if (Request.status == "pending")
            {
                <span class="badge badge-light-warning border border-warning text-warning fw-bold px-3 py-2">Đang chờ duyệt</span>
            }
            else if (Request.status == "approved")
            {
                <span class="badge badge-light-success border border-success text-success fw-bold px-3 py-2">Đã phê duyệt</span>
            }
            else
            {
                <span class="badge badge-light-danger border border-danger text-danger fw-bold px-3 py-2">Từ chối</span>
            }
        }
    </div>
    <!--end::Header-->

    <!--begin::Body-->
    <div class="offcanvas-body p-0 pb-20">
        @if (Request != null)
        {
            <!--begin::Employee Info-->
            <div class="d-flex align-items-center p-6 border-bottom border-gray-200">
                <div class="symbol symbol-50px symbol-circle me-4">
                    <img src="https://ui-avatars.com/api/?name=@Uri.EscapeDataString(Request.employeeName)&background=random&color=fff" alt="" />
                </div>
                <div class="d-flex flex-column">
                    <span class="text-gray-900 fw-bolder fs-4 mb-1">@Request.employeeName</span>
                    <span class="text-muted fw-semibold fs-7 mb-1">Mã NV: @Request.employeeId &bull; Phòng @Request.department</span>
                    <span class="text-gray-500 fs-8 fst-italic">Ngày gửi: @Request.submitDate</span>
                </div>
            </div>
            <!--end::Employee Info-->

            <div class="p-6">
                <!--begin::Compare section-->
                <div class="d-flex align-items-center mb-4">
                    <i class="ki-duotone ki-arrows-loop fs-3 text-primary me-2">
                        <span class="path1"></span><span class="path2"></span>
                    </i>
                    <h3 class="fw-bold fs-5 text-gray-900 m-0">So sánh lịch làm việc</h3>
                </div>

                <!--begin::Old Schedule-->
                <div class="border border-gray-300 rounded p-4 mb-4">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="text-muted fw-bold fs-8 text-uppercase">LỊCH CŨ</span>
                        <i class="ki-duotone ki-time fs-4 text-muted"><span class="path1"></span><span class="path2"></span></i>
                    </div>
                    <div class="fw-bolder fs-5 text-gray-900 mb-1">@Request.oldShiftDate</div>
                    <div class="d-flex align-items-center text-muted fs-7">
                        <i class="ki-duotone ki-time fs-6 me-1"><span class="path1"></span><span class="path2"></span></i>
                        @Request.currentShift (@Request.oldShiftTime)
                    </div>
                </div>
                <!--end::Old Schedule-->

                <!--begin::Arrow-->
                <div class="d-flex justify-content-center mb-4">
                    <div class="d-flex justify-content-center align-items-center bg-primary rounded-circle" style="width: 24px; height: 24px;">
                        <i class="ki-duotone ki-arrow-down fs-7 text-white"><span class="path1"></span><span class="path2"></span></i>
                    </div>
                </div>
                <!--end::Arrow-->

                <!--begin::New Schedule-->
                <div class="border border-primary bg-light-primary rounded p-4 mb-8">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="text-primary fw-bold fs-8 text-uppercase">LỊCH MỚI DỰ KIẾN</span>
                        <i class="ki-duotone ki-calendar-add fs-4 text-primary">
                            <span class="path1"></span><span class="path2"></span><span class="path3"></span><span class="path4"></span><span class="path5"></span><span class="path6"></span>
                        </i>
                    </div>
                    <div class="fw-bolder fs-5 text-gray-900 mb-1">@Request.newShiftDate</div>
                    <div class="d-flex align-items-center text-primary fs-7">
                        <i class="ki-duotone ki-time fs-6 me-1 text-primary"><span class="path1"></span><span class="path2"></span></i>
                        @Request.requestedShift (@Request.newShiftTime)
                    </div>
                </div>
                <!--end::New Schedule-->

                <!--begin::Reason-->
                <div class="mb-8">
                    <h3 class="fw-bold fs-6 text-gray-900 mb-3">Lý do xin đổi ca</h3>
                    <div class="bg-gray-100 rounded p-4 text-gray-700 fs-6">
                        @Request.reason
                    </div>
                </div>
                <!--end::Reason-->

                <!--begin::Note-->
                @if (Request.status == "pending")
                {
                    <div class="mb-5">
                        <h3 class="fw-bold fs-6 text-gray-900 mb-3">Ghi chú phê duyệt</h3>
                        <textarea class="form-control" rows="3" placeholder="Nhập lý do hoặc lời nhắn cho nhân viên..."></textarea>
                    </div>
                }
                <!--end::Note-->
            </div>
        }
    </div>
    <!--end::Body-->

    <!--begin::Footer-->
    <div class="offcanvas-footer border-top p-5 d-flex justify-content-between bg-white position-absolute bottom-0 w-100" style="z-index: 10;">
        @if (Request != null && Request.status == "pending")
        {
            <button type="button" class="btn btn-light-danger fw-bold w-50 me-3" data-bs-dismiss="offcanvas" @onclick="Reject">
                <i class="ki-duotone ki-cross fs-4 me-2"><span class="path1"></span><span class="path2"></span></i> Từ chối đơn
            </button>
            <button type="button" class="btn btn-primary fw-bold w-50" data-bs-dismiss="offcanvas" @onclick="Approve">
                <i class="ki-duotone ki-check fs-4 me-2"><span class="path1"></span><span class="path2"></span></i> Xác nhận phê duyệt
            </button>
        }
        else
        {
            <button type="button" class="btn btn-light fw-bold w-100" data-bs-dismiss="offcanvas">Đóng</button>
        }
    </div>
    <!--end::Footer-->
</div>

@code {
    [Parameter]
    public ShiftApprovalRequest? Request { get; set; }

    [Parameter]
    public EventCallback<string> OnApprove { get; set; }

    [Parameter]
    public EventCallback<string> OnReject { get; set; }

    private async Task Approve()
    {
        if (Request != null && OnApprove.HasDelegate)
        {
            await OnApprove.InvokeAsync(Request.id);
        }
    }

    private async Task Reject()
    {
        if (Request != null && OnReject.HasDelegate)
        {
            await OnReject.InvokeAsync(Request.id);
        }
    }
}
