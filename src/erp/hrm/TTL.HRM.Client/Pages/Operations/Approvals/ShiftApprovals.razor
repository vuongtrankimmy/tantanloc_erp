@page "/hrm/approvals/shifts"
@using TTL.HRM.Client.Pages.Operations.Approvals.Components
@rendermode InteractiveServer

<SectionContent SectionName="PageTitle">Phê duyệt đổi ca làm việc</SectionContent>

<SectionContent SectionName="PageBreadcrumbs">
    <li class="breadcrumb-item text-muted">
        <a href="/" class="text-muted text-hover-primary">Trang chủ</a>
    </li>
    <li class="breadcrumb-item text-muted">Phê duyệt</li>
    <li class="breadcrumb-item text-gray-900">Đổi ca làm việc</li>
</SectionContent>

<!--begin::Header-->
<div class="d-flex flex-stack mb-5">
    <div>
        <h3 class="fw-bold fs-2 text-gray-900 mb-1">Phê duyệt đổi ca làm việc</h3>
        <span class="text-muted fs-6">Quản lý và xử lý các yêu cầu thay đổi ca làm việc của nhân viên trong hệ thống.</span>
    </div>
    <div class="d-flex align-items-center">
        <button class="btn btn-sm btn-primary d-flex align-items-center me-3" data-bs-toggle="modal" data-bs-target="#kt_modal_create_shift_request">
            <i class="ki-duotone ki-plus fs-3 me-2"></i> Tạo yêu cầu
        </button>
        <button class="btn btn-sm btn-light border d-flex align-items-center">
            <i class="ki-duotone ki-exit-down fs-3 me-2">
                <span class="path1"></span><span class="path2"></span>
            </i>
            Xuất báo cáo
        </button>
    </div>
</div>
<!--end::Header-->

<!--begin::Card-->
<div class="card">
    <div class="card-header border-bottom pt-5">
        <!--begin::Tabs-->
        <div class="d-flex w-100 flex-stack">
            <ul class="nav nav-stretch nav-line-tabs nav-line-tabs-2x border-transparent fs-6 fw-bold">
                <li class="nav-item">
                    <a class="nav-link text-active-primary ms-0 me-6 py-4 @(CurrentTab == "pending" ? "active" : "")" @onclick='() => SetTab("pending")' style="cursor: pointer;">
                        Chờ duyệt (12)
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-active-primary ms-0 me-6 py-4 @(CurrentTab == "approved" ? "active" : "")" @onclick='() => SetTab("approved")' style="cursor: pointer;">
                        Đã duyệt
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-active-primary ms-0 me-6 py-4 @(CurrentTab == "rejected" ? "active" : "")" @onclick='() => SetTab("rejected")' style="cursor: pointer;">
                        Từ chối
                    </a>
                </li>
            </ul>

            <!--begin::Filters-->
            <div class="d-flex align-items-center gap-3">
                <select class="form-select form-select-sm form-select-solid w-200px">
                    <option value="">Tất cả phòng ban</option>
                    <option value="KT">Kỹ thuật</option>
                    <option value="HR">Nhân sự</option>
                    <option value="KD">Kinh doanh</option>
                    <option value="MKT">Marketing</option>
                </select>
                <select class="form-select form-select-sm form-select-solid w-150px">
                    <option value="">Tất cả loại ca</option>
                    <option value="SANG">Ca Sáng</option>
                    <option value="CHIEU">Ca Chiều</option>
                    <option value="DEM">Ca Đêm</option>
                    <option value="HC">Hành chính</option>
                </select>
            </div>
            <!--end::Filters-->
        </div>
        <!--end::Tabs-->
    </div>
    
    <div class="card-body py-4">
        <!--begin::Table-->
        <div class="table-responsive">
            <table class="table align-middle table-row-dashed fs-6 gy-5">
                <thead>
                    <tr class="text-start text-muted fw-bold fs-7 text-uppercase gs-0">
                        <th class="min-w-200px ps-4">Nhân viên</th>
                        <th class="min-w-100px">Ca hiện tại</th>
                        <th class="min-w-100px">Ca muốn đổi</th>
                        <th class="min-w-200px">Lý do</th>
                        <th class="min-w-125px">Ngày áp dụng</th>
                        <th class="min-w-100px">Trạng thái</th>
                        <th class="text-end min-w-200px pe-4">Thao tác</th>
                    </tr>
                </thead>
                <tbody class="text-gray-600 fw-semibold">
                    @foreach (var req in Requests.Where(r => r.status == CurrentTab || (CurrentTab == "pending" && r.status == "pending")))
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="d-flex align-items-center">
                                    <div class="symbol symbol-40px symbol-circle me-3">
                                        <img src="https://ui-avatars.com/api/?name=@Uri.EscapeDataString(req.employeeName)&background=random&color=fff" alt="" />
                                    </div>
                                    <div class="d-flex flex-column">
                                        <span class="text-gray-800 fw-bold mb-1">@req.employeeName</span>
                                        <span class="text-muted fs-7">ID: @req.employeeId - @req.department</span>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <span class="badge badge-light-@(req.currentShiftColor) fw-bold px-3 py-2">@req.currentShift</span>
                            </td>
                            <td>
                                <span class="badge badge-light-@(req.requestedShiftColor) fw-bold px-3 py-2 text-@(req.requestedShiftColor)">@req.requestedShift</span>
                            </td>
                            <td>
                                <span class="text-gray-700 text-truncate d-inline-block" style="max-width: 200px;">@req.reason</span>
                            </td>
                            <td>
                                @req.applyDate
                            </td>
                            <td>
                                @if (req.status == "pending")
                                {
                                    <span class="text-warning fw-bold d-flex align-items-center">
                                        <span class="bullet bullet-dot bg-warning me-2"></span> Chờ duyệt
                                    </span>
                                }
                                else if (req.status == "approved")
                                {
                                    <span class="text-success fw-bold d-flex align-items-center">
                                        <span class="bullet bullet-dot bg-success me-2"></span> Đã duyệt
                                    </span>
                                }
                                else if (req.status == "rejected")
                                {
                                    <span class="text-danger fw-bold d-flex align-items-center">
                                        <span class="bullet bullet-dot bg-danger me-2"></span> Từ chối
                                    </span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                <button type="button" class="btn btn-sm btn-icon btn-color-primary btn-active-light-primary show menu-dropdown" data-kt-menu-trigger="click" data-kt-menu-placement="bottom-end">
                                    <i class="ki-duotone ki-category fs-6">
                                        <span class="path1"></span><span class="path2"></span><span class="path3"></span><span class="path4"></span>
                                    </i>
                                </button>
                                <div class="menu menu-sub menu-sub-dropdown menu-column menu-rounded menu-gray-800 menu-state-bg-light-primary fw-semibold w-200px py-3" data-kt-menu="true" data-popper-placement="bottom-end">
                                    <div class="menu-item px-3">
                                        <a href="javascript:void(0);" class="menu-link px-3" data-bs-toggle="offcanvas" data-bs-target="#offcanvas_shift_approval_detail" @onclick="() => ShowDetail(req)">Xem chi tiết</a>
                                    </div>
                                    @if (req.status == "pending")
                                    {
                                        <div class="menu-item px-3">
                                            <a href="javascript:void(0);" class="menu-link px-3 text-success" @onclick="() => ApproveRequest(req.id)">Phê duyệt</a>
                                        </div>
                                        <div class="menu-item px-3">
                                            <a href="javascript:void(0);" class="menu-link px-3 text-danger" @onclick="() => RejectRequest(req.id)">Từ chối</a>
                                        </div>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <!--end::Table-->

        <!--begin::Pagination-->
        <div class="d-flex flex-stack border-top pt-5 px-4">
            <div class="fs-6 fw-semibold text-gray-700">
                Hiển thị 1-4 trên tổng số 12 yêu cầu
            </div>
            <ul class="pagination">
                <li class="page-item previous disabled"><a href="#" class="page-link"><i class="previous"></i></a></li>
                <li class="page-item active"><a href="#" class="page-link">1</a></li>
                <li class="page-item"><a href="#" class="page-link">2</a></li>
                <li class="page-item"><a href="#" class="page-link">3</a></li>
                <li class="page-item next"><a href="#" class="page-link"><i class="next"></i></a></li>
            </ul>
        </div>
        <!--end::Pagination-->
    </div>
</div>
<!--end::Card-->

<ShiftApprovalDetailDrawer Request="SelectedRequest" OnApprove="ApproveRequest" OnReject="RejectRequest" />
<CreateShiftApprovalModal />
