<div class="card mb-5 mb-xl-10">
    <div class="card-header cursor-pointer">
        <div class="card-title m-0">
            <h3 class="fw-bold m-0">Thông tin nghỉ phép</h3>
        </div>
    </div>
    <div class="card-body p-9">
        <!-- Summary Cards -->
        <div class="row g-5 g-xl-8 mb-8">
            <div class="col-xl-3">
                <div class="border border-primary border-dashed rounded p-5">
                    <span class="fs-8 fw-semibold text-muted text-uppercase d-block mb-1">Tổng ngày phép</span>
                    <span class="fs-1 fw-bold text-primary">15</span>
                </div>
            </div>
            <div class="col-xl-3">
                <div class="border border-success border-dashed rounded p-5">
                    <span class="fs-8 fw-semibold text-muted text-uppercase d-block mb-1">Đã sử dụng</span>
                    <span class="fs-1 fw-bold text-success">2</span>
                </div>
            </div>
            <div class="col-xl-3">
                <div class="border border-info border-dashed rounded p-5">
                    <span class="fs-8 fw-semibold text-muted text-uppercase d-block mb-1">Đang chờ duyệt</span>
                    <span class="fs-1 fw-bold text-info">1</span>
                </div>
            </div>
            <div class="col-xl-3">
                <div class="border border-danger border-dashed rounded p-5">
                    <span class="fs-8 fw-semibold text-muted text-uppercase d-block mb-1">Còn lại</span>
                    <span class="fs-1 fw-bold text-danger">13</span>
                </div>
            </div>
        </div>

        <!-- Leave Requests List -->
        <div class="mt-10">
            <h4 class="fw-bold text-gray-900 mb-5">Danh sách yêu cầu nghỉ phép</h4>
            <div class="table-responsive">
                <table class="table table-row-dashed table-row-gray-300 align-middle gs-0 gy-4">
                    <thead>
                        <tr class="fw-bold text-muted bg-light text-uppercase fs-8 text-center">
                            <th class="ps-4 min-w-150px rounded-start text-start">LOẠI NGHỈ</th>
                            <th class="min-w-150px">THỜI GIAN</th>
                            <th class="min-w-100px">TỔNG NGÀY</th>
                            <th class="min-w-200px text-start">LÝ DO</th>
                            <th class="min-w-100px text-end rounded-end pe-4">TRẠNG THÁI</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td class="ps-4 text-start">
                                <span class="bullet bullet-vertical h-20px bg-warning me-2"></span>
                                <span class="text-gray-800 fw-semibold">Nghỉ phép năm</span>
                            </td>
                            <td class="text-center text-gray-800 fw-semibold">20/02 - 20/02</td>
                            <td class="text-center text-primary fw-bold">1</td>
                            <td class="text-start text-gray-600">Khám sức khỏe định kỳ</td>
                            <td class="text-end pe-4"><span class="badge badge-light-warning">Pending</span></td>
                        </tr>
                        <tr>
                            <td class="ps-4 text-start">
                                <span class="bullet bullet-vertical h-20px bg-success me-2"></span>
                                <span class="text-gray-800 fw-semibold">Nghỉ phép năm</span>
                            </td>
                            <td class="text-center text-gray-800 fw-semibold">15/01 - 16/01</td>
                            <td class="text-center text-primary fw-bold">2</td>
                            <td class="text-start text-gray-600">Nghỉ phép gia đình</td>
                            <td class="text-end pe-4"><span class="badge badge-light-success">Approved</span></td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
