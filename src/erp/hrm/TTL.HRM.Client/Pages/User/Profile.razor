@page "/user/profile"
@page "/user/profile/{Id}"
@rendermode InteractiveServer
@using TTL.Shared.UI.Layouts.Component
@using TTL.HRM.Client.Pages.User.Components

<SectionContent SectionName="PageTitle">Profile</SectionContent>

<SectionContent SectionName="PageBreadcrumbs">
    <li class="breadcrumb-item text-muted">
        <a href="/" class="text-muted text-hover-primary">Trang chủ</a>
    </li>
    <li class="breadcrumb-item text-muted">User</li>
    <li class="breadcrumb-item text-gray-900">Profile</li>
</SectionContent>

<!-- Navbar -->
<div class="card mb-5 mb-xl-10">
    <div class="card-body pt-9 pb-0">
        <!-- Details -->
        <div class="d-flex flex-wrap flex-sm-nowrap">
            <!-- Avatar -->
            <div class="me-7 mb-4">
                <div class="symbol symbol-100px symbol-lg-160px symbol-fixed position-relative">
                    <img src="_content/TTL.Shared.UI/assets/media/avatars/300-1.jpg" alt="image" onerror="this.src='_content/TTL.Shared.UI/assets/media/avatars/blank.png';" />
                    <div class="position-absolute translate-middle bottom-0 start-100 mb-6 bg-success rounded-circle border border-4 border-body h-20px w-20px"></div>
                </div>
            </div>
            
            <!-- Info -->
            <div class="flex-grow-1">
                <!-- Title -->
                <div class="d-flex justify-content-between align-items-start flex-wrap mb-2">
                    <div class="d-flex flex-column">
                        <div class="d-flex align-items-center mb-2">
                            <a href="#" class="text-gray-900 text-hover-primary fs-2 fw-bold me-1">Phạm Minh Hùng</a>
                            <a href="#"><i class="ki-outline ki-verify fs-1 text-primary"></i></a>
                            <a href="#" class="btn btn-sm btn-light-success fw-bold ms-2 fs-8 py-1 px-3">Đang hoạt động</a>
                        </div>

                        <div class="d-flex flex-wrap fw-semibold fs-6 mb-4 pe-2">
                            <a href="#" class="d-flex align-items-center text-gray-500 text-hover-primary me-5 mb-2">
                                <i class="ki-outline ki-profile-circle fs-4 me-1"></i> Developer
                            </a>
                            <a href="#" class="d-flex align-items-center text-gray-500 text-hover-primary me-5 mb-2">
                                <i class="ki-outline ki-geolocation fs-4 me-1"></i> Hồ Chí Minh, VN
                            </a>
                            <a href="#" class="d-flex align-items-center text-gray-500 text-hover-primary mb-2">
                                <i class="ki-outline ki-sms fs-4 me-1"></i> hung.pham@domain.com
                            </a>
                        </div>
                    </div>

                    <!-- Actions -->
                    <div class="d-flex my-4">
                        <a href="#" class="btn btn-sm btn-light me-2" id="kt_user_follow_button">
                            <i class="ki-outline ki-check fs-3 d-none"></i>
                            <span class="indicator-label">Đổi mật khẩu</span>
                        </a>
                        <a href="#" class="btn btn-sm btn-primary me-3">Chỉnh sửa hồ sơ</a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Nav tabs -->
        <ul class="nav nav-stretch nav-line-tabs nav-line-tabs-2x border-transparent fs-5 fw-bold">
            <li class="nav-item mt-2">
                <a class="nav-link text-active-primary ms-0 me-10 py-5 @(ActiveTab == "Overview" ? "active" : "")" href="javascript:void(0)" @onclick="@(() => SetTab("Overview"))">Tổng quan</a>
            </li>
            <li class="nav-item mt-2">
                <a class="nav-link text-active-primary ms-0 me-10 py-5 @(ActiveTab == "Contracts" ? "active" : "")" href="javascript:void(0)" @onclick="@(() => SetTab("Contracts"))">Hợp đồng</a>
            </li>
            <li class="nav-item mt-2">
                <a class="nav-link text-active-primary ms-0 me-10 py-5 @(ActiveTab == "Payroll" ? "active" : "")" href="javascript:void(0)" @onclick="@(() => SetTab("Payroll"))">Lương & Thưởng</a>
            </li>
            <li class="nav-item mt-2">
                <a class="nav-link text-active-primary ms-0 me-10 py-5 @(ActiveTab == "Documents" ? "active" : "")" href="javascript:void(0)" @onclick="@(() => SetTab("Documents"))">Tài liệu</a>
            </li>
            <li class="nav-item mt-2">
                <a class="nav-link text-active-primary ms-0 me-10 py-5 @(ActiveTab == "Expertise" ? "active" : "")" href="javascript:void(0)" @onclick="@(() => SetTab("Expertise"))">Chuyên môn</a>
            </li>
            <li class="nav-item mt-2">
                <a class="nav-link text-active-primary ms-0 me-10 py-5 @(ActiveTab == "Attendance" ? "active" : "")" href="javascript:void(0)" @onclick="@(() => SetTab("Attendance"))">Lịch sử chấm công</a>
            </li>
            <li class="nav-item mt-2">
                <a class="nav-link text-active-primary ms-0 me-10 py-5 @(ActiveTab == "Leaves" ? "active" : "")" href="javascript:void(0)" @onclick="@(() => SetTab("Leaves"))">Nghỉ phép</a>
            </li>
            <li class="nav-item mt-2">
                <a class="nav-link text-active-primary ms-0 me-10 py-5 @(ActiveTab == "Logs" ? "active" : "")" href="javascript:void(0)" @onclick="@(() => SetTab("Logs"))">Nhật ký</a>
            </li>
        </ul>
    </div>
</div>

<!-- Tab content -->
<div class="tab-content">
    @if (ActiveTab == "Overview")
    {
        <ProfileOverview />
    }
    else if (ActiveTab == "Contracts")
    {
        <ProfileContracts />
    }
    else if (ActiveTab == "Payroll")
    {
        <ProfilePayroll />
    }
    else if (ActiveTab == "Documents")
    {
        <ProfileDocuments />
    }
    else if (ActiveTab == "Expertise")
    {
        <ProfileExpertise />
    }
    else if (ActiveTab == "Attendance")
    {
        <ProfileAttendance />
    }
    else if (ActiveTab == "Leaves")
    {
        <ProfileLeaves />
    }
    else if (ActiveTab == "Logs")
    {
        <ProfileLogs />
    }
</div>

