@page "/hrm/setting/bank"

<SectionContent SectionName="PageTitle">Danh sách Ngân hàng</SectionContent>

<SectionContent SectionName="PageBreadcrumbs">
    <li class="breadcrumb-item text-muted">
        <a href="/" class="text-muted text-hover-primary">Home</a>
    </li>
    <li class="breadcrumb-item text-muted">Quản trị hệ thống</li>
    <li class="breadcrumb-item text-muted">Cài đặt & cấu hình</li>
    <li class="breadcrumb-item text-gray-900">Ngân hàng</li>
</SectionContent>

<div class="mb-5">
    <!--begin::Cards-->
    <div class="row g-5 g-xl-8">
        <div class="col-md-4">
            <div class="card bg-primary card-xl-stretch mb-xl-8">
                <div class="card-body p-6">
                    <div class="fs-2hx fw-bold text-white mb-2">@(banks?.Count() ?? 0)</div>
                    <div class="fs-6 fw-semibold text-white opacity-75">Tổng số ngân hàng</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-success card-xl-stretch mb-xl-8">
                <div class="card-body p-6">
                    <div class="fs-2hx fw-bold text-white mb-2">@(banks?.Count(x => x.StatusId == 1) ?? 0)</div>
                    <div class="fs-6 fw-semibold text-white opacity-75">Đang hoạt động</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-danger card-xl-stretch mb-xl-8">
                <div class="card-body p-6">
                    <div class="fs-2hx fw-bold text-white mb-2">@(banks?.Count(x => x.StatusId == 0) ?? 0)</div>
                    <div class="fs-6 fw-semibold text-white opacity-75">Ngưng hoạt động</div>
                </div>
            </div>
        </div>
    </div>
    <!--end::Cards-->
</div>

<div class="d-flex flex-wrap flex-stack pb-7">
    <!--begin::Title-->
    <div class="d-flex flex-wrap align-items-center my-1">
        <h3 class="fw-bold me-5 my-1">Danh sách Ngân hàng (@(banks?.Count() ?? 0))</h3>
    </div>
    <!--end::Title-->
    <!--begin::Controls-->
    <div class="d-flex flex-wrap my-1">
        <!--begin::Search-->
        <div class="d-flex align-items-center position-relative me-4">
            <i class="ki-duotone ki-magnifier fs-3 position-absolute ms-3">
                <span class="path1"></span>
                <span class="path2"></span>
            </i>
            <input type="text" id="kt_filter_search" class="form-control form-control-sm form-control-solid w-150px ps-10" placeholder="Tìm kiếm" />
        </div>
        <!--end::Search-->
        <!--begin::Actions-->
        <div class="d-flex my-0">
            <a href="javascript:;" class="btn btn-sm btn-primary">Thêm mới</a>
        </div>
        <!--end::Actions-->
    </div>
    <!--end::Controls-->
</div>

<div class="tab-content">
    <div id="kt_project_users_table_pane" class="tab-pane fade show active" role="tabpanel">
        <div class="card card-flush">
            <div class="card-body pt-0">
                <table id="kt_project_users_table" class="table table-row-bordered table-row-dashed gy-4 align-middle fw-bold">
                    <thead class="fs-7 text-gray-500 text-uppercase">
                        <tr>
                            <th class="min-w-250px">
                                <span class="dt-column-title">TÊN NGÂN HÀNG</span>
                            </th>
                            <th class="text-center min-w-100px">
                                <span class="dt-column-title">MÃ (BIN)</span>
                            </th>
                            <th class="text-center min-w-100px">
                                <span class="dt-column-title">SWIFT CODE</span>
                            </th>
                            <th class="text-end min-w-100px">
                                <span class="dt-column-title">TRẠNG THÁI</span>
                            </th>
                            <th class="text-end pe-4 rounded-end min-w-100px">
                                <span class="dt-column-title">THAO TÁC</span>
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (banks == null)
                        {
                            <tr>
                                <td colspan="5" class="text-center">Đang tải dữ liệu...</td>
                            </tr>
                        }
                        else if (!banks.Any())
                        {
                            <tr>
                                <td colspan="5" class="text-center">Không có dữ liệu.</td>
                            </tr>
                        }
                        else
                        {
                            foreach (var bank in banks)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <div class="symbol symbol-45px me-4">
                                                <span class="symbol-label bg-light-primary">
                                                    <i class="ki-outline ki-bank fs-3 text-primary"></i>
                                                </span>
                                            </div>
                                            <div class="d-flex justify-content-start flex-column">
                                                <span class="text-dark fw-bolder text-hover-primary fs-6 mb-1">@bank.ShortName</span>
                                                <span class="text-muted fw-bold fs-7">@bank.FullName</span>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-center">
                                        <span class="badge badge-light fw-bolder px-3 py-2 border">@bank.Code</span>
                                    </td>
                                    <td class="text-center">
                                        <span class="fw-bold ms-3">@bank.SwiftCode</span>
                                    </td>
                                    <td class="text-end pe-0">
                                        @if(bank.StatusId == 1)
                                        {
                                            <div class="badge badge-light-primary">@bank.Status</div>
                                        }
                                        else
                                        {
                                            <div class="badge badge-light-danger">@bank.Status</div>
                                        }
                                    </td>
                                    <td class="text-end">
                                        <button type="button" class="btn btn-clean btn-sm btn-icon btn-icon-primary btn-active-light-primary me-n3" data-kt-menu-trigger="click" data-kt-menu-placement="bottom-end">
                                            <i class="ki-duotone ki-element-plus fs-3 text-primary">
                                                <span class="path1"></span>
                                                <span class="path2"></span>
                                                <span class="path3"></span>
                                                <span class="path4"></span>
                                                <span class="path5"></span>
                                            </i>
                                        </button>
                                        <!--begin::Menu-->
                                        <div class="menu menu-sub menu-sub-dropdown menu-column menu-rounded menu-gray-600 menu-state-bg-light-primary fw-semibold fs-7 w-125px py-4" data-kt-menu="true">
                                            <div class="menu-item px-3">
                                                <a href="javascript:;" class="menu-link px-3"><i class="ki-duotone ki-pencil fs-4 me-2"><span class="path1"></span><span class="path2"></span></i> Sửa</a>
                                            </div>
                                            <div class="menu-item px-3">
                                                <a href="javascript:;" class="menu-link px-3 text-danger"><i class="ki-duotone ki-trash fs-4 me-2 text-danger"><span class="path1"></span><span class="path2"></span><span class="path3"></span><span class="path4"></span><span class="path5"></span></i> Xóa</a>
                                            </div>
                                        </div>
                                        <!--end::Menu-->
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
                <div class="px-7 py-5 border-top">
                    <div class="d-flex flex-stack flex-wrap pt-10">
                        <div class="fs-6 fw-bold text-gray-700">
                            <span>Hiển thị 1 đến @(banks?.Count() ?? 0) trong tổng số @(banks?.Count() ?? 0) bản ghi</span>
                        </div>
                        <ul class="pagination">
                            <li class="page-item previous disabled">
                                <a href="javascript:;" class="page-link">
                                    <i class="ki-outline ki-left fs-2"></i>
                                </a>
                            </li>
                            <li class="page-item active">
                                <a href="javascript:;" class="page-link">1</a>
                            </li>
                            <li class="page-item next disabled">
                                <a href="javascript:;" class="page-link">
                                    <i class="ki-outline ki-right fs-2"></i>
                                </a>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
