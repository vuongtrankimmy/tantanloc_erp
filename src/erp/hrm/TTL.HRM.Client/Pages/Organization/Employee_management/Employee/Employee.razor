@page "/hrm/employee"
@using TTL.Shared.Models.HRM.Organization
@using TTL.HRM.Client.Pages.Organization.Employee_management.Employee_detail
@using System.Net.Http.Json

<SectionContent SectionName="PageTitle">Danh sách Nhân viên</SectionContent>

<SectionContent SectionName="PageBreadcrumbs">
    <li class="breadcrumb-item text-muted">
        <a href="/" class="text-muted text-hover-primary">Home</a>
    </li>
    <li class="breadcrumb-item text-muted">Tổ chức & Nhân sự</li>
    <li class="breadcrumb-item text-gray-900">Nhân viên</li>
</SectionContent>

<div class="mb-5">
    <!--begin::Cards-->
    <div class="row g-5 g-xl-8">
        <div class="col-md-4">
            <div class="card bg-primary card-xl-stretch mb-xl-8">
                <div class="card-body p-6">
                    <div class="fs-2hx fw-bold text-white mb-2">@Employees.Count</div>
                    <div class="fs-6 fw-semibold text-white opacity-75">Tổng số nhân sự</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-success card-xl-stretch mb-xl-8">
                <div class="card-body p-6">
                    <div class="fs-2hx fw-bold text-white mb-2">@Employees.Count(e => e.StatusId == 1)</div>
                    <div class="fs-6 fw-semibold text-white opacity-75">Đang làm việc</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-danger card-xl-stretch mb-xl-8">
                <div class="card-body p-6">
                    <div class="fs-2hx fw-bold text-white mb-2">@Employees.Count(e => e.StatusId != 1)</div>
                    <div class="fs-6 fw-semibold text-white opacity-75">Nghỉ phép / Thôi việc</div>
                </div>
            </div>
        </div>
    </div>
    <!--end::Cards-->
</div>

<div class="d-flex flex-wrap flex-stack pb-7">
    <!--begin::Title-->
    <div class="d-flex flex-wrap align-items-center my-1">
        <h3 class="fw-bold me-5 my-1">Nhân viên (@Employees.Count)</h3>
    </div>
    <!--end::Title-->
    <!--begin::Controls-->
    <div class="d-flex flex-wrap my-1">
        <!--begin::Tab nav-->
        <ul class="nav nav-pills me-6 mb-2 mb-sm-0" role="tablist">
            <li class="nav-item m-0" role="presentation">
                <a class="btn btn-sm btn-icon btn-light btn-color-muted btn-active-primary me-3 @GetActiveCssClass(ViewMode.Card)" @onclick="() => SetActiveView(ViewMode.Card)" aria-selected="@(ActiveView == ViewMode.Card)" role="button" tabindex="-1">
                    <i class="ki-duotone ki-element-plus fs-2">
                        <span class="path1"></span><span class="path2"></span><span class="path3"></span><span class="path4"></span><span class="path5"></span>
                    </i>
                </a>
            </li>
            <li class="nav-item m-0" role="presentation">
                <a class="btn btn-sm btn-icon btn-light btn-color-muted btn-active-primary @GetActiveCssClass(ViewMode.Table)" @onclick="() => SetActiveView(ViewMode.Table)" aria-selected="@(ActiveView == ViewMode.Table)" role="button">
                    <i class="ki-duotone ki-row-horizontal fs-2">
                        <span class="path1"></span><span class="path2"></span>
                    </i>
                </a>
            </li>
        </ul>
        <!--end::Tab nav-->
        <!--begin::Search-->
        <div class="d-flex align-items-center position-relative me-4">
            <i class="ki-duotone ki-magnifier fs-3 position-absolute ms-3">
                <span class="path1"></span><span class="path2"></span>
            </i>
            <input type="text" id="kt_filter_search" class="form-control form-control-sm form-control-solid w-200px ps-10" placeholder="Tìm kiếm nhân viên" />
        </div>
        <!--end::Search-->
        <!--begin::Actions-->
        <div class="d-flex my-0">
            <!--begin::Select-->
            <select name="department" class="form-select form-select-sm border-body bg-body w-150px me-5">
                <option value="">Tất cả phòng ban</option>
                <option value="1">Kỹ thuật</option>
                <option value="2">Marketing</option>
                <option value="3">Tài chính</option>
                <option value="4">Kinh doanh</option>
            </select>
            <!--end::Select-->
            <a href="/hrm/employee/create" class="btn btn-sm btn-primary">Thêm mới</a>
        </div>
        <!--end::Actions-->
    </div>
    <!--end::Controls-->
</div>

<div class="tab-content">
    <div id="kt_project_users_card_pane" class="tab-pane fade @GetShowActiveCssClass(ViewMode.Card)" role="tabpanel">
        <div class="row g-6 g-xl-9">
        </div>
    </div>
    <div id="kt_project_users_table_pane" class="tab-pane fade @GetShowActiveCssClass(ViewMode.Table)" role="tabpanel">
        <div class="card card-flush">
            <div class="card-body pt-0">
                <table id="kt_project_users_table" class="table table-row-bordered table-row-dashed gy-4 align-middle fw-bold">
                    <thead class="fs-7 text-gray-500 text-uppercase">
                        <tr>
                            <th class="min-w-250px">HỌ TÊN & EMAIL</th>
                            <th class="text-center min-w-100px">MÃ NV</th>
                            <th class="text-center min-w-150px">CHỨC VỤ</th>
                            <th class="text-center min-w-150px">PHÒNG BAN</th>
                            <th class="text-center min-w-100px">TRẠNG THÁI</th>
                            <th class="text-end pe-4 rounded-end min-w-100px">THAO TÁC</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var emp in Employees)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="symbol symbol-40px me-4">
                                            <img src="https://ui-avatars.com/api/?name=@(Uri.EscapeDataString(emp.FullName))&background=@emp.AvatarColor&color=fff" alt="" />
                                        </div>
                                        <div class="d-flex justify-content-start flex-column">
                                            <a href="javascript:;" class="text-dark fw-bolder text-hover-primary fs-6 mb-1">@emp.FullName</a>
                                            <span class="text-muted fw-bold fs-7">@emp.Email</span>
                                        </div>
                                    </div>
                                </td>
                                <td class="text-center">
                                    <span class="badge badge-light fw-bolder px-3 py-2 border">@emp.Code</span>
                                </td>
                                <td class="text-center">
                                    <span class="text-gray-800 fw-semibold">@emp.Position</span>
                                </td>
                                <td class="text-center">
                                    <span class="badge @emp.DepartmentBadgeClass fw-bold px-3 py-2">@emp.Department</span>
                                </td>
                                <td class="text-center">
                                    <div class="badge @emp.StatusBadgeClass">@emp.Status</div>
                                </td>
                                <td class="text-end">
                                    <button type="button" class="btn btn-sm btn-icon btn-color-primary btn-active-light-primary show menu-dropdown" data-kt-menu-trigger="click" data-kt-menu-placement="bottom-end">
                                        <i class="ki-duotone ki-category fs-6">
                                            <span class="path1"></span>
                                            <span class="path2"></span>
                                            <span class="path3"></span>
                                            <span class="path4"></span>
                                        </i>
                                    </button>
                                    <div class="menu menu-sub menu-sub-dropdown menu-column menu-rounded menu-gray-800 menu-state-bg-light-primary fw-semibold w-200px py-3z" data-kt-menu="true" data-popper-placement="bottom-end">
                                        <!--begin::Menu item-->
                                        <div class="menu-item px-3">
                                            <a href="javascript:void(0);" class="menu-link px-3 kt_drawer_employee_detail_toggle" @onclick="() => SelectEmployee(emp)">Xem</a>
                                        </div>
                                        <!--end::Menu item-->
                                        <!--begin::Menu item-->
                                          <div class="menu-item px-3">
                                              <a href="/hrm/employee/edit/@emp.Code" class="menu-link px-3">Sửa</a>
                                          </div>
                                        <!--end::Menu item-->
                                        <!--begin::Menu item-->
                                        <div class="menu-item px-3">
                                            <a href="#" class="menu-link px-3">Xóa</a>
                                        </div>
                                        <!--end::Menu item-->
                                        <!--begin::Menu separator-->
                                        <div class="separator my-2"></div>
                                        <!--end::Menu separator-->
                                        <!--end::Menu sub-->
                                    </div>
                                    <!--end::Menu item-->
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            <div class="px-7 py-5 border-top">
                <div class="d-flex flex-stack flex-wrap pt-10">
                    <div class="fs-6 fw-bold text-gray-700">
                        <span>Hiển thị 1 đến @Employees.Count trong tổng số @Employees.Count bản ghi</span>
                    </div>
                    <ul class="pagination">
                        <li class="page-item previous disabled"><a href="javascript:;" class="page-link"><i class="ki-outline ki-left fs-2"></i></a></li>
                        <li class="page-item active"><a href="javascript:;" class="page-link">1</a></li>
                        <li class="page-item next disabled"><a href="javascript:;" class="page-link"><i class="ki-outline ki-right fs-2"></i></a></li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>
</div>

<EmployeeDetailDrawer Employee="SelectedEmployee" />


