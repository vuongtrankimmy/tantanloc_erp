@page "/hrm/contract"
@page "/hrm/contract/templates"
@using TTL.Shared.Models.HRM.Organization

<SectionContent SectionName="PageTitle">Mẫu hợp đồng nâng cao</SectionContent>

<SectionContent SectionName="PageBreadcrumbs">
    <li class="breadcrumb-item text-muted">
        <a href="/" class="text-muted text-hover-primary">Quản lý nhân sự</a>
    </li>
    <li class="breadcrumb-item text-gray-900">Hợp đồng</li>
</SectionContent>

<div class="d-flex flex-wrap flex-stack pb-7">
    <!--begin::Title-->
    <div class="d-flex flex-wrap align-items-center my-1">
        <h3 class="fw-bolder fs-1 me-5 my-1 text-dark">Mẫu hợp đồng nâng cao</h3>
    </div>
    <!--end::Title-->
    <!--begin::Controls-->
    <div class="d-flex flex-wrap my-1">
        <a href="hrm/contract/create" class="btn btn-sm btn-primary fw-bold">
            <i class="ki-duotone ki-plus fs-3"></i> Tạo mẫu mới
        </a>
    </div>
    <!--end::Controls-->
</div>

<div class="card shadow-sm mb-5 mb-xl-8">
    <div class="card-header border-0 pt-6 pb-2">
        <div class="d-flex flex-wrap flex-stack w-100 gap-3">
            <div class="position-relative w-100 w-md-400px">
                <i class="ki-duotone ki-magnifier fs-3 text-gray-500 position-absolute top-50 translate-middle-y ms-3"><span class="path1"></span><span class="path2"></span></i>
                <input type="text" class="form-control form-control-solid ps-10 bg-light" placeholder="Tìm kiếm theo tên mẫu hoặc số hiệu mẫu..." />
            </div>
            
            <div class="d-flex align-items-center gap-3">
                <select class="form-select form-select-solid w-150px bg-light">
                    <option value="">Trạng thái</option>
                    <option value="active">Đang sử dụng</option>
                    <option value="draft">Nháp</option>
                </select>
                
                <button type="button" class="btn btn-light border border-gray-300 text-gray-700 fw-bold">
                    <i class="ki-duotone ki-filter fs-3"><span class="path1"></span><span class="path2"></span></i> Lọc nâng cao
                </button>
            </div>
        </div>
        
        <!-- Tabs -->
        <div class="d-flex align-items-center w-100 mt-5 border-bottom">
            <ul class="nav nav-stretch nav-line-tabs nav-line-tabs-2x border-transparent fs-5 fw-bold">
                <li class="nav-item mt-2">
                    <a class="nav-link text-active-primary ms-0 me-10 py-5 @(ActiveTab == "all" ? "active" : "")" href="javascript:;" @onclick='() => SetTab("all")'>
                        Tất cả mẫu (@Templates.Count)
                    </a>
                </li>
                <li class="nav-item mt-2">
                    <a class="nav-link text-active-primary ms-0 me-10 py-5 @(ActiveTab == "active" ? "active" : "")" href="javascript:;" @onclick='() => SetTab("active")'>
                        Đang sử dụng (@Templates.Count(t => t.status == "Đang sử dụng"))
                    </a>
                </li>
                <li class="nav-item mt-2">
                    <a class="nav-link text-active-primary ms-0 me-10 py-5 @(ActiveTab == "draft" ? "active" : "")" href="javascript:;" @onclick='() => SetTab("draft")'>
                        Nháp (@Templates.Count(t => t.status == "Nháp"))
                    </a>
                </li>
            </ul>
        </div>
    </div>
    
    <div class="card-body py-0">
        <!--begin::Table-->
        <div class="table-responsive">
            <table class="table align-middle table-row-dashed fs-6 gy-5">
                <thead>
                    <tr class="text-start text-muted fw-bolder fs-8 text-uppercase gs-0">
                        <th class="min-w-250px">TÊN MẪU HỢP ĐỒNG</th>
                        <th class="min-w-150px">SỐ HIỆU MẪU</th>
                        <th class="min-w-125px">NGÀY TẠO</th>
                        <th class="min-w-200px">NGƯỜI CẬP NHẬT CUỐI</th>
                        <th class="min-w-100px text-end pe-4">TRẠNG THÁI</th>
                    </tr>
                </thead>
                <tbody class="text-gray-600 fw-semibold">
                    @foreach (var template in GetFilteredTemplates())
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="symbol symbol-35px symbol-square me-3">
                                        @if (template.status == "Đang sử dụng")
                                        {
                                            <span class="symbol-label bg-light-primary"><i class="ki-duotone ki-document fs-2 text-primary"><span class="path1"></span><span class="path2"></span></i></span>
                                        }
                                        else
                                        {
                                            <span class="symbol-label bg-light"><i class="ki-duotone ki-document fs-2 text-gray-500"><span class="path1"></span><span class="path2"></span></i></span>
                                        }
                                    </div>
                                    <div class="d-flex justify-content-start flex-column">
                                        <a href="hrm/contract/edit/@template.id" class="text-gray-900 fw-bold text-hover-primary fs-6">@template.template_name</a>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <a href="javascript:;" class="text-primary fw-semibold fs-6">@template.template_code</a>
                            </td>
                            <td>
                                <span class="text-gray-600 fs-6">@template.created_date.ToString("dd/MM/yyyy")</span>
                            </td>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="symbol symbol-30px symbol-circle me-3">
                                        <span class="symbol-label fw-bold @GetAvatarClass(template.last_updated_by)">@GetInitial(template.last_updated_by)</span>
                                    </div>
                                    <span class="text-gray-700 fs-6">@template.last_updated_by</span>
                                </div>
                            </td>
                            <td class="text-end pe-0">
                                <span class="badge @GetStatusBadgeClass(template.status) fw-bold px-3 py-1 fs-8">@template.status</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <!--end::Table-->

        <!--begin::Pagination-->
        <div class="d-flex flex-stack flex-wrap pt-4 pb-5 border-top border-dashed">
            <div class="fs-6 fw-semibold text-gray-500">
                Hiển thị 1-10 của @Templates.Count mẫu
            </div>
            <ul class="pagination">
                <li class="page-item previous disabled"><a href="javascript:;" class="page-link text-muted"><i class="ki-outline ki-left fs-2"></i></a></li>
                <li class="page-item active"><a href="javascript:;" class="page-link">1</a></li>
                <li class="page-item"><a href="javascript:;" class="page-link">2</a></li>
                <li class="page-item"><a href="javascript:;" class="page-link">3</a></li>
                <li class="page-item next"><a href="javascript:;" class="page-link text-muted"><i class="ki-outline ki-right fs-2"></i></a></li>
            </ul>
        </div>
        <!--end::Pagination-->
    </div>
</div>

<!-- Info Cards -->
<div class="row g-5 g-xl-8">
    <div class="col-md-4">
        <div class="card bg-light-primary border-0">
            <div class="card-body p-6 d-flex align-items-start">
                <i class="ki-duotone ki-bulb fs-1 text-primary me-4 mt-1"><span class="path1"></span><span class="path2"></span></i>
                <div>
                    <h4 class="fw-bolder text-dark mb-1">Tra cứu nhanh</h4>
                    <span class="text-primary fw-semibold fs-7">Bạn có thể tìm kiếm bằng số hiệu (VD: QT-NS-01) để định vị nhanh mẫu văn bản cần dùng.</span>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card bg-light border-0">
            <div class="card-body p-6 d-flex align-items-start">
                <i class="ki-duotone ki-information-5 fs-1 text-gray-600 me-4 mt-1"><span class="path1"></span><span class="path2"></span><span class="path3"></span></i>
                <div>
                    <h4 class="fw-bolder text-dark mb-1">Mô tả chi tiết</h4>
                    <span class="text-gray-600 fw-semibold fs-7">Di chuột vào tên mẫu để xem nhanh phần mô tả chi tiết của từng loại hợp đồng.</span>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card bg-light-info border-0">
            <div class="card-body p-6 d-flex align-items-start">
                <i class="ki-duotone ki-chart-simple fs-1 text-info me-4 mt-1"><span class="path1"></span><span class="path2"></span><span class="path3"></span><span class="path4"></span></i>
                <div>
                    <h4 class="fw-bolder text-dark mb-1">Thống kê sử dụng</h4>
                    <span class="text-info fw-semibold fs-7">Cột "Số lượng áp dụng" cho biết tổng số hợp đồng thực tế đã được ký kết từ mẫu này.</span>
                </div>
            </div>
        </div>
    </div>
</div>
