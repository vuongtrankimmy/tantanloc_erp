@page "/hrm/contract/create"
@page "/hrm/contract/edit/{Id}"
@using TTL.Shared.Models.HRM.Organization

<SectionContent SectionName="PageTitle">Thông tin chi tiết</SectionContent>

<SectionContent SectionName="PageBreadcrumbs">
    <li class="breadcrumb-item text-muted">
        <a href="/" class="text-muted text-hover-primary">Quản trị nhân sự</a>
    </li>
    <li class="breadcrumb-item text-gray-900">Thiết lập chi tiết mẫu hợp đồng</li>
</SectionContent>

<div class="d-flex flex-wrap flex-stack pb-7">
    <div class="d-flex flex-wrap align-items-center my-1">
        <h3 class="fw-bolder fs-1 me-5 my-1 text-dark">Thiết lập chi tiết mẫu hợp đồng</h3>
    </div>
    <div class="d-flex flex-wrap my-1 gap-2">
        <button type="button" class="btn btn-sm btn-light fw-bold" @onclick="GoBack">
            Quay lại
        </button>
        <button type="button" class="btn btn-sm btn-primary fw-bold" @onclick="SaveChanges">
            <i class="ki-duotone ki-save fs-3"><span class="path1"></span><span class="path2"></span></i> Lưu thay đổi
        </button>
    </div>
</div>

<div class="row g-5 g-xl-8">
    <!-- Main Content -->
    <div class="col-xl-9">
        <!-- Form Fields -->
        <div class="card shadow-sm mb-5">
            <div class="card-body p-8">
                <div class="row mb-8">
                    <div class="col-lg-8 mb-4 mb-lg-0">
                        <label class="form-label fw-bold text-gray-700 fs-6">Tên mẫu hợp đồng</label>
                        <input type="text" class="form-control" @bind="Template.template_name" />
                    </div>
                    <div class="col-lg-4">
                        <label class="form-label fw-bold text-gray-700 fs-6">Số hiệu mẫu (Code)</label>
                        <input type="text" class="form-control" @bind="Template.template_code" />
                    </div>
                </div>

                <div class="row">
                    <div class="col-lg-12">
                        <label class="form-label fw-bold text-gray-700 fs-6">Mô tả chi tiết mẫu</label>
                        <textarea class="form-control" rows="3" placeholder="Nhập mô tả về phạm vi áp dụng của mẫu hợp đồng này..." @bind="Template.description"></textarea>
                    </div>
                </div>
            </div>
        </div>

        <!-- Editor Content -->
        <div class="card shadow-sm mb-5">
            <div class="card-header pt-6 border-0">
                <div class="card-title flex-column">
                    <h3 class="fw-bolder mb-1">Nội dung mẫu hợp đồng</h3>
                    <div class="fs-6 fw-semibold text-muted">Chỉnh sửa nội dung văn bản và chèn các biến động từ danh sách bên phải.</div>
                </div>
            </div>
            <div class="card-body pt-2">
                <!-- Fake Quill Toolbar -->
                <div class="border border-bottom-0 rounded-top p-3 bg-light d-flex gap-2">
                    <button class="btn btn-icon btn-sm btn-active-light-primary"><i class="ki-duotone ki-text-bold fs-3"><span class="path1"></span><span class="path2"></span></i></button>
                    <button class="btn btn-icon btn-sm btn-active-light-primary"><i class="ki-duotone ki-text-italic fs-3"><span class="path1"></span><span class="path2"></span></i></button>
                    <button class="btn btn-icon btn-sm btn-active-light-primary"><i class="ki-duotone ki-text-underline fs-3"><span class="path1"></span><span class="path2"></span><span class="path3"></span></i></button>
                    <div class="separator separator-vertical my-1 mx-2"></div>
                    <button class="btn btn-icon btn-sm btn-active-light-primary"><i class="ki-duotone ki-text-align-left fs-3"><span class="path1"></span><span class="path2"></span><span class="path3"></span></i></button>
                    <button class="btn btn-icon btn-sm btn-active-light-primary"><i class="ki-duotone ki-text-align-center fs-3"><span class="path1"></span><span class="path2"></span><span class="path3"></span></i></button>
                    <button class="btn btn-icon btn-sm btn-active-light-primary"><i class="ki-duotone ki-text-align-right fs-3"><span class="path1"></span><span class="path2"></span><span class="path3"></span></i></button>
                </div>
                <!-- Fake Quill Editor Area -->
                <div class="border rounded-bottom p-5 min-h-400px fs-5" contenteditable="true" style="outline: none;">
                    @if (!string.IsNullOrEmpty(Template.content))
                    {
                        @((MarkupString)Template.content)
                    }
                    else
                    {
                        <p class="text-muted">Nhập nội dung hợp đồng...</p>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Sidebar Variables Content -->
    <div class="col-xl-3">
        <div class="card shadow-sm mb-5 d-flex flex-column h-100">
            <div class="card-header pt-6 border-0">
                <div class="card-title flex-column">
                    <h3 class="fw-bolder mb-1">Danh sách biến</h3>
                    <div class="fs-7 fw-semibold text-muted">Nhấp hoặc kéo thả biến vào văn bản để tự động điền.</div>
                </div>
            </div>
            <div class="card-body pt-2 d-flex flex-column">
                <div class="position-relative mb-5">
                    <i class="ki-duotone ki-magnifier fs-3 text-gray-500 position-absolute top-50 translate-middle-y ms-3"><span class="path1"></span><span class="path2"></span></i>
                    <input type="text" class="form-control form-control-sm form-control-solid ps-10" placeholder="Tìm kiếm biến..." />
                </div>

                <div class="flex-grow-1 overflow-auto h-400px pe-2">
                    <!-- Company Vars -->
                    <div class="mb-5">
                        <h5 class="text-primary fw-bold mb-3"><i class="ki-duotone ki-bank fs-4 text-primary me-2"><span class="path1"></span><span class="path2"></span></i> CÔNG TY</h5>
                        <div class="d-flex flex-column gap-2 ms-5">
                            <span class="badge badge-light-primary py-2 px-3 fs-7 fw-semibold cursor-pointer text-start text-hover-primary">@("{{Ten_Cong_Ty}}")</span>
                            <span class="badge badge-light-primary py-2 px-3 fs-7 fw-semibold cursor-pointer text-start text-hover-primary">@("{{Dia_Chi_Cong_Ty}}")</span>
                            <span class="badge badge-light-primary py-2 px-3 fs-7 fw-semibold cursor-pointer text-start text-hover-primary">@("{{SDT_Cong_Ty}}")</span>
                            <span class="badge badge-light-primary py-2 px-3 fs-7 fw-semibold cursor-pointer text-start text-hover-primary">@("{{MST_Cong_Ty}}")</span>
                            <span class="badge badge-light-primary py-2 px-3 fs-7 fw-semibold cursor-pointer text-start text-hover-primary">@("{{STK_Cong_Ty}}")</span>
                        </div>
                    </div>

                    <!-- Employee Vars -->
                    <div class="mb-5">
                        <h5 class="text-info fw-bold mb-3"><i class="ki-duotone ki-user fs-4 text-info me-2"><span class="path1"></span><span class="path2"></span></i> NHÂN VIÊN</h5>
                        <div class="d-flex flex-column gap-2 ms-5">
                            <span class="badge badge-light-info py-2 px-3 fs-7 fw-semibold cursor-pointer text-start text-hover-info">@("{{Ten_Nhan_Vien}}")</span>
                            <span class="badge badge-light-info py-2 px-3 fs-7 fw-semibold cursor-pointer text-start text-hover-info">@("{{Ma_Nhan_Vien}}")</span>
                            <span class="badge badge-light-info py-2 px-3 fs-7 fw-semibold cursor-pointer text-start text-hover-info">@("{{Ngay_Sinh}}")</span>
                            <span class="badge badge-light-info py-2 px-3 fs-7 fw-semibold cursor-pointer text-start text-hover-info">@("{{Quoc_Tich}}")</span>
                            <span class="badge badge-light-info py-2 px-3 fs-7 fw-semibold cursor-pointer text-start text-hover-info">@("{{Nghe_Nghiep}}")</span>
                            <span class="badge badge-light-info py-2 px-3 fs-7 fw-semibold cursor-pointer text-start text-hover-info">@("{{So_CMND_CCCD}}")</span>
                        </div>
                    </div>

                    <!-- Contract Vars -->
                    <div class="mb-5">
                        <h5 class="text-success fw-bold mb-3"><i class="ki-duotone ki-document fs-4 text-success me-2"><span class="path1"></span><span class="path2"></span></i> HỢP ĐỒNG</h5>
                        <div class="d-flex flex-column gap-2 ms-5">
                            <span class="badge badge-light-success py-2 px-3 fs-7 fw-semibold cursor-pointer text-start text-hover-success">@("{{Ma_Hop_Dong}}")</span>
                            <span class="badge badge-light-success py-2 px-3 fs-7 fw-semibold cursor-pointer text-start text-hover-success">@("{{Loai_Hop_Dong}}")</span>
                            <span class="badge badge-light-success py-2 px-3 fs-7 fw-semibold cursor-pointer text-start text-hover-success">@("{{Thoi_Han_Hop_Dong}}")</span>
                            <span class="badge badge-light-success py-2 px-3 fs-7 fw-semibold cursor-pointer text-start text-hover-success">@("{{Ngay_Bat_Dau}}")</span>
                            <span class="badge badge-light-success py-2 px-3 fs-7 fw-semibold cursor-pointer text-start text-hover-success">@("{{Ngay_Ket_Thuc}}")</span>
                            <span class="badge badge-light-success py-2 px-3 fs-7 fw-semibold cursor-pointer text-start text-hover-success">@("{{Dia_Diem_Lam_Viec}}")</span>
                            <span class="badge badge-light-success py-2 px-3 fs-7 fw-semibold cursor-pointer text-start text-hover-success">@("{{Thoi_Gian_Lam_Viec}}")</span>
                            <span class="badge badge-light-success py-2 px-3 fs-7 fw-semibold cursor-pointer text-start text-hover-success">@("{{Ngay_Ki_Hop_Dong}}")</span>
                            <span class="badge badge-light-success py-2 px-3 fs-7 fw-semibold cursor-pointer text-start text-hover-success">@("{{Muc_Luong}}")</span>
                            <span class="badge badge-light-success py-2 px-3 fs-7 fw-semibold cursor-pointer text-start text-hover-success">@("{{Phu_Cap}}")</span>
                        </div>
                    </div>
                </div>

                <div class="mt-auto pt-5 border-top">
                    <button class="btn btn-light-primary w-100 fw-bold">
                        <i class="ki-duotone ki-question fs-3"><span class="path1"></span><span class="path2"></span><span class="path3"></span></i> Hướng dẫn sử dụng
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>
