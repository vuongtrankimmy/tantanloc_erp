@page "/hrm/department"
@rendermode InteractiveServer
@using TTL.HRM.Client.Pages.Organization.Company_structure.Department.Components
<SectionContent SectionName="PageTitle">Danh sách Phòng ban</SectionContent>

<SectionContent SectionName="PageBreadcrumbs">
    <li class="breadcrumb-item text-muted">
        <a href="/" class="text-muted text-hover-primary">Home</a>
    </li>
    <li class="breadcrumb-item text-muted">Tổ chức & Nhân sự</li>
    <li class="breadcrumb-item text-muted">Cấu trúc công ty</li>
    <li class="breadcrumb-item text-gray-900">Phòng ban</li>
</SectionContent>

<div class="mb-5">
    <!--begin::Cards-->
    <div class="row g-5 g-xl-8">
        <div class="col-md-4">
            <div class="card bg-primary card-xl-stretch mb-xl-8">
                <div class="card-body p-6">
                    <div class="fs-2hx fw-bold text-white mb-2">38</div>
                    <div class="fs-6 fw-semibold text-white opacity-75">Tổng số phòng ban</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-success card-xl-stretch mb-xl-8">
                <div class="card-body p-6">
                    <div class="fs-2hx fw-bold text-white mb-2">35</div>
                    <div class="fs-6 fw-semibold text-white opacity-75">Phòng ban đang hoạt động</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-danger card-xl-stretch mb-xl-8">
                <div class="card-body p-6">
                    <div class="fs-2hx fw-bold text-white mb-2">3</div>
                    <div class="fs-6 fw-semibold text-white opacity-75">Phòng ban ngưng hoạt động</div>
                </div>
            </div>
        </div>
    </div>
    <!--end::Cards-->
</div>

<div class="d-flex flex-wrap flex-stack pb-7">
    <!--begin::Title-->
    <div class="d-flex flex-wrap align-items-center my-1">
        <h3 class="fw-bold me-5 my-1">Phòng ban (38)</h3>
    </div>
    <!--end::Title-->
    <!--begin::Controls-->
    <div class="d-flex flex-wrap my-1">
        <!--begin::Tab nav-->
        <ul class="nav nav-pills me-6 mb-2 mb-sm-0" role="tablist">
            <li class="nav-item m-0" role="presentation">
                <a class="btn btn-sm btn-icon btn-light btn-color-muted btn-active-primary me-3" data-bs-toggle="tab" href="#kt_project_users_card_pane" aria-selected="false" role="tab" tabindex="-1">
                    <i class="ki-duotone ki-element-plus fs-2">
                        <span class="path1"></span>
                        <span class="path2"></span>
                        <span class="path3"></span>
                        <span class="path4"></span>
                        <span class="path5"></span>
                    </i>
                </a>
            </li>
            <li class="nav-item m-0" role="presentation">
                <a class="btn btn-sm btn-icon btn-light btn-color-muted btn-active-primary active" data-bs-toggle="tab" href="#kt_project_users_table_pane" aria-selected="true" role="tab">
                    <i class="ki-duotone ki-row-horizontal fs-2">
                        <span class="path1"></span>
                        <span class="path2"></span>
                    </i>
                </a>
            </li>
        </ul>
        <!--end::Tab nav-->
        <!--begin::Search-->
        <div class="d-flex align-items-center position-relative me-4">
            <i class="ki-duotone ki-magnifier fs-3 position-absolute ms-3">
                <span class="path1"></span>
                <span class="path2"></span>
            </i>
            <input type="text" id="kt_filter_search" class="form-control form-control-sm form-control-solid w-150px ps-10" placeholder="Tìm kiếm" />
        </div>
        <!--end::Search-->
        <!--begin::Actions-->
        <div class="d-flex my-0">
            <!--begin::Select-->
            <select name="status" data-control="select2" data-hide-search="true" data-placeholder="Trạng thái" class="form-select form-select-sm border-body bg-body w-150px me-5">
                <option value="1">Đang hoạt động</option>
                <option value="2">Ngưng hoạt động</option>
            </select>
            <!--end::Select-->
            <a href="javascript:;" class="btn btn-sm btn-primary">Thêm mới</a>
        </div>
        <!--end::Actions-->
    </div>
    <!--end::Controls-->
</div>

<div class="tab-content">
    <div id="kt_project_users_card_pane" class="tab-pane fade" role="tabpanel">
        <div class="row g-6 g-xl-9">
        </div>
    </div>
    <div id="kt_project_users_table_pane" class="tab-pane fade show active" role="tabpanel">
        <DepartmentTable Departments="@departments" OnShowDetail="ShowDetail" />
    </div>
</div>

<!-- Right Sidebar / Offcanvas -->
<div class="offcanvas offcanvas-end w-400px w-md-500px" tabindex="-1" id="kt_department_detail_panel">
    <div class="offcanvas-header border-bottom">
        <h3 class="offcanvas-title fw-bold">Chi tiết phòng ban</h3>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
    </div>
    <div class="offcanvas-body p-0 bg-light">
        <DepartmentDetail Code="@selectedDeptCode" />
    </div>
</div>
