@page "/hrm/position"

<SectionContent SectionName="PageTitle">Danh sách Chức vụ</SectionContent>

<SectionContent SectionName="PageBreadcrumbs">
    <li class="breadcrumb-item text-muted">
        <a href="/" class="text-muted text-hover-primary">Home</a>
    </li>
    <li class="breadcrumb-item text-muted">Tổ chức & Nhân sự</li>
    <li class="breadcrumb-item text-muted">Cấu trúc công ty</li>
    <li class="breadcrumb-item text-gray-900">Chức vụ</li>
</SectionContent>

<div class="mb-5">
    <!--begin::Cards-->
    <div class="row g-5 g-xl-8">
        <div class="col-md-4">
            <div class="card bg-primary card-xl-stretch mb-xl-8">
                <div class="card-body p-6">
                    <div class="fs-2hx fw-bold text-white mb-2">10</div>
                    <div class="fs-6 fw-semibold text-white opacity-75">Tổng số chức danh</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-success card-xl-stretch mb-xl-8">
                <div class="card-body p-6">
                    <div class="fs-2hx fw-bold text-white mb-2">0</div>
                    <div class="fs-6 fw-semibold text-white opacity-75">Chức danh đang sử dụng</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-danger card-xl-stretch mb-xl-8">
                <div class="card-body p-6">
                    <div class="fs-2hx fw-bold text-white mb-2">0</div>
                    <div class="fs-6 fw-semibold text-white opacity-75">Tuyển dụng</div>
                </div>
            </div>
        </div>
    </div>
    <!--end::Cards-->
</div>

<div class="d-flex flex-wrap flex-stack pb-7">
    <!--begin::Title-->
    <div class="d-flex flex-wrap align-items-center my-1">
        <h3 class="fw-bold me-5 my-1">Chức vụ (10)</h3>
    </div>
    <!--end::Title-->
    <!--begin::Controls-->
    <div class="d-flex flex-wrap my-1">
        <!--begin::Tab nav-->
        <ul class="nav nav-pills me-6 mb-2 mb-sm-0" role="tablist">
            <li class="nav-item m-0" role="presentation">
                <a class="btn btn-sm btn-icon btn-light btn-color-muted btn-active-primary me-3" data-bs-toggle="tab" href="#kt_project_users_card_pane" aria-selected="false" role="tab" tabindex="-1">
                    <i class="ki-duotone ki-element-plus fs-2">
                        <span class="path1"></span>
                        <span class="path2"></span>
                        <span class="path3"></span>
                        <span class="path4"></span>
                        <span class="path5"></span>
                    </i>
                </a>
            </li>
            <li class="nav-item m-0" role="presentation">
                <a class="btn btn-sm btn-icon btn-light btn-color-muted btn-active-primary active" data-bs-toggle="tab" href="#kt_project_users_table_pane" aria-selected="true" role="tab">
                    <i class="ki-duotone ki-row-horizontal fs-2">
                        <span class="path1"></span>
                        <span class="path2"></span>
                    </i>
                </a>
            </li>
        </ul>
        <!--end::Tab nav-->
        <!--begin::Search-->
        <div class="d-flex align-items-center position-relative me-4">
            <i class="ki-duotone ki-magnifier fs-3 position-absolute ms-3">
                <span class="path1"></span>
                <span class="path2"></span>
            </i>
            <input type="text" id="kt_filter_search" class="form-control form-control-sm form-control-solid w-150px ps-10" placeholder="Tìm kiếm" />
        </div>
        <!--end::Search-->
        <!--begin::Actions-->
        <div class="d-flex my-0">
            <!--begin::Select-->
            <select name="status" data-control="select2" data-hide-search="true" data-placeholder="Filter" class="form-select form-select-sm border-body bg-body w-150px me-5 select2-hidden-accessible" data-select2-id="select2-data-7-ehmj" tabindex="-1" aria-hidden="true" data-kt-initialized="1">
                <option value="1" data-select2-id="select2-data-9-g0c1">Recently Updated</option>
                <option value="2">Last Month</option>
                <option value="3">Last Quarter</option>
                <option value="4">Last Year</option>
            </select>
            <!--end::Select-->
            <a href="javascript:;" class="btn btn-sm btn-primary">Thêm mới</a>
        </div>
        <!--end::Actions-->
    </div>
    <!--end::Controls-->
</div>

<div class="tab-content">
    <div id="kt_project_users_card_pane" class="tab-pane fade" role="tabpanel">
        <div class="row g-6 g-xl-9">
        </div>
    </div>
    <div id="kt_project_users_table_pane" class="tab-pane fade show active" role="tabpanel">
        <div class="card card-flush">
            <div class="card-body pt-0">
                <table id="kt_project_users_table" class="table table-row-bordered table-row-dashed gy-4 align-middle fw-bold">
                        <thead class="fs-7 text-gray-500 text-uppercase">
                            <tr>
                                <th class="min-w-250px">
                                    <span class="dt-column-title">CHỨC DANH</span>
                                </th>
                                <th class="text-center min-w-100px">
                                    <span class="dt-column-title">CHUYÊN MÔN</span>
                                </th>
                                <th class="text-center min-w-100px">
                                    <span class="dt-column-title">CẤP ĐỘ</span>
                                </th>
                                <th class="text-center min-w-100px">
                                    <span class="dt-column-title">NHÂN SỰ</span>
                                </th>
                                <th class="text-center min-w-200px">
                                    <span class="dt-column-title">MỨC LƯƠNG CƠ SỞ</span>
                                </th>
                                <th class="text-center min-w-100px">
                                    <span class="dt-column-title">YÊU CẦU</span>
                                </th>
                                <th class="text-end pe-4 rounded-end min-w-100px">
                                    <span class="dt-column-title">THAO TÁC</span>
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (positions == null)
                            {
                                <tr>
                                    <td colspan="7" class="text-center">Đang tải dữ liệu...</td>
                                </tr>
                            }
                            else if (!positions.Any())
                            {
                                <tr>
                                    <td colspan="7" class="text-center">Không có dữ liệu.</td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var pos in positions)
                                {
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <div class="symbol symbol-40px me-4">
                                                    <span class="symbol-label bg-light-primary">
                                                        <i class="ki-outline ki-briefcase fs-3 text-primary"></i>
                                                    </span>
                                                </div>
                                                <div class="d-flex justify-content-start flex-column">
                                                    <span class="text-dark fw-bolder fs-6">@pos.name</span>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="text-center">
                                            <span class="text-gray-800 fw-semibold">@pos.job_group</span>
                                        </td>
                                        <td class="text-center">
                                            <span class="text-gray-800 fw-semibold">@pos.level</span>
                                        </td>
                                        <td class="text-center">
                                            <span class="text-gray-800 fw-semibold">@pos.headcount</span>
                                        </td>
                                        <td class="text-center">
                                            <span class="text-gray-800 fw-bold">@pos.salary_range</span>
                                        </td>
                                        <td class="text-center">
                                            <span class="text-gray-800 fw-semibold">@pos.requests</span>
                                        </td>
                                        <td class="text-end">
                                            <a href="#" class="btn btn-clean btn-sm btn-icon btn-icon-primary btn-active-light-primary me-n3" data-kt-menu-trigger="click" data-kt-menu-placement="bottom-end">
                                                <i class="ki-duotone ki-element-plus fs-3 text-primary">
                                                    <span class="path1"></span>
                                                    <span class="path2"></span>
                                                    <span class="path3"></span>
                                                    <span class="path4"></span>
                                                    <span class="path5"></span>
                                                </i>
                                            </a>
                                            <!--begin::Menu-->
                                            <div class="menu menu-sub menu-sub-dropdown menu-column menu-rounded menu-gray-600 menu-state-bg-light-primary fw-semibold fs-7 w-125px py-4" data-kt-menu="true">
                                                <div class="menu-item px-3">
                                                    <a href="javascript:;" class="menu-link px-3"><i class="ki-duotone ki-eye fs-4 me-2"><span class="path1"></span><span class="path2"></span><span class="path3"></span></i> Xem</a>
                                                </div>
                                                <div class="menu-item px-3">
                                                    <a href="javascript:;" class="menu-link px-3"><i class="ki-duotone ki-pencil fs-4 me-2"><span class="path1"></span><span class="path2"></span></i> Sửa</a>
                                                </div>
                                                <div class="menu-item px-3">
                                                    <a href="javascript:;" class="menu-link px-3 text-danger"><i class="ki-duotone ki-trash fs-4 me-2 text-danger"><span class="path1"></span><span class="path2"></span><span class="path3"></span><span class="path4"></span><span class="path5"></span></i> Xóa</a>
                                                </div>
                                            </div>
                                            <!--end::Menu-->
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                <div class="px-7 py-5 border-top">
                    <div class="d-flex flex-stack flex-wrap pt-10">
                        <div class="fs-6 fw-bold text-gray-700">
                            <span>Hiển thị 1 đến 10 trong tổng số 10 bản ghi</span>
                        </div>
                        <ul class="pagination">
                            <li class="page-item previous disabled">
                                <a href="javascript:;" class="page-link">
                                    <i class="ki-outline ki-left fs-2"></i>
                                </a>
                            </li>
                            <li class="page-item active">
                                <a href="javascript:;" class="page-link">1</a>
                            </li>
                            <li class="page-item next disabled">
                                <a href="javascript:;" class="page-link">
                                    <i class="ki-outline ki-right fs-2"></i>
                                </a>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
