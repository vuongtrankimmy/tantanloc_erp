@page "/hrm"

<PageTitle>HRM Dashboard</PageTitle>

<div class="container-fluid py-5">
    <div class="row mb-4">
        <div class="col-12">
            <h1 class="display-5 fw-bold">Human Resources Management</h1>
            <p class="text-muted">Welcome to the HRM module dashboard.</p>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body">
                    <h5 class="card-title text-primary"><i class="bi bi-people-fill me-2"></i> Employee Profiles</h5>
                    <p class="card-text">Manage employee records, personal details, and job information.</p>
                    <a href="#" class="btn btn-outline-primary mt-3">Go to Profiles</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body">
                    <h5 class="card-title text-success"><i class="bi bi-calendar-check me-2"></i> Leave Management</h5>
                    <p class="card-text">Approve or reject leave requests and monitor employee absences.</p>
                    <a href="#" class="btn btn-outline-success mt-3">Manage Leaves</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body">
                    <h5 class="card-title text-warning"><i class="bi bi-cash-coin me-2"></i> Payroll</h5>
                    <p class="card-text">Process payroll, manage salaries, bonuses, and deductions.</p>
                    <a href="#" class="btn btn-outline-warning mt-3">Payroll System</a>
                </div>
            </div>
        </div>
    </div>
</div>
