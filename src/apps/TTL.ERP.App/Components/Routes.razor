<Router AppAssembly="@typeof(MauiProgram).Assembly" AdditionalAssemblies="new[] { typeof(TTL.Auth.Client.Pages.Login).Assembly, typeof(TTL.Shared.UI._Imports).Assembly, typeof(TTL.HRM.Client.Pages.HrmDashboard).Assembly }">
    <Found Context="routeData">
        <RouteView RouteData="@routeData" DefaultLayout="@typeof(TTL.Shared.UI.Layouts.ErpMainLayout)" />
        <FocusOnNavigate RouteData="@routeData" Selector="h1" />
    </Found>
    <NotFound>
        <PageTitle>Not found</PageTitle>
        <LayoutView Layout="@typeof(TTL.Shared.UI.Layouts.ErpMainLayout)">
            <p role="alert">Sorry, there's nothing at this address.</p>
        </LayoutView>
    </NotFound>
</Router>
